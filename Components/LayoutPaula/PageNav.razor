@inject NavigationManager Nav

<nav class="tables-nav">
    <div class="tables-nav-brand">
        <div class="tables-nav-icon">
            @((MarkupString)IconSvg)
        </div>
        <div>
            <span class="tables-nav-title">@Title</span>
            <span class="tables-nav-sub">@Subtitle</span>
        </div>
    </div>

    @if (ShowSignOut)
    {
        <div class="tables-nav-actions">
            <button class="btn-signout" @onclick="HandleSignOut">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16 17 21 12 16 7" />
                    <line x1="21" y1="12" x2="9" y2="12" />
                </svg>
                Sign Out
            </button>
        </div>
    }

    @if (RightContent is not null)
    {
        <div class="tables-nav-actions">
            @RightContent
        </div>
    }
</nav>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = "";
    [Parameter] public string Subtitle { get; set; } = "";
    [Parameter] public string IconSvg { get; set; } = "";
    [Parameter] public bool ShowSignOut { get; set; }
    [Parameter] public EventCallback OnSignOut { get; set; }
    [Parameter] public RenderFragment? RightContent { get; set; }

    async Task HandleSignOut()
    {
        if (OnSignOut.HasDelegate)
        {
            await OnSignOut.InvokeAsync();
            return;
        }

        Nav.NavigateTo("/");
    }
}
