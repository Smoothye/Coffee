@page "/budget"
@layout PaulaLayout
@rendermode InteractiveServer
@inject WeddingPlannerApp.Services.WeddingStateService State
@using WeddingPlannerApp.Components.LayoutPaula
@using WeddingPlannerApp.Components.PagesPaula.BudgetComponents
@using WeddingPlannerApp.Services
@implements IDisposable

<PageNav Title="Budget"
         Subtitle="Track your wedding expenses"
         IconSvg="@SvgIcons.BudgetNav" />

<Toast @ref="_toast" />

<div class="budget-page">
    <BudgetSummaryGrid Total="State.BudgetTotal"
                       Spent="State.BudgetSpent"
                       Paid="State.BudgetPaid"
                       Remaining="State.BudgetRemaining" />

    <BudgetProgressCard Percent="State.BudgetPercent" />

    <BudgetCategoryBreakdown Categories="CategoryTotals"
                             TotalSpent="State.BudgetSpent" />

    <BudgetTable Items="State.BudgetItems"
                 Categories="budgetCategories"
                 OnAddRequested="@(() => addOpen = true)"
                 OnTogglePaid="TogglePaid"
                 OnRemove="RemoveItem"
                 OnSave="SaveItem" />
</div>

<BudgetAddExpenseModal IsOpen="addOpen"
                       Categories="budgetCategories"
                       OnAdd="AddItem"
                       OnClose="@(() => addOpen = false)" />

<ConfirmDialog IsOpen="confirmDeleteOpen"
               Title="Delete budget item?"
               Message="This expense will be removed from your budget."
               ConfirmText="Delete item"
               OnCancel="@(() => confirmDeleteOpen = false)"
               OnConfirm="ConfirmRemoveItem" />

@code {
    Toast _toast = default!;

    static readonly string[] budgetCategories =
    {
        "Venue", "Catering", "Photography", "Florals", "Music",
        "Dress/Suit", "Decor", "Invitations", "Transport", "Cake", "Other"
    };

    static readonly Dictionary<string, string> catColors = new()
    {
        ["Venue"] = "#7d9b76",
        ["Catering"] = "#a8c8a4",
        ["Photography"] = "#4f6b4a",
        ["Florals"] = "#c8dbc5",
        ["Music"] = "#d97706",
        ["Dress/Suit"] = "#7c3aed",
        ["Decor"] = "#db2777",
        ["Invitations"] = "#0891b2",
        ["Transport"] = "#64748b",
        ["Cake"] = "#f59e0b",
        ["Other"] = "#9ca3af",
    };

    bool addOpen;
    bool confirmDeleteOpen;
    int pendingRemoveId;

    IReadOnlyList<BudgetCategoryTotal> CategoryTotals =>
        State.BudgetItems
            .Where(i => i.Actual > 0)
            .GroupBy(i => i.Category)
            .Select(g => new BudgetCategoryTotal(g.Key, g.Sum(i => i.Actual), CatColor(g.Key)))
            .ToList();

    static string CatColor(string category) =>
        catColors.TryGetValue(category, out var color) ? color : "#9ca3af";

    void AddItem(BudgetDraft draft)
    {
        State.AddBudgetItem(new BudgetItem
        {
            Name = draft.Name,
            Category = draft.Category,
            Estimated = draft.Estimated,
            Actual = draft.Actual,
        });
    }

    void SaveItem(BudgetItem item) => State.UpdateBudgetItem(item);
    void TogglePaid(int id) => State.TogglePaid(id);
    void RemoveItem(int id)
    {
        pendingRemoveId = id;
        confirmDeleteOpen = true;
    }

    void ConfirmRemoveItem()
    {
        State.RemoveBudgetItem(pendingRemoveId);
        confirmDeleteOpen = false;
    }

    protected override void OnInitialized() => State.OnChange += Refresh;
    void Refresh() => InvokeAsync(StateHasChanged);
    public void Dispose() => State.OnChange -= Refresh;
}
