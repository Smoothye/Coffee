@page "/budget"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@layout PaulaLayout
@rendermode InteractiveServer
@inject WeddingPlannerApp.Services.WeddingStateService State
@inject WeddingPlannerApp.Services.WeddingApiClient Api
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Authorization
@using WeddingPlannerApp.Components.LayoutPaula
@using WeddingPlannerApp.Components.PagesPaula.BudgetComponents
@using WeddingPlannerApp.DTOs.Guest
@using WeddingPlannerApp.Models
@using WeddingPlannerApp.Services
@implements IDisposable

<PageNav Title="Budget"
         Subtitle="Track your wedding expenses"
         IconSvg="@SvgIcons.BudgetNav" />

<Toast @ref="_toast" />

<div class="budget-page">
    <BudgetSummaryGrid Total="State.BudgetTotal"
                       Estimated="State.BudgetEstimated"
                       Spent="State.BudgetSpent"
                       Paid="State.BudgetPaid"
                       Unpaid="State.BudgetUnpaid"
                       Remaining="State.BudgetRemaining"
                       TotalChanged="UpdateBudgetTotal" />

    <BudgetProgressCard Percent="State.BudgetPercent" />

    @if (menuBudgetRows.Count > 0)
    {
        <BudgetMenuBreakdown Rows="menuBudgetRows" />
    }

    <BudgetCategoryBreakdown Categories="CategoryTotals"
                             TotalSpent="State.BudgetSpent" />

    <BudgetTable Items="State.BudgetItems"
                 Categories="budgetCategories"
                 OnAddRequested="@(() => addOpen = true)"
                 OnTogglePaid="TogglePaid"
                 OnRemove="RemoveItem"
                 OnSave="SaveItem" />
</div>

<BudgetAddExpenseModal IsOpen="addOpen"
                       Categories="budgetCategories"
                       OnAdd="AddItem"
                       OnClose="@(() => addOpen = false)" />

<ConfirmDialog IsOpen="confirmDeleteOpen"
               Title="Delete budget item?"
               Message="This expense will be removed from your budget."
               ConfirmText="Delete item"
               OnCancel="@(() => confirmDeleteOpen = false)"
               OnConfirm="ConfirmRemoveItem" />

@code {
    Toast _toast = default!;

    static readonly string[] budgetCategories =
    {
        "Venue", "Catering", "Photography", "Florals", "Music",
        "Dress/Suit", "Decor", "Invitations", "Transport", "Cake", "Other"
    };

    static readonly Dictionary<string, string> catColors = new()
    {
        ["Venue"] = "#7d9b76",
        ["Catering"] = "#a8c8a4",
        ["Photography"] = "#4f6b4a",
        ["Florals"] = "#c8dbc5",
        ["Music"] = "#d97706",
        ["Dress/Suit"] = "#7c3aed",
        ["Decor"] = "#db2777",
        ["Invitations"] = "#0891b2",
        ["Transport"] = "#64748b",
        ["Cake"] = "#f59e0b",
        ["Other"] = "#9ca3af",
    };

    bool addOpen;
    bool confirmDeleteOpen;
    int pendingRemoveId;
    string budgetStorageKey = "everafter.budget.total";
    List<MenuBudgetRow> menuBudgetRows = [];

    IReadOnlyList<BudgetCategoryTotal> CategoryTotals =>
        State.BudgetItems
            .Where(i => i.Actual > 0)
            .GroupBy(i => i.Category)
            .Select(g => new BudgetCategoryTotal(g.Key, g.Sum(i => i.Actual), CatColor(g.Key)))
            .ToList();

    static string CatColor(string category) =>
        catColors.TryGetValue(category, out var color) ? color : "#9ca3af";

    bool WouldExceedBudget(int actualDelta) =>
        actualDelta > 0 && State.BudgetSpent + actualDelta > State.BudgetTotal;

    void AddItem(BudgetDraft draft)
    {
        if (WouldExceedBudget(draft.Actual))
        {
            _toast.Show("Actual spent cannot exceed the total budget.", true);
            return;
        }

        State.AddBudgetItem(new BudgetItem
        {
            Name = draft.Name,
            Category = draft.Category,
            Estimated = draft.Estimated,
            Actual = draft.Actual,
        });
    }

    async Task UpdateBudgetTotal(int total)
    {
        if (total < State.BudgetSpent)
        {
            _toast.Show("Total budget cannot be lower than current actual spent.", true);
            return;
        }

        State.UpdateBudgetTotal(total);
        await SaveBudgetTotalAsync(total);
    }

    void SaveItem(BudgetItem item)
    {
        var existing = State.BudgetItems.FirstOrDefault(i => i.Id == item.Id);
        var currentActual = existing?.Actual ?? 0;
        if (WouldExceedBudget(item.Actual - currentActual))
        {
            _toast.Show("Actual spent cannot exceed the total budget.", true);
            return;
        }

        State.UpdateBudgetItem(item);
    }
    void TogglePaid(int id) => State.TogglePaid(id);
    void RemoveItem(int id)
    {
        if (State.BudgetItems.FirstOrDefault(i => i.Id == id)?.IsProtected == true)
            return;

        pendingRemoveId = id;
        confirmDeleteOpen = true;
    }

    void ConfirmRemoveItem()
    {
        State.RemoveBudgetItem(pendingRemoveId);
        confirmDeleteOpen = false;
    }

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += Refresh;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.IsInRole("Admin"))
        {
            Nav.NavigateTo("/admin", replace: true);
            return;
        }

        await SyncMenuBudgetAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await LoadBudgetTotalAsync();
    }

    void Refresh() => InvokeAsync(StateHasChanged);
    public void Dispose() => State.OnChange -= Refresh;

    async Task SyncMenuBudgetAsync()
    {
        var eventItem = (await Api.GetEventsAsync()).OrderByDescending(e => e.EventId).FirstOrDefault();
        if (eventItem is null)
        {
            menuBudgetRows.Clear();
            State.UpsertMenuBudgetItem(0);
            return;
        }

        budgetStorageKey = $"everafter.budget.{eventItem.EventId}.total";

        var venue = await Api.GetVenueAsync(eventItem.VenueId);
        if (venue is not null)
            State.UpsertVenueBudgetItem(venue.Name, (int)Math.Round(venue.EstimatedPrice));

        if (eventItem.MenuIds.Count == 0)
        {
            menuBudgetRows.Clear();
            State.UpsertMenuBudgetItem(0);
            return;
        }

        var menus = (await Api.GetMenusAsync())
            .Where(menu => eventItem.MenuIds.Contains(menu.MenuId))
            .ToList();
        var guests = await Api.GetGuestsAsync(eventItem.EventId);
        var activeGuests = guests.Where(g => g.RsvpStatus != RsvpStatus.Declined).ToList();
        var selectedMenuTypes = menus.Select(menu => menu.DietaryType).Distinct().ToList();
        var counts = BuildMenuCounts(activeGuests, eventItem.EstimatedGuests, selectedMenuTypes);

        menuBudgetRows = menus
            .Select(menu =>
            {
                var guestsForMenu = counts.TryGetValue(menu.DietaryType, out var count) ? count : 0;
                var total = guestsForMenu * menu.Price;
                return new MenuBudgetRow(menu.Name, menu.DietaryType.ToString(), guestsForMenu, menu.Price, total);
            })
            .OrderBy(row => row.Label)
            .ToList();

        State.UpsertMenuBudgetItem((int)Math.Round(menuBudgetRows.Sum(row => row.Total)));
    }

    async Task LoadBudgetTotalAsync()
    {
        try
        {
            var stored = await JS.InvokeAsync<string?>("localStorage.getItem", budgetStorageKey);
            if (int.TryParse(stored, out var total) && total >= State.BudgetSpent)
                State.UpdateBudgetTotal(total);
        }
        catch
        {
            // Budget still works if browser storage is unavailable.
        }
    }

    async Task SaveBudgetTotalAsync(int total)
    {
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", budgetStorageKey, total.ToString());
        }
        catch
        {
            // Budget still works if browser storage is unavailable.
        }
    }

    static Dictionary<MenuDietaryType, int> BuildMenuCounts(
        IReadOnlyList<GuestDto> guests,
        int estimatedGuests,
        IReadOnlyCollection<MenuDietaryType> selectedMenuTypes)
    {
        if (selectedMenuTypes.Count == 0)
            return [];

        if (guests.Count == 0)
            return new() { [ResolveSelectedMenuType(MenuDietaryType.Standard, selectedMenuTypes)] = Math.Max(estimatedGuests, 0) };

        return guests
            .GroupBy(guest => ResolveSelectedMenuType(MenuTypeFor(guest.DietaryRequirements), selectedMenuTypes))
            .ToDictionary(group => group.Key, group => group.Count());
    }

    static MenuDietaryType ResolveSelectedMenuType(
        MenuDietaryType preferredType,
        IReadOnlyCollection<MenuDietaryType> selectedMenuTypes)
    {
        if (selectedMenuTypes.Contains(preferredType))
            return preferredType;

        if (selectedMenuTypes.Contains(MenuDietaryType.Standard))
            return MenuDietaryType.Standard;

        return selectedMenuTypes.First();
    }

    static MenuDietaryType MenuTypeFor(DietaryRequirements dietary) => dietary switch
    {
        DietaryRequirements.Vegan => MenuDietaryType.Vegan,
        DietaryRequirements.Vegetarian => MenuDietaryType.Vegetarian,
        DietaryRequirements.Other => MenuDietaryType.Fasting,
        _ => MenuDietaryType.Standard
    };

}
