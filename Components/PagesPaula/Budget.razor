@page "/budget"
@layout UserLayout
@rendermode InteractiveServer
@inject WeddingPlannerApp.Services.WeddingStateService State
@using WeddingPlannerApp.Components.LayoutPaula
@implements IDisposable

<PageNav Title="Budget"
         Subtitle="Track your wedding expenses"
         IconSvg="@SvgIcons.BudgetNav" />

<Toast @ref="_toast" />

<div class="budget-page">

    <div class="budget-summary-grid">
        <div class="budget-stat-card bsc-total">
            <div class="bsc-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" /><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" /></svg>
            </div>
            <div>
                <p class="bsc-value">$@State.BudgetTotal.ToString("N0")</p>
                <p class="bsc-label">Total Budget</p>
            </div>
        </div>
        <div class="budget-stat-card bsc-spent">
            <div class="bsc-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18" /><polyline points="17 6 23 6 23 12" /></svg>
            </div>
            <div>
                <p class="bsc-value">$@State.BudgetSpent.ToString("N0")</p>
                <p class="bsc-label">Spent</p>
            </div>
        </div>
        <div class="budget-stat-card bsc-paid">
            <div class="bsc-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
            </div>
            <div>
                <p class="bsc-value">$@State.BudgetPaid.ToString("N0")</p>
                <p class="bsc-label">Paid</p>
            </div>
        </div>
        <div class="budget-stat-card @(State.BudgetRemaining >= 0 ? "bsc-remaining" : "bsc-over")">
            <div class="bsc-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" /></svg>
            </div>
            <div>
                <p class="bsc-value">$@Math.Abs(State.BudgetRemaining).ToString("N0")</p>
                <p class="bsc-label">@(State.BudgetRemaining >= 0 ? "Remaining" : "Over budget")</p>
            </div>
        </div>
    </div>

    <div class="budget-progress-card">
        <div class="budget-progress-top">
            <span class="budget-progress-label">Budget used</span>
            <span class="budget-progress-pct @(State.BudgetPercent > 100 ? "pct-danger" : State.BudgetPercent > 80 ? "pct-warn" : "pct-ok")">
                @State.BudgetPercent%
            </span>
        </div>
        <div class="budget-bar-outer">
            <div class="budget-bar-fill @(State.BudgetPercent > 100 ? "bar-danger" : State.BudgetPercent > 80 ? "bar-warn" : "bar-ok")"
                 style="width:@Math.Min(State.BudgetPercent, 100)%"></div>
        </div>
    </div>

    <div class="budget-categories-card">
        <h3 class="budget-section-title">By category</h3>
        <div class="budget-cat-list">
            @foreach (var cat in categoryTotals)
            {
                <div class="budget-cat-row">
                    <span class="budget-cat-dot" style="background:@CatColor(cat.Key)"></span>
                    <span class="budget-cat-name">@cat.Key</span>
                    <div class="budget-cat-bar-wrap">
                        <div class="budget-cat-bar" style="width:@(State.BudgetSpent > 0 ? cat.Value * 100 / State.BudgetSpent : 0)%;background:@CatColor(cat.Key)"></div>
                    </div>
                    <span class="budget-cat-amount">$@cat.Value.ToString("N0")</span>
                </div>
            }
        </div>
    </div>

    <div class="budget-table-card">
        <div class="toolbar" style="padding:.75rem 1rem .5rem;">
            <div class="search-wrap">
                <span class="search-icon">@SvgIcons.Search</span>
                <input class="input search-input" placeholder="Search expenses..."
                       @bind="budgetSearch" @bind:event="oninput" />
            </div>
            <select class="input select-input filter-select" @bind="tableFilter">
                <option value="all">All</option>
                <option value="paid">Paid</option>
                <option value="unpaid">Unpaid</option>
            </select>
            <div class="toolbar-actions">
                <button class="btn-add" @onclick="@(() => addOpen = true)">
                    @SvgIcons.Plus Add Expense
                </button>
            </div>
        </div>

        <div class="budget-table-wrap">
            <table class="budget-table">
                <thead>
                    <tr>
                        <th>Item</th><th>Category</th>
                        <th class="text-right">Estimated</th>
                        <th class="text-right">Actual</th>
                        <th class="text-center">Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in filteredItems)
                    {
                        var it = item;
                        @if (editingId == it.Id)
                        {
                            <tr class="budget-row budget-row-editing">
                                <td><input class="input budget-inline-input" @bind="editName" @bind:event="oninput" /></td>
                                <td>
                                    <select class="input select-input budget-inline-input" @bind="editCategory">
                                        @foreach (var c in budgetCategories) { <option value="@c">@c</option> }
                                    </select>
                                </td>
                                <td><input type="number" class="input budget-inline-input text-right" @bind="editEstimated" @bind:event="oninput" /></td>
                                <td><input type="number" class="input budget-inline-input text-right" @bind="editActual" @bind:event="oninput" /></td>
                                <td class="text-center">
                                    <div style="display:flex;gap:.3rem;justify-content:center;">
                                        <button class="icon-btn accept" @onclick="@(() => SaveEdit(it.Id))">@SvgIcons.CheckSmall</button>
                                        <button class="icon-btn reject" @onclick="@(() => editingId = -1)">@SvgIcons.XSmall</button>
                                    </div>
                                </td>
                                <td></td>
                            </tr>
                        }
                        else
                        {
                            <tr class="budget-row @(it.Paid ? "budget-row-paid" : "")">
                                <td class="budget-item-name">@it.Name</td>
                                <td><span class="budget-cat-badge">@it.Category</span></td>
                                <td class="text-right">$@it.Estimated.ToString("N0")</td>
                                <td class="text-right @(it.Actual > it.Estimated ? "text-danger" : "")">
                                    @(it.Actual > 0 ? $"${it.Actual:N0}" : "—")
                                </td>
                                <td class="text-center">
                                    <button class="paid-toggle @(it.Paid ? "paid-toggle-paid" : "")"
                                            @onclick="@(() => State.TogglePaid(it.Id))">
                                        @(it.Paid ? "✓ Paid" : "Unpaid")
                                    </button>
                                </td>
                                <td>
                                    <div style="display:flex;gap:.25rem;align-items:center;">
                                        <button class="icon-btn expand" @onclick="@(() => StartEdit(it))">@SvgIcons.Edit</button>
                                        <button class="icon-btn delete" @onclick="@(() => State.RemoveBudgetItem(it.Id))">@SvgIcons.Trash</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    @if (!filteredItems.Any())
                    {
                        <tr><td colspan="6" class="budget-empty-row">No expenses yet — add one above.</td></tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="budget-totals-row">
                        <td colspan="2"><strong>Total</strong></td>
                        <td class="text-right"><strong>$@State.BudgetItems.Sum(i => i.Estimated).ToString("N0")</strong></td>
                        <td class="text-right"><strong>$@State.BudgetItems.Sum(i => i.Actual).ToString("N0")</strong></td>
                        <td></td><td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

</div>

<ModalShell IsOpen="addOpen" Title="Add Expense" OnClose="CloseAdd">
    @if (!string.IsNullOrEmpty(addError))
    {
        <div class="error-banner">@addError</div>
    }
    <div class="form-grid-2">
        <div class="field">
            <label>Name *</label>
            <input class="input" placeholder="e.g. Florist deposit" @bind="newName" @bind:event="oninput" />
        </div>
        <div class="field">
            <label>Category</label>
            <select class="input select-input" @bind="newCat">
                @foreach (var c in budgetCategories) { <option value="@c">@c</option> }
            </select>
        </div>
    </div>
    <div class="form-grid-2">
        <div class="field">
            <label>Estimated ($) *</label>
            <input type="number" class="input" min="0" placeholder="0" @bind="newEstimated" @bind:event="oninput" />
        </div>
        <div class="field">
            <label>Actual ($)</label>
            <input type="number" class="input" min="0" placeholder="0" @bind="newActual" @bind:event="oninput" />
        </div>
    </div>
    <button class="btn-add-guest" @onclick="AddItem">
        @SvgIcons.Plus Add Expense
    </button>
</ModalShell>

@code {

    Toast _toast = default!;

    static readonly string[] budgetCategories = {
        "Venue","Catering","Photography","Florals","Music",
        "Dress/Suit","Decor","Invitations","Transport","Cake","Other"
    };

    static readonly Dictionary<string, string> catColors = new()
    {
        ["Venue"]="        #7d9b76",["Catering"]="#a8c8a4",["Photography"]="#4f6b4a",
        ["Florals"]="#c8dbc5",["Music"]="#d97706",["Dress/Suit"]="#7c3aed",
        ["Decor"]="#db2777",["Invitations"]="#0891b2",["Transport"]="#64748b",
        ["Cake"]="#f59e0b",["Other"]="#9ca3af",
    };

    string CatColor(string cat) => catColors.TryGetValue(cat, out var c) ? c : "#9ca3af";

    Dictionary<string, int> categoryTotals =>
        State.BudgetItems
             .Where(i => i.Actual > 0)
             .GroupBy(i => i.Category)
             .ToDictionary(g => g.Key, g => g.Sum(i => i.Actual));

    string tableFilter = "all";
    string budgetSearch = "";

    IEnumerable<WeddingPlannerApp.Services.BudgetItem> filteredItems
    {
        get
        {
            var q = State.BudgetItems.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(budgetSearch))
                q = q.Where(i => i.Name.Contains(budgetSearch, StringComparison.OrdinalIgnoreCase)
                               || i.Category.Contains(budgetSearch, StringComparison.OrdinalIgnoreCase));
            return tableFilter switch
            {
                "paid"   => q.Where(i => i.Paid),
                "unpaid" => q.Where(i => !i.Paid),
                _        => q
            };
        }
    }

    bool   addOpen  = false;
    string addError = "";
    string newName  = "";
    string newCat   = "Other";
    int    newEstimated = 0;
    int    newActual    = 0;

    void CloseAdd() { addOpen = false; addError = ""; newName = ""; newEstimated = 0; newActual = 0; }

    void AddItem()
    {
        addError = "";
        if (string.IsNullOrWhiteSpace(newName))  { addError = "Name is required."; return; }
        if (newEstimated <= 0) { addError = "Estimated cost must be > 0."; return; }
        State.AddBudgetItem(new WeddingPlannerApp.Services.BudgetItem
        {
            Name = newName.Trim(), Category = newCat,
            Estimated = newEstimated, Actual = newActual,
        });
        CloseAdd();
    }

    int    editingId    = -1;
    string editName     = "";
    string editCategory = "";
    int    editEstimated = 0;
    int    editActual    = 0;

    void StartEdit(WeddingPlannerApp.Services.BudgetItem item)
    {
        editingId = item.Id; editName = item.Name; editCategory = item.Category;
        editEstimated = item.Estimated; editActual = item.Actual;
    }

    void SaveEdit(int id)
    {
        State.UpdateBudgetItem(new WeddingPlannerApp.Services.BudgetItem
        {
            Id = id, Name = editName, Category = editCategory,
            Estimated = editEstimated, Actual = editActual,
            Paid = State.BudgetItems.FirstOrDefault(i => i.Id == id)?.Paid ?? false,
        });
        editingId = -1;
    }

    protected override void OnInitialized() => State.OnChange += Refresh;
    void Refresh() => InvokeAsync(StateHasChanged);
    public void Dispose() => State.OnChange -= Refresh;
}
