@page "/"
@rendermode InteractiveServer
@inject NavigationManager Nav

<div class="splash-wrap">
    <div class="splash-bg">
        <div class="splash-bg-img"></div>
        <div class="splash-bg-overlay"></div>
        <div class="splash-bg-vignette"></div>
    </div>

    <div class="petals" aria-hidden="true">
        @for (int i = 1; i <= 12; i++)
        {
            <div class="petal petal-@i"></div>
        }
    </div>

    <div class="splash-content">
        <div class="ring-wrap">
            <div class="ring ring-outer"></div>
            <div class="ring ring-inner"></div>
            <div class="ring-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24"
                     fill="currentColor" stroke="none">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78
                    7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                </svg>
            </div>
        </div>

        <p class="splash-eyebrow">Welcome to</p>

        <h1 class="splash-title">
            <span class="title-ever">Ever</span><span class="title-after">After</span>
        </h1>

        <div class="splash-divider">
            <span class="divider-line"></span>
            <span class="divider-diamond"></span>
            <span class="divider-line"></span>
        </div>


        <p class="splash-motto">
            Every love story deserves<br />a perfect beginning.
        </p>

        <button class="splash-btn" @onclick="Continue">
            <span class="btn-text">Begin Your Journey</span>
            <span class="btn-arrow">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                </svg>
            </span>
        </button>

        <p class="splash-footer">Wedding &amp; Event Planning Platform</p>

    </div>
</div>

@code {
    void Continue() => Nav.NavigateTo("/login");
}
