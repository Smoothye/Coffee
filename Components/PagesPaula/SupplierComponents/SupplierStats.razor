<div class="supplier-stats">
    <div class="supplier-stat"><span class="supplier-stat-val">@Available</span><span class="supplier-stat-label">Available</span></div>
    <div class="supplier-stat"><span class="supplier-stat-val" style="color:#16a34a">@Confirmed</span><span class="supplier-stat-label">Confirmed</span></div>
    <div class="supplier-stat"><span class="supplier-stat-val" style="color:#d97706">@Pending</span><span class="supplier-stat-label">In contact</span></div>
    <div class="supplier-stat"><span class="supplier-stat-val">@NotSelected</span><span class="supplier-stat-label">Not selected</span></div>
    <div class="supplier-stat"><span class="supplier-stat-val" style="color:#16a34a">@Money(PaidTotal)</span><span class="supplier-stat-label">Paid</span></div>
    <div class="supplier-stat"><span class="supplier-stat-val" style="color:#dc2626">@Money(UnpaidTotal)</span><span class="supplier-stat-label">Unpaid</span></div>
</div>

@code {
    [Parameter] public int Available { get; set; }
    [Parameter] public int Confirmed { get; set; }
    [Parameter] public int Pending { get; set; }
    [Parameter] public int NotSelected { get; set; }
    [Parameter] public decimal PaidTotal { get; set; }
    [Parameter] public decimal UnpaidTotal { get; set; }

    static string Money(decimal value) => value > 0 ? $"${value:N0}" : "-";
}
