@using WeddingPlannerApp.Components.LayoutPaula

<div class="supplier-card @(Status == "confirmed" ? "supplier-card-booked" : "")" @key="Supplier.Id">
    <div class="supplier-card-top">
        <div class="supplier-card-info">
            <h4 class="supplier-name">@Supplier.Name</h4>
            <span class="supplier-cat-badge">@Supplier.Category</span>
        </div>
        @if (Status != null)
        {
            <span class="supplier-status-pill status-@Status">
                @(Status == "confirmed" ? "Confirmed" : "In contact")
            </span>
        }
    </div>

    <div class="supplier-contacts">
        @if (!string.IsNullOrEmpty(Supplier.Phone))
        {
            <div class="supplier-contact-row">
                @SvgIcons.Phone
                @Supplier.Phone
            </div>
        }
        @if (!string.IsNullOrEmpty(Supplier.Email))
        {
            <div class="supplier-contact-row">
                @SvgIcons.Mail
                @Supplier.Email
            </div>
        }
        <p class="supplier-notes">@Supplier.Description</p>
        <div class="supplier-cost-row supplier-cost-edit @(EventSupplier is null ? "supplier-cost-row-single" : "")">
            <label>
                <span>Price</span>
                <input class="input supplier-cost-input"
                       type="number"
                       min="0"
                       max="@MaxSupplierPrice"
                       step="50"
                       disabled="@(!CanEditCosts || IsPaid)"
                       @bind="Supplier.Price"
                       @bind:after="NotifyBudgetSync" />
            </label>
            @if (EventSupplier != null)
            {
                <div class="supplier-payment-inline">
                    <div class="supplier-payment-label-row">
                        <span>Payment</span>
                        @if (IsPaid)
                        {
                            <span class="supplier-payment-info"
                                  tabindex="0"
                                  aria-label="Paid suppliers are locked until switched back to unpaid.">
                                @SvgIcons.AlertCircle
                                <span class="supplier-payment-tooltip" role="tooltip">
                                    Switch to unpaid before editing the price.
                                </span>
                            </span>
                        }
                    </div>
                    <button type="button"
                            class="paid-toggle @(EventSupplier.Paid ? "paid-toggle-paid" : "")"
                            @onclick="@(() => OnPaidChanged.InvokeAsync((Supplier.Id, !EventSupplier.Paid)))">
                        @(EventSupplier.Paid ? "Paid" : "Unpaid")
                    </button>
                </div>
            }
        </div>
        @if (!CanEditCosts)
        {
            <p class="supplier-budget-hint">Start contact before adding budget values.</p>
        }
    </div>

    @if (EventSupplier != null)
    {
        <div class="supplier-notes-field">
            <input class="input" style="font-size:.78rem;padding:.35rem .6rem;" placeholder="Add notes..." @bind="EventSupplier.Notes" />
        </div>
    }

    <div class="supplier-actions @(Status == null ? "supplier-actions-single" : "")">
        @if (Status == null)
        {
            <button class="supplier-book-btn supplier-book-pending"
                    @onclick="@(() => OnSetStatus.InvokeAsync((Supplier.Id, "pending")))">
                @SvgIcons.PhoneOutgoing
                Contact supplier
            </button>
        }
        else if (Status == "pending")
        {
            <button class="supplier-book-btn supplier-book-booked"
                    @onclick="@(() => OnSetStatus.InvokeAsync((Supplier.Id, "confirmed")))">
                @SvgIcons.Check Mark as confirmed
            </button>
            <button class="btn-outline supplier-remove-btn" @onclick="@(() => OnRemoveStatus.InvokeAsync(Supplier.Id))">Remove</button>
        }
        else if (Status == "confirmed")
        {
            <button type="button" class="supplier-book-btn supplier-book-booked supplier-confirmed-state" disabled>
                @SvgIcons.Check Confirmed
            </button>
            <button class="btn-outline supplier-remove-btn" @onclick="@(() => OnRemoveStatus.InvokeAsync(Supplier.Id))">Remove</button>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public SupplierModel Supplier { get; set; } = new();
    [Parameter] public string? Status { get; set; }
    [Parameter] public EventSupplierModel? EventSupplier { get; set; }
    [Parameter] public EventCallback<(int SupplierId, string Status)> OnSetStatus { get; set; }
    [Parameter] public EventCallback<(int SupplierId, bool Paid)> OnPaidChanged { get; set; }
    [Parameter] public EventCallback<int> OnRemoveStatus { get; set; }
    [Parameter] public EventCallback<SupplierModel> OnSyncBudget { get; set; }

    bool CanEditCosts => Status != null;
    bool IsPaid => EventSupplier?.Paid == true;
    const int MaxSupplierPrice = 1000000;
    Task NotifyBudgetSync() => OnSyncBudget.InvokeAsync(Supplier);
}
