@using WeddingPlannerApp.Components.LayoutPaula

<div class="supplier-card @(Status == "confirmed" ? "supplier-card-booked" : "")" @key="Supplier.Id">
    <div class="supplier-card-top">
        <div class="supplier-card-info">
            <h4 class="supplier-name">@Supplier.Name</h4>
            <span class="supplier-cat-badge">@Supplier.Category</span>
        </div>
        @if (Status != null)
        {
            <span class="supplier-status-pill status-@Status">
                @(Status == "confirmed" ? "Confirmed" : "In contact")
            </span>
        }
    </div>

    <div class="supplier-contacts">
        @if (!string.IsNullOrEmpty(Supplier.Phone))
        {
            <div class="supplier-contact-row">
                @SvgIcons.Phone
                @Supplier.Phone
            </div>
        }
        @if (!string.IsNullOrEmpty(Supplier.Email))
        {
            <div class="supplier-contact-row">
                @SvgIcons.Mail
                @Supplier.Email
            </div>
        }
        <p class="supplier-notes">@Supplier.Description</p>
        <div class="supplier-cost-row supplier-cost-edit">
            <label><span>Price</span><input class="input supplier-cost-input" type="number" min="0" step="50" disabled="@(!CanEditCosts)" @bind="Supplier.Price" @bind:event="oninput" @bind:after="NotifyBudgetSync" /></label>
            <label><span>Advance</span><input class="input supplier-cost-input" type="number" min="0" step="50" disabled="@(!CanEditCosts)" @bind="Supplier.Advance" @bind:event="oninput" @bind:after="NotifyBudgetSync" /></label>
            <label><span>Remaining</span><input class="input supplier-cost-input" type="number" min="0" step="50" disabled value="@Supplier.Remaining.ToString("0")" /></label>
        </div>
        @if (!CanEditCosts)
        {
            <p class="supplier-budget-hint">Start contact before adding budget values.</p>
        }
    </div>

    @if (EventSupplier != null)
    {
        <div class="supplier-payment-row">
            <span>Remaining payment</span>
            <button type="button"
                    class="paid-toggle @(EventSupplier.RemainingPaid ? "paid-toggle-paid" : "")"
                    @onclick="@(() => OnRemainingPaidChanged.InvokeAsync((Supplier.Id, !EventSupplier.RemainingPaid)))">
                @(EventSupplier.RemainingPaid ? "Paid" : "Unpaid")
            </button>
        </div>
        <div class="supplier-notes-field">
            <input class="input" style="font-size:.78rem;padding:.35rem .6rem;" placeholder="Add notes..." @bind="EventSupplier.Notes" />
        </div>
    }

    <div class="supplier-actions">
        @if (Status == null)
        {
            <button class="supplier-book-btn supplier-book-pending"
                    style="background:linear-gradient(135deg,var(--sage),var(--sage-dark));color:#fff;border:none;box-shadow:0 3px 12px rgba(79,107,74,.3);"
                    @onclick="@(() => OnSetStatus.InvokeAsync((Supplier.Id, "pending")))">
                @SvgIcons.PhoneOutgoing
                Contact supplier
            </button>
        }
        else if (Status == "pending")
        {
            <button class="supplier-book-btn supplier-book-booked"
                    style="background:linear-gradient(135deg,var(--sage),var(--sage-dark));color:#fff;border:none;"
                    @onclick="@(() => OnSetStatus.InvokeAsync((Supplier.Id, "confirmed")))">
                @SvgIcons.Check Mark confirmed
            </button>
            <button class="btn-outline" style="font-size:.78rem;padding:.35rem .65rem;" @onclick="@(() => OnRemoveStatus.InvokeAsync(Supplier.Id))">Remove</button>
        }
        else if (Status == "confirmed")
        {
            <button class="supplier-book-btn supplier-book-booked" @onclick="@(() => OnSetStatus.InvokeAsync((Supplier.Id, "pending")))">
                @SvgIcons.Check Confirmed
            </button>
            <button class="btn-outline" style="font-size:.78rem;padding:.35rem .65rem;" @onclick="@(() => OnRemoveStatus.InvokeAsync(Supplier.Id))">Remove</button>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public SupplierModel Supplier { get; set; } = new();
    [Parameter] public string? Status { get; set; }
    [Parameter] public EventSupplierModel? EventSupplier { get; set; }
    [Parameter] public EventCallback<(int SupplierId, string Status)> OnSetStatus { get; set; }
    [Parameter] public EventCallback<(int SupplierId, bool RemainingPaid)> OnRemainingPaidChanged { get; set; }
    [Parameter] public EventCallback<int> OnRemoveStatus { get; set; }
    [Parameter] public EventCallback<SupplierModel> OnSyncBudget { get; set; }

    bool CanEditCosts => Status != null;
    Task NotifyBudgetSync() => OnSyncBudget.InvokeAsync(Supplier);
}
