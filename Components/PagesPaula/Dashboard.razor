@page "/dashboard"
@page "/dashboard/{EventId:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@layout PaulaLayout
@rendermode InteractiveServer
@using WeddingPlannerApp.Components.PagesPaula.DashboardWidgets
@using WeddingPlannerApp.DTOs.Event
@using WeddingPlannerApp.DTOs.Guest
@using WeddingPlannerApp.DTOs.Venue
@using WeddingPlannerApp.Models
@using WeddingPlannerApp.Data
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using WeddingPlannerApp.Services
@inject NavigationManager Nav
@inject WeddingPlannerApp.Services.WeddingApiClient Api
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject WeddingStateService State

<HeadContent>
    <link rel="stylesheet" href="styles/Dashboard.css" />
</HeadContent>

<PageNav Title="Dashboard"
         Subtitle="@($"{daysUntilWedding} days until your wedding")"
         IconSvg="@SvgIcons.DashboardNav" />

<div class="dash-body">
    @if (!string.IsNullOrEmpty(loadError))
    {
        <div class="error-banner">@SvgIcons.AlertCircle @loadError</div>
    }

    <div class="dash-header">
        <h1 class="dash-greeting">@Greeting, @userDisplayName</h1>
        <p class="dash-subtitle">
            @SvgIcons.CalendarSmall
            @daysUntilWedding days until your wedding - @weddingDate.ToString("MMMM d, yyyy")
        </p>
    </div>

    <CountdownCard WeddingDate="weddingDate"
                   DaysUntilWedding="daysUntilWedding"
                   WeeksUntilWedding="weeksUntilWedding"
                   MonthsUntilWedding="monthsUntilWedding" />

    <div class="dash-grid">
        <BudgetWidget BudgetTotal="budgetTotal"
                      BudgetSpent="budgetSpent"
                      Categories="budgetCategories"
                      Href="/budget" />

        <RsvpWidget Confirmed="rsvpConfirmed"
                    Pending="rsvpPending"
                    Declined="rsvpDeclined"
                    PlusOnes="rsvpPlusOnes"
                    Href="@($"/guests/{EventId}")" />

        <TasksWidget Tasks="tasks"
                     OnToggleTask="ToggleTask"
                     Href="/tasks" />

        <MenuDetailsWidget SelectedMenu="@selectedMenu"
                           MenuRows="menuRows"
                           MenuEstimate="menuEstimate"
                           VenueName="@venueName"
                           ExpectedGuests="expectedGuests"
                           SeatedGuests="seatedGuests"
                           SeatingTotalGuests="seatingTotalGuests"
                           TablesConfirmed="tablesConfirmed"
                           BudgetPercent="budgetPercent"
                           Href="@($"/menu/{EventId}")"
                           VenueHref="@($"/venues/event/{EventId}")"
                           GuestsHref="@($"/guests/{EventId}")"
                           TablesHref="@($"/tables/{EventId}")"
                           BudgetHref="/budget" />
    </div>
</div>

@code {
    [Parameter] public int EventId { get; set; }

    DateTime weddingDate = DateTime.Today;
    string venueName = "";
    int expectedGuests = 0;
    bool tablesConfirmed = false;
    string selectedMenu = "";
    List<string> menuRows = [];
    int menuEstimate = 0;
    int seatedGuests = 0;
    int seatingTotalGuests = 0;
    string loadError = "";
    string userDisplayName = "there";

    [CascadingParameter] public Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    int daysUntilWedding => Math.Max(0, (weddingDate - DateTime.Today).Days);
    int weeksUntilWedding => daysUntilWedding / 7;
    int monthsUntilWedding => Math.Max(0, ((weddingDate.Year - DateTime.Today.Year) * 12) + weddingDate.Month - DateTime.Today.Month);

    string Greeting => DateTime.Now.Hour switch { < 12 => "Good morning", < 18 => "Good afternoon", _ => "Good evening" };

    int budgetTotal = 0;
    int budgetSpent = 0;
    int budgetEstimated = 0;
    int budgetPercent => budgetTotal > 0 ? budgetEstimated * 100 / budgetTotal : 0;

    List<DashboardBudgetCategory> budgetCategories = [];

    int rsvpConfirmed = 0;
    int rsvpPending = 0;
    int rsvpDeclined = 0;
    int rsvpPlusOnes = 0;

    List<DashboardTaskItem> tasks = [];

    void ToggleTask(int id)
    {
        State.ToggleTask(id);
        ApplyTasksState();
    }

    protected override async Task OnParametersSetAsync()
    {
        loadError = "";

        try
        {
            if (await RedirectAdminAsync())
                return;

            await LoadUserName();

            var ownEvent = (await Api.GetEventsAsync()).OrderByDescending(e => e.EventId).FirstOrDefault();
            if (ownEvent is null)
            {
                Nav.NavigateTo("/onboarding", replace: true);
                return;
            }

            if (EventId <= 0 || EventId != ownEvent.EventId)
            {
                EventId = ownEvent.EventId;
                Nav.NavigateTo($"/dashboard/{EventId}", replace: true);
                return;
            }

            var eventItem = await Api.GetEventAsync(EventId);
            if (eventItem is null)
            {
                Nav.NavigateTo("/onboarding", replace: true);
                return;
            }

            if (eventItem is null)
                return;

            ApplyEvent(eventItem);

            var guests = await Api.GetGuestsAsync(EventId);
            ApplyGuestStats(guests);

            var venue = await Api.GetVenueAsync(eventItem.VenueId);
            if (venue != null)
                venueName = venue.Name;

            var menus = await Api.GetMenusAsync();
            selectedMenu = FormatMenuNames(eventItem.MenuIds, menus);
            ApplyMenuRows(eventItem.MenuIds, menus, guests, eventItem.EstimatedGuests);
            if (venue != null)
                State.UpsertVenueBudgetItem(venue.Name, (int)Math.Round(venue.EstimatedPrice));
            State.UpsertMenuBudgetItem(menuEstimate);
            ApplyBudgetState();
            ApplyTasksState();
        }
        catch (Exception ex)
        {
            loadError = $"Could not load dashboard data: {ex.Message}";
        }
    }

    async Task<bool> RedirectAdminAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!authState.User.IsInRole("Admin"))
            return false;

        Nav.NavigateTo("/admin", replace: true);
        return true;
    }

    async Task LoadUserName()
    {
        if (AuthenticationStateTask is null)
            return;

        var authState = await AuthenticationStateTask;
        var user = await UserManager.GetUserAsync(authState.User);
        if (user is null)
            return;

        userDisplayName = !string.IsNullOrWhiteSpace(user.FirstName)
            ? user.FirstName.Trim()
            : user.Email?.Split('@')[0] ?? "there";
    }

    void ApplyEvent(EventDto eventItem)
    {
        weddingDate = eventItem.EventDate;
        expectedGuests = eventItem.EstimatedGuests;
        if (State.BudgetTotal <= 0)
            State.UpdateBudgetTotal((int)eventItem.TotalBudget);
        selectedMenu = eventItem.MenuIds.Count > 0
            ? $"{eventItem.MenuIds.Count} menus selected"
            : "Select a menu";
    }

    static string FormatMenuNames(
        IReadOnlyCollection<int> menuIds,
        IReadOnlyCollection<WeddingPlannerApp.Models.Menu> menus)
    {
        if (menuIds.Count == 0)
            return "Select a menu";

        var menuNames = menus
            .Where(menu => menuIds.Contains(menu.MenuId))
            .Select(menu => menu.Name)
            .ToList();

        return menuNames.Count > 0
            ? string.Join(", ", menuNames)
            : $"{menuIds.Count} menus selected";
    }

    void ApplyGuestStats(IReadOnlyCollection<GuestDto> guests)
    {
        rsvpConfirmed = guests.Count(g => g.RsvpStatus == RsvpStatus.Confirmed);
        rsvpPending = guests.Count(g => g.RsvpStatus == RsvpStatus.Pending);
        rsvpDeclined = guests.Count(g => g.RsvpStatus == RsvpStatus.Declined);
        rsvpPlusOnes = guests.Count(g => g.HasPlusOne);
        var activeGuests = guests.Where(g => g.RsvpStatus != RsvpStatus.Declined).ToList();
        seatingTotalGuests = activeGuests.Count;
        seatedGuests = activeGuests.Count(g => g.TableId.HasValue && g.SeatNumber.HasValue);
        tablesConfirmed = seatingTotalGuests > 0 && seatedGuests == seatingTotalGuests;
    }

    void ApplyMenuRows(
        IReadOnlyCollection<int> menuIds,
        IReadOnlyCollection<WeddingPlannerApp.Models.Menu> menus,
        IReadOnlyCollection<GuestDto> guests,
        int estimatedGuests)
    {
        var selectedMenus = menus
            .Where(menu => menuIds.Contains(menu.MenuId))
            .OrderBy(menu => menu.DietaryType)
            .ThenBy(menu => menu.Price)
            .ToList();
        var activeGuests = guests.Where(g => g.RsvpStatus != RsvpStatus.Declined).ToList();
        var selectedMenuTypes = selectedMenus.Select(menu => menu.DietaryType).Distinct().ToList();
        var counts = BuildMenuCounts(activeGuests, estimatedGuests, selectedMenuTypes);

        menuRows = selectedMenus
            .Select(menu =>
            {
                var guestCount = counts.TryGetValue(menu.DietaryType, out var count) ? count : 0;
                var total = menu.Price * guestCount;
                return $"{menu.Name} - {menu.DietaryType} - {guestCount} guests x ${menu.Price:0}/person = ${total:N0}";
            })
            .ToList();

        menuEstimate = selectedMenus.Sum(menu =>
        {
            var guestCount = counts.TryGetValue(menu.DietaryType, out var count) ? count : 0;
            return (int)Math.Round(menu.Price * guestCount);
        });
    }

    static Dictionary<MenuDietaryType, int> BuildMenuCounts(
        IReadOnlyList<GuestDto> guests,
        int estimatedGuests,
        IReadOnlyCollection<MenuDietaryType> selectedMenuTypes)
    {
        if (selectedMenuTypes.Count == 0)
            return [];

        if (guests.Count == 0)
            return new() { [ResolveSelectedMenuType(MenuDietaryType.Standard, selectedMenuTypes)] = Math.Max(estimatedGuests, 0) };

        return guests
            .GroupBy(guest => ResolveSelectedMenuType(MenuTypeFor(guest.DietaryRequirements), selectedMenuTypes))
            .ToDictionary(group => group.Key, group => group.Count());
    }

    static MenuDietaryType ResolveSelectedMenuType(
        MenuDietaryType preferredType,
        IReadOnlyCollection<MenuDietaryType> selectedMenuTypes)
    {
        if (selectedMenuTypes.Contains(preferredType))
            return preferredType;

        if (selectedMenuTypes.Contains(MenuDietaryType.Standard))
            return MenuDietaryType.Standard;

        return selectedMenuTypes.First();
    }

    static MenuDietaryType MenuTypeFor(DietaryRequirements dietary) => dietary switch
    {
        DietaryRequirements.Vegan => MenuDietaryType.Vegan,
        DietaryRequirements.Vegetarian => MenuDietaryType.Vegetarian,
        DietaryRequirements.Fasting => MenuDietaryType.Fasting,
        _ => MenuDietaryType.Standard
    };

    void ApplyBudgetState()
    {
        budgetTotal = State.BudgetTotal;
        budgetSpent = State.BudgetSpent;
        budgetEstimated = State.BudgetEstimated;
        budgetCategories = State.BudgetItems
            .GroupBy(item => item.Category)
            .Select(group => new DashboardBudgetCategory(group.Key, group.Sum(item => item.Actual > 0 ? item.Actual : item.Estimated), BudgetCategoryColor(group.Key)))
            .OrderByDescending(category => category.Amount)
            .ToList();
    }

    void ApplyTasksState()
    {
        tasks = State.Tasks
            .Select(task => new DashboardTaskItem(
                task.Id,
                task.Title,
                task.Category,
                task.DueDate,
                task.Priority,
                task.Done))
            .ToList();
    }

    static string BudgetCategoryColor(string category) => category switch
    {
        "Venue" => "#7d9b76",
        "Catering" => "#a8c8a4",
        "Photography" => "#4f6b4a",
        "Florals" => "#c8dbc5",
        "Music" => "#d97706",
        "Dress/Suit" => "#7c3aed",
        "Decor" => "#db2777",
        "Invitations" => "#0891b2",
        "Transport" => "#64748b",
        "Cake" => "#f59e0b",
        _ => "#9ca3af"
    };
}
