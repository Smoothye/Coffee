@page "/dashboard"
@layout PaulaLayout
@rendermode InteractiveServer
@using WeddingPlannerApp.Components.PagesPaula.DashboardWidgets

<HeadContent>
    <link rel="stylesheet" href="styles/Dashboard.css" />
</HeadContent>

<PageNav Title="Dashboard"
         Subtitle="@($"{daysUntilWedding} days until your wedding")"
         IconSvg="@SvgIcons.DashboardNav" />

<div class="dash-body">
    <div class="dash-header">
        <h1 class="dash-greeting">@Greeting, Emma</h1>
        <p class="dash-subtitle">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:.3rem">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
            </svg>
            @daysUntilWedding days until your wedding - @weddingDate.ToString("MMMM d, yyyy")
        </p>
    </div>

    <CountdownCard WeddingDate="weddingDate"
                   DaysUntilWedding="daysUntilWedding"
                   WeeksUntilWedding="weeksUntilWedding"
                   MonthsUntilWedding="monthsUntilWedding" />

    <div class="dash-grid">
        <BudgetWidget BudgetTotal="budgetTotal"
                      BudgetSpent="budgetSpent"
                      Categories="budgetCategories" />

        <RsvpWidget Confirmed="rsvpConfirmed"
                    Pending="rsvpPending"
                    Declined="rsvpDeclined"
                    PlusOnes="rsvpPlusOnes" />

        <TasksWidget Tasks="tasks" OnToggleTask="ToggleTask" />

        <MenuDetailsWidget SelectedMenu="@selectedMenu"
                           VenueName="@venueName"
                           ExpectedGuests="expectedGuests"
                           TablesConfirmed="tablesConfirmed"
                           BudgetPercent="budgetPercent" />
    </div>
</div>

@code {
    DateTime weddingDate = new(2026, 9, 12);
    string venueName = "Rosewood Gardens";
    int expectedGuests = 120;
    bool tablesConfirmed = false;
    string selectedMenu = "Classic Elegance";

    int daysUntilWedding => Math.Max(0, (weddingDate - DateTime.Today).Days);
    int weeksUntilWedding => daysUntilWedding / 7;
    int monthsUntilWedding => Math.Max(0, ((weddingDate.Year - DateTime.Today.Year) * 12) + weddingDate.Month - DateTime.Today.Month);

    string Greeting => DateTime.Now.Hour switch { < 12 => "Good morning", < 18 => "Good afternoon", _ => "Good evening" };

    int budgetTotal = 20000;
    int budgetSpent = 14200;
    int budgetPercent => budgetTotal > 0 ? budgetSpent * 100 / budgetTotal : 0;

    List<DashboardBudgetCategory> budgetCategories =
    [
        new("Catering", 5800, "#7d9b76"),
        new("Venue", 4500, "#a8c8a4"),
        new("Photography", 2200, "#4f6b4a"),
        new("Florals", 900, "#c8dbc5"),
        new("Other", 800, "#d97706"),
    ];

    int rsvpConfirmed = 84;
    int rsvpPending = 28;
    int rsvpDeclined = 8;
    int rsvpPlusOnes = 14;

    List<DashboardTaskItem> tasks =
    [
        new(1, "Final headcount to caterer", "Catering", DateTime.Today.AddDays(3), "high"),
        new(2, "Confirm florist order", "Florals", DateTime.Today.AddDays(5), "high"),
        new(3, "Send final seating chart", "Tables", DateTime.Today.AddDays(7), "high"),
        new(4, "Pay venue balance", "Venue", DateTime.Today.AddDays(10), "high"),
        new(5, "Review ceremony timeline", "Schedule", DateTime.Today.AddDays(14), "medium"),
        new(6, "Collect dietary requirements", "Catering", DateTime.Today.AddDays(4), "medium"),
        new(7, "Book hair & makeup", "Beauty", DateTime.Today.AddDays(21), "medium"),
        new(8, "Order wedding favors", "Decor", DateTime.Today.AddDays(30), "low", true),
        new(9, "Send save-the-dates", "Invitations", DateTime.Today.AddDays(-5), "high", true),
    ];

    void ToggleTask(int id)
    {
        var task = tasks.FirstOrDefault(x => x.Id == id);
        if (task is not null)
        {
            task.Done = !task.Done;
        }
    }
}
