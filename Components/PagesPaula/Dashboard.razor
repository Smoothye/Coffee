@page "/dashboard"
@page "/dashboard/{EventId:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@layout PaulaLayout
@rendermode InteractiveServer
@using WeddingPlannerApp.Components.PagesPaula.DashboardWidgets
@using WeddingPlannerApp.DTOs.Budget
@using WeddingPlannerApp.DTOs.Event
@using WeddingPlannerApp.DTOs.Guest
@using WeddingPlannerApp.DTOs.Menu
@using WeddingPlannerApp.DTOs.Task
@using WeddingPlannerApp.DTOs.Venue
@using WeddingPlannerApp.Models
@using WeddingPlannerApp.Data
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using WeddingPlannerApp.Services
@inject NavigationManager Nav
@inject WeddingPlannerApp.Services.WeddingApiClient Api
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject WeddingStateService State
@inject IJSRuntime JS

<HeadContent>
    <link rel="stylesheet" href="styles/Dashboard.css" />
</HeadContent>

<PageNav Title="Dashboard"
         Subtitle="@($"{daysUntilWedding} days until your wedding")"
         IconSvg="@SvgIcons.DashboardNav" />

<ModalShell IsOpen="eventNotesOpen" Title="Event notes" OnClose="CloseEventNotes" ExtraClass="table-notes-modal">
    <div class="table-notes-body">
        <label class="form-label">Wedding notes</label>
        <textarea class="input table-notes-input"
                  maxlength="180"
                  rows="4"
                  @bind="eventNotesDraft"
                  @bind:event="oninput"
                  placeholder="Add a short note for this event"></textarea>
        <p class="field-hint">@eventNotesDraft.Length/180 characters</p>
        @if (!string.IsNullOrWhiteSpace(eventNotesError))
        {
            <div class="error-banner">@SvgIcons.AlertCircle @eventNotesError</div>
        }
        <div class="table-notes-actions">
            <button class="btn-outline" @onclick="CloseEventNotes">Cancel</button>
            <button class="btn-add-guest" disabled="@eventNotesSaving" @onclick="SaveEventNotes">
                @SvgIcons.CheckSmall @(eventNotesSaving ? "Saving..." : "Save")
            </button>
        </div>
    </div>
</ModalShell>

<div class="dash-body">
    @if (!string.IsNullOrEmpty(loadError))
    {
        <div class="error-banner">@SvgIcons.AlertCircle @loadError</div>
    }

    @if (venueApprovalNotice is not null && !venueApprovalNoticeDismissed)
    {
        <div class="venue-approval-banner">
            <div class="venue-approval-icon">@SvgIcons.CheckCircle</div>
            <div>
                <p class="venue-approval-title">Venue change approved</p>
                <p class="venue-approval-copy">Your wedding venue is now <strong>@venueApprovalNotice.VenueName</strong>.</p>
            </div>
            <button type="button" class="venue-approval-dismiss" title="Dismiss notification" @onclick="DismissVenueApprovalNotice">
                @SvgIcons.XSmall
            </button>
        </div>
    }

    <div class="dash-header">
        <div>
            <h1 class="dash-greeting">@Greeting, @userDisplayName</h1>
            <p class="dash-subtitle">
                @SvgIcons.CalendarSmall
                @daysUntilWedding days until your wedding - @weddingDate.ToString("MMMM d, yyyy")
            </p>
        </div>
        <button type="button" class="dash-notes-btn" @onclick="OpenEventNotes">
            @SvgIcons.Edit Notes
        </button>
    </div>

    <CountdownCard WeddingDate="weddingDate"
                   DaysUntilWedding="daysUntilWedding"
                   WeeksUntilWedding="weeksUntilWedding"
                   MonthsUntilWedding="monthsUntilWedding" />

    <div class="dash-grid">
        <BudgetWidget BudgetTotal="budgetTotal"
                      BudgetSpent="budgetSpent"
                      Categories="budgetCategories"
                      Href="/budget" />

        <RsvpWidget Confirmed="rsvpConfirmed"
                    Pending="rsvpPending"
                    Declined="rsvpDeclined"
                    PlusOnes="rsvpPlusOnes"
                    Href="@($"/guests/{EventId}")" />

        <TasksWidget Tasks="tasks"
                     OnToggleTask="ToggleTask"
                     Href="@($"/tasks/{EventId}")" />

        <MenuDetailsWidget SelectedMenu="@selectedMenu"
                           MenuRows="menuRows"
                           MenuEstimate="menuEstimate"
                           VenueName="@venueName"
                           ExpectedGuests="expectedGuests"
                           ActualGuests="actualGuests"
                           SeatedGuests="seatedGuests"
                           SeatingTotalGuests="seatingTotalGuests"
                           TablesConfirmed="tablesConfirmed"
                           BudgetPercent="budgetPercent"
                           Href="@($"/menu/{EventId}")"
                           VenueHref="@($"/venues/event/{EventId}")"
                           GuestsHref="@($"/guests/{EventId}")"
                           TablesHref="@($"/tables/{EventId}")"
                           BudgetHref="/budget" />
    </div>
</div>

@code {
    [Parameter] public int EventId { get; set; }

    DateTime weddingDate = DateTime.Today;
    string venueName = "";
    int expectedGuests = 0;
    int actualGuests = 0;
    bool tablesConfirmed = false;
    string selectedMenu = "";
    List<string> menuRows = [];
    int menuEstimate = 0;
    int seatedGuests = 0;
    int seatingTotalGuests = 0;
    string loadError = "";
    string userDisplayName = "there";
    EventDto? currentEvent;
    bool eventNotesOpen = false;
    bool eventNotesSaving = false;
    string eventNotesDraft = "";
    string eventNotesError = "";
    const string HeadConfigPrefix = "[[head-godparents:";
    const string HeadConfigSuffix = "]]";
    const string VenueRequestPrefix = "[[venue-change-request:";
    const string VenueApprovedPrefix = "[[venue-change-approved:";
    const string VenueMarkerSuffix = "]]";
    VenueApprovalNotice? venueApprovalNotice = null;
    string? venueApprovalStorageKey = null;
    string? checkedVenueApprovalStorageKey = null;
    bool venueApprovalNoticeDismissed = true;

    [CascadingParameter] public Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    int daysUntilWedding => Math.Max(0, (weddingDate - DateTime.Today).Days);
    int weeksUntilWedding => daysUntilWedding / 7;
    int monthsUntilWedding => Math.Max(0, ((weddingDate.Year - DateTime.Today.Year) * 12) + weddingDate.Month - DateTime.Today.Month);

    string Greeting => DateTime.Now.Hour switch { < 12 => "Good morning", < 18 => "Good afternoon", _ => "Good evening" };

    int budgetTotal = 0;
    int budgetSpent = 0;
    int budgetEstimated = 0;
    int budgetPercent => budgetTotal > 0 ? budgetEstimated * 100 / budgetTotal : 0;

    List<DashboardBudgetCategory> budgetCategories = [];

    int rsvpConfirmed = 0;
    int rsvpPending = 0;
    int rsvpDeclined = 0;
    int rsvpPlusOnes = 0;

    List<DashboardTaskItem> tasks = [];
    List<WeddingTaskDto> eventTasks = [];

    async Task ToggleTask(int id)
    {
        if (id < 0)
        {
            Nav.NavigateTo("/budget");
            return;
        }

        var task = eventTasks.FirstOrDefault(t => t.TaskId == id);
        if (task is null)
            return;

        var done = !task.Done;
        try
        {
            await Api.UpdateTaskAsync(EventId, task.TaskId, new WeddingTaskUpdateDto
            {
                Title = task.Title,
                Category = task.Category,
                Priority = task.Priority,
                DueDate = task.DueDate,
                Done = done,
                Notes = task.Notes
            });

            task.Done = done;
            task.Status = done ? "completed" : "pending";
            task.CompletedAt = done ? DateTime.UtcNow : null;
            ApplyTasksState();
        }
        catch (Exception ex)
        {
            loadError = $"Could not update task: {ex.Message}";
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        loadError = "";

        try
        {
            if (await RedirectAdminAsync())
                return;

            await LoadUserName();

            var ownEvent = (await Api.GetEventsAsync()).OrderByDescending(e => e.EventId).FirstOrDefault();
            if (ownEvent is null)
            {
                Nav.NavigateTo("/onboarding", replace: true);
                return;
            }

            if (EventId <= 0 || EventId != ownEvent.EventId)
            {
                EventId = ownEvent.EventId;
                Nav.NavigateTo($"/dashboard/{EventId}", replace: true);
                return;
            }

            var eventItem = await Api.GetEventAsync(EventId);
            if (eventItem is null)
            {
                Nav.NavigateTo("/onboarding", replace: true);
                return;
            }

            if (eventItem is null)
                return;

            ApplyEvent(eventItem);

            var guests = await Api.GetGuestsAsync(EventId);
            ApplyGuestStats(guests);

            var venue = await Api.GetVenueAsync(eventItem.VenueId);
            if (venue != null)
                venueName = venue.Name;
            SetVenueApprovalNotice(eventItem, venue);

            var menus = await Api.GetMenusAsync();
            selectedMenu = FormatMenuNames(eventItem.MenuIds, menus);
            ApplyMenuRows(eventItem.MenuIds, menus, guests, eventItem.EstimatedGuests);
            State.ReplaceBudgetItems((await Api.GetBudgetItemsAsync(EventId)).Select(ToBudgetItem));
            if (venue != null)
                State.UpsertVenueBudgetItem(venue.Name, (int)Math.Round(venue.EstimatedPrice));
            State.UpsertMenuBudgetItem(menuEstimate);
            ApplyBudgetState();
            eventTasks = await Api.GetTasksAsync(EventId);
            ApplyTasksState();
        }
        catch (Exception ex)
        {
            loadError = $"Could not load dashboard data: {ex.Message}";
        }
    }

    async Task<bool> RedirectAdminAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!authState.User.IsInRole("Admin"))
            return false;

        Nav.NavigateTo("/admin", replace: true);
        return true;
    }

    async Task LoadUserName()
    {
        if (AuthenticationStateTask is null)
            return;

        var authState = await AuthenticationStateTask;
        var user = await UserManager.GetUserAsync(authState.User);
        if (user is null)
            return;

        userDisplayName = !string.IsNullOrWhiteSpace(user.FirstName)
            ? user.FirstName.Trim()
            : user.Email?.Split('@')[0] ?? "there";
    }

    void ApplyEvent(EventDto eventItem)
    {
        currentEvent = eventItem;
        weddingDate = eventItem.EventDate;
        expectedGuests = eventItem.EstimatedGuests;
        if (State.BudgetTotal <= 0)
            State.UpdateBudgetTotal((int)eventItem.TotalBudget);
        selectedMenu = eventItem.MenuIds.Count > 0
            ? $"{eventItem.MenuIds.Count} menus selected"
            : "Select a menu";
    }

    void SetVenueApprovalNotice(EventDto eventItem, VenueDto? venue)
    {
        var approved = ReadApprovedVenueIds(eventItem.Notes);
        if (approved is null || approved.Value.RequestedVenueId != eventItem.VenueId)
        {
            venueApprovalNotice = null;
            venueApprovalStorageKey = null;
            checkedVenueApprovalStorageKey = null;
            venueApprovalNoticeDismissed = true;
            return;
        }

        venueApprovalNotice = new VenueApprovalNotice(venue?.Name ?? $"Venue #{eventItem.VenueId}");
        venueApprovalStorageKey = VenueApprovalSeenKey(eventItem.EventId, approved.Value.RequestedVenueId);
        venueApprovalNoticeDismissed = true;
    }

    async Task DismissVenueApprovalNotice()
    {
        venueApprovalNoticeDismissed = true;
        if (string.IsNullOrWhiteSpace(venueApprovalStorageKey))
            return;

        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", venueApprovalStorageKey, "1");
        }
        catch { }
    }

    void OpenEventNotes()
    {
        eventNotesError = "";
        eventNotesDraft = RemoveHiddenEventMarkers(currentEvent?.Notes).Trim();
        eventNotesOpen = true;
    }

    void CloseEventNotes()
    {
        eventNotesOpen = false;
        eventNotesError = "";
    }

    async Task SaveEventNotes()
    {
        if (currentEvent is null)
            return;

        eventNotesSaving = true;
        eventNotesError = "";

        try
        {
            var notes = WithHeadConfigPreserved(currentEvent.Notes, eventNotesDraft.Trim());
            await Api.UpdateEventAsync(currentEvent.EventId, new EventUpdateDto
            {
                VenueId = currentEvent.VenueId,
                MenuIds = currentEvent.MenuIds,
                Name = currentEvent.Name,
                BrideName = currentEvent.BrideName,
                GroomName = currentEvent.GroomName,
                EventDate = currentEvent.EventDate,
                EstimatedGuests = currentEvent.EstimatedGuests,
                TotalBudget = currentEvent.TotalBudget,
                Notes = string.IsNullOrWhiteSpace(notes) ? null : notes
            });

            currentEvent.Notes = string.IsNullOrWhiteSpace(notes) ? null : notes;
            CloseEventNotes();
        }
        catch (Exception ex)
        {
            eventNotesError = $"Could not save notes: {ex.Message}";
        }
        finally
        {
            eventNotesSaving = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (venueApprovalNotice is null ||
            string.IsNullOrWhiteSpace(venueApprovalStorageKey) ||
            checkedVenueApprovalStorageKey == venueApprovalStorageKey)
            return;

        checkedVenueApprovalStorageKey = venueApprovalStorageKey;

        try
        {
            var seen = await JS.InvokeAsync<string?>("localStorage.getItem", venueApprovalStorageKey);
            venueApprovalNoticeDismissed = string.Equals(seen, "1", StringComparison.Ordinal);
        }
        catch
        {
            venueApprovalNoticeDismissed = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    static string WithHeadConfigPreserved(string? existingNotes, string visibleNotes)
    {
        var hiddenMarkers = ReadHiddenEventMarkers(existingNotes);
        return string.IsNullOrWhiteSpace(hiddenMarkers)
            ? visibleNotes
            : $"{visibleNotes.Trim()} {hiddenMarkers}".Trim();
    }

    static string ReadHiddenEventMarkers(string? notes)
    {
        var markers = new[]
        {
            ReadMarker(notes, HeadConfigPrefix, HeadConfigSuffix),
            ReadMarker(notes, VenueRequestPrefix, VenueMarkerSuffix),
            ReadMarker(notes, VenueApprovedPrefix, VenueMarkerSuffix)
        }.Where(marker => !string.IsNullOrWhiteSpace(marker));

        return string.Join(" ", markers);
    }

    static string ReadMarker(string? notes, string prefix, string suffix)
    {
        if (string.IsNullOrWhiteSpace(notes))
            return "";

        var start = notes.IndexOf(prefix, StringComparison.OrdinalIgnoreCase);
        if (start < 0)
            return "";

        var end = notes.IndexOf(suffix, start, StringComparison.OrdinalIgnoreCase);
        if (end < 0)
            return "";

        return notes[start..(end + suffix.Length)].Trim();
    }

    static string RemoveHiddenEventMarkers(string? notes)
    {
        if (string.IsNullOrWhiteSpace(notes))
            return "";

        var cleaned = RemoveMarker(notes, HeadConfigPrefix, HeadConfigSuffix);
        cleaned = RemoveMarker(cleaned, VenueRequestPrefix, VenueMarkerSuffix);
        cleaned = RemoveMarker(cleaned, VenueApprovedPrefix, VenueMarkerSuffix);
        return cleaned.Trim();
    }

    static (int CurrentVenueId, int RequestedVenueId)? ReadApprovedVenueIds(string? notes)
    {
        var marker = ReadMarker(notes, VenueApprovedPrefix, VenueMarkerSuffix);
        if (string.IsNullOrWhiteSpace(marker))
            return null;

        var content = marker[VenueApprovedPrefix.Length..^VenueMarkerSuffix.Length];
        var parts = content.Split(':', 2);
        if (parts.Length != 2)
            return null;

        return int.TryParse(parts[0], out var currentVenueId) &&
               int.TryParse(parts[1], out var requestedVenueId)
            ? (currentVenueId, requestedVenueId)
            : null;
    }

    static string VenueApprovalSeenKey(int eventId, int venueId) =>
        $"venue-change-approved-seen:{eventId}:{venueId}";

    static string RemoveMarker(string notes, string prefix, string suffix)
    {
        var start = notes.IndexOf(prefix, StringComparison.OrdinalIgnoreCase);
        if (start < 0)
            return notes;

        var end = notes.IndexOf(suffix, start, StringComparison.OrdinalIgnoreCase);
        if (end < 0)
            return notes[..start].Trim();

        return (notes[..start] + notes[(end + suffix.Length)..]).Trim();
    }

    sealed record VenueApprovalNotice(string VenueName);

    static string FormatMenuNames(
        IReadOnlyCollection<int> menuIds,
        IReadOnlyCollection<MenuDto> menus)
    {
        if (menuIds.Count == 0)
            return "Select a menu";

        var menuNames = menus
            .Where(menu => menuIds.Contains(menu.MenuId))
            .Select(menu => menu.Name)
            .ToList();

        return menuNames.Count > 0
            ? string.Join(", ", menuNames)
            : $"{menuIds.Count} menus selected";
    }

    void ApplyGuestStats(IReadOnlyCollection<GuestDto> guests)
    {
        rsvpConfirmed = guests.Count(g => g.RsvpStatus == RsvpStatus.Confirmed);
        rsvpPending = guests.Count(g => g.RsvpStatus == RsvpStatus.Pending);
        rsvpDeclined = guests.Count(g => g.RsvpStatus == RsvpStatus.Declined);
        rsvpPlusOnes = guests.Count(g => g.HasPlusOne);
        var activeGuests = guests.Where(g => g.RsvpStatus != RsvpStatus.Declined).ToList();
        actualGuests = activeGuests.Count;
        seatingTotalGuests = activeGuests.Count;
        seatedGuests = activeGuests.Count(g => g.TableId.HasValue && g.SeatNumber.HasValue);
        tablesConfirmed = seatingTotalGuests > 0 && seatedGuests == seatingTotalGuests;
    }

    void ApplyMenuRows(
        IReadOnlyCollection<int> menuIds,
        IReadOnlyCollection<MenuDto> menus,
        IReadOnlyCollection<GuestDto> guests,
        int estimatedGuests)
    {
        var selectedMenus = menus
            .Where(menu => menuIds.Contains(menu.MenuId))
            .OrderBy(menu => menu.DietaryType)
            .ThenBy(menu => menu.Price)
            .ToList();
        var activeGuests = guests.Where(g => g.RsvpStatus != RsvpStatus.Declined).ToList();
        var selectedMenuTypes = selectedMenus.Select(menu => menu.DietaryType).Distinct().ToList();
        var counts = BuildMenuCounts(activeGuests, estimatedGuests, selectedMenuTypes);

        menuRows = selectedMenus
            .Select(menu =>
            {
                var guestCount = counts.TryGetValue(menu.DietaryType, out var count) ? count : 0;
                var total = menu.Price * guestCount;
                return $"{menu.Name} - {menu.DietaryType} - {guestCount} guests x ${menu.Price:0}/person = ${total:N0}";
            })
            .ToList();

        menuEstimate = selectedMenus.Sum(menu =>
        {
            var guestCount = counts.TryGetValue(menu.DietaryType, out var count) ? count : 0;
            return (int)Math.Round(menu.Price * guestCount);
        });
    }

    static Dictionary<MenuDietaryType, int> BuildMenuCounts(
        IReadOnlyList<GuestDto> guests,
        int estimatedGuests,
        IReadOnlyCollection<MenuDietaryType> selectedMenuTypes)
    {
        if (selectedMenuTypes.Count == 0)
            return [];

        if (guests.Count == 0)
            return new() { [ResolveSelectedMenuType(MenuDietaryType.Standard, selectedMenuTypes)] = Math.Max(estimatedGuests, 0) };

        return guests
            .GroupBy(guest => ResolveSelectedMenuType(MenuTypeFor(guest.DietaryRequirements), selectedMenuTypes))
            .ToDictionary(group => group.Key, group => group.Count());
    }

    static MenuDietaryType ResolveSelectedMenuType(
        MenuDietaryType preferredType,
        IReadOnlyCollection<MenuDietaryType> selectedMenuTypes)
    {
        if (selectedMenuTypes.Contains(preferredType))
            return preferredType;

        if (selectedMenuTypes.Contains(MenuDietaryType.Standard))
            return MenuDietaryType.Standard;

        return selectedMenuTypes.First();
    }

    static MenuDietaryType MenuTypeFor(DietaryRequirements dietary) => dietary switch
    {
        DietaryRequirements.Vegan => MenuDietaryType.Vegan,
        DietaryRequirements.Vegetarian => MenuDietaryType.Vegetarian,
        DietaryRequirements.Fasting => MenuDietaryType.Fasting,
        _ => MenuDietaryType.Standard
    };

    void ApplyBudgetState()
    {
        budgetTotal = State.BudgetTotal;
        budgetSpent = State.BudgetSpent;
        budgetEstimated = State.BudgetEstimated;
        budgetCategories = State.BudgetItems
            .GroupBy(item => item.Category)
            .Select(group => new DashboardBudgetCategory(group.Key, group.Sum(item => item.Actual > 0 ? item.Actual : item.Estimated), BudgetCategoryColor(group.Key)))
            .OrderByDescending(category => category.Amount)
            .ToList();
    }

    void ApplyTasksState()
    {
        tasks = eventTasks
            .Select(task => new DashboardTaskItem(
                task.TaskId,
                task.Title,
                task.Category,
                task.DueDate,
                task.Priority,
                task.Done))
            .ToList();

        if (currentEvent is not null && currentEvent.TotalBudget <= 0)
        {
            tasks.Insert(0, new DashboardTaskItem(
                -1,
                "Set your wedding budget",
                "Budget",
                DateTime.Today,
                "high"));
        }
    }

    static string BudgetCategoryColor(string category) => category switch
    {
        "Venue" => "#7d9b76",
        "Catering" => "#a8c8a4",
        "Photography" => "#4f6b4a",
        "Florals" => "#c8dbc5",
        "Music" => "#d97706",
        "Dress/Suit" => "#7c3aed",
        "Decor" => "#db2777",
        "Invitations" => "#0891b2",
        "Transport" => "#64748b",
        "Cake" => "#f59e0b",
        _ => "#9ca3af"
    };

    static BudgetItem ToBudgetItem(BudgetItemDto item) => new()
    {
        Id = item.BudgetItemId,
        SupplierId = item.SupplierId,
        Name = item.Name,
        Category = item.Category,
        Estimated = item.Estimated,
        Actual = item.Actual,
        Paid = item.Paid
    };
}
