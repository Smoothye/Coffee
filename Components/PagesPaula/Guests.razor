@page "/guests"
@page "/guests/{EventId:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@layout PaulaLayout
@using System.Text
@using System.ComponentModel.DataAnnotations
@using System.Text.RegularExpressions
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using WeddingPlannerApp.Components.LayoutPaula
@using WeddingPlannerApp.DTOs.Event
@using WeddingPlannerApp.Components.PagesPaula.GuestComponents
@using WeddingPlannerApp.DTOs.Guest
@using WeddingPlannerApp.Models
@using WeddingPlannerApp.Services
@using GuestGroup = WeddingPlannerApp.Models.Group
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject WeddingApiClient Api
@inject AuthenticationStateProvider AuthStateProvider

<PageNav Title="Guest List"
         Subtitle="Manage &amp; track RSVPs"
         IconSvg="@SvgIcons.GuestListNav" />

<CsvGuideModal IsOpen="csvGuideOpen"
               Title="Import Guests"
               AcceptedTitle="Accepted formats"
               Columns="guestCsvColumns"
               OnClose="@(() => { csvGuideOpen = false; dragActive = false; })">
    <LeftFooter>
            <div class="csv-rules">
                <p class="csv-rules-title">@SvgIcons.AlertCircle Duplicate rules</p>
                <ul class="csv-rules-list">
                    <li>Same <strong>email</strong> or <strong>phone</strong> -> skipped</li>
                    <li>Same <strong>full name</strong> -> allowed (shown as duplicate)</li>
                </ul>
            </div>
            <button class="btn-outline" style="margin-top:.75rem;width:100%;justify-content:center;" @onclick="DownloadTemplate">
                @SvgIcons.Download Download blank template
            </button>
    </LeftFooter>
    <UploadContent>
            <p class="csv-section-title">Upload file</p>
            <div class="csv-dropzone @(dragActive ? "csv-dropzone-active" : "")"
                 @ondragenter="@((e) => dragActive = true)"
                 @ondragleave="@((e) => dragActive = false)"
                 @ondragover:preventDefault="true"
                 @ondragover="@((e) => dragActive = true)">
                <div class="csv-drop-inner">
                    @if (importResult == null)
                    {
                        <div class="csv-drop-icon">@SvgIcons.UploadCloud</div>
                        <p class="csv-drop-title">Drag &amp; drop your .csv here</p>
                        <p class="csv-drop-sub">or</p>
                    }
                    else
                    {
                        <div class="csv-drop-icon @(importResult.HasWarning ? "icon-warn" : "icon-ok")">
                            @(importResult.HasWarning ? SvgIcons.AlertCircle : SvgIcons.CheckCircle)
                        </div>
                        <p class="csv-drop-title">@importResult.Message</p>
                        <p class="csv-drop-sub">Upload another file?</p>
                    }
                    <label class="btn-add" style="cursor:pointer;margin-top:.5rem;">
                        @SvgIcons.Upload Browse file
                        <InputFile OnChange="HandleImport" accept=".csv" style="display:none;" />
                    </label>
                    <p class="csv-accepted-note">Accepted: <strong>.csv</strong> only</p>
                </div>
            </div>
            @if (importResult != null)
            {
                <button class="btn-add-guest" style="margin-top:.75rem;"
                        @onclick="@(() => { csvGuideOpen = false; dragActive = false; importResult = null; })">
                    @SvgIcons.Check Done - View Guests
                </button>
            }
    </UploadContent>
</CsvGuideModal>

<GuestAddModal IsOpen="dialogOpen"
               NewGuest="newGuest"
               FormError="@formError"
               FieldErrors="guestFieldErrors"
               AvailableMenuOptions="availableMenuOptions"
               PlusOneDietary="plusOneDietary"
               PlusOneDietaryChanged="@((value) => plusOneDietary = value)"
               OnAdd="AddGuest"
               OnClose="CloseDialog" />

@if (!string.IsNullOrEmpty(importSummary))
{
    <div class="import-toast @(importHasWarning ? "import-toast-warn" : "import-toast-ok")">
        @(importHasWarning ? SvgIcons.AlertCircle : SvgIcons.CheckCircle)
        @importSummary
        <button class="import-toast-close" @onclick="@(() => importSummary = "")">@SvgIcons.X</button>
    </div>
}

<ConfirmDialog IsOpen="confirmDeleteOpen"
               Title="Delete guest?"
               Message="@confirmDeleteMessage"
               ConfirmText="Delete guest"
               OnCancel="@(() => confirmDeleteOpen = false)"
               OnConfirm="ConfirmRemoveGuest" />

<div class="guests-wrap">
    @if (isLoading)
    {
        <div class="import-toast import-toast-ok">@SvgIcons.CheckCircle Loading guests...</div>
    }
    else if (!string.IsNullOrEmpty(loadError))
    {
        <div class="import-toast import-toast-warn">@SvgIcons.AlertCircle @loadError</div>
    }

    <GuestStats Total="@guests.Count"
                Confirmed="@guests.Count(g => g.RsvpStatus == RsvpStatus.Confirmed)"
                Pending="@guests.Count(g => g.RsvpStatus == RsvpStatus.Pending)"
                Declined="@guests.Count(g => g.RsvpStatus == RsvpStatus.Declined)" />

    <div class="guests-window">
        <div class="guest-tools-row guest-toolbar-shell">
            <GuestFilters Search="@search"
                          SearchChanged="@((value) => search = value)"
                          Group="@filterGroup"
                          GroupChanged="@((value) => filterGroup = value)"
                          Status="@filterStatus"
                          StatusChanged="@((value) => filterStatus = value)" />

            <GuestCommandBar OnCsvGuide="@OpenCsvGuide"
                             OnImport="HandleImport"
                             OnExport="ExportCSV"
                             OnAddGuest="OpenDialog" />
        </div>

        <GuestList Guests="FilteredGuests.ToList()"
                   OnTogglePlusOne="TogglePlusOne"
                   OnSetStatus="SetStatus"
                   OnSetDietary="SetDietary"
                   OnRemove="RemoveGuest"
                   MenuOptions="availableMenuOptions" />
    </div>
</div>

@code {
    [Parameter] public int EventId { get; set; }

    bool   dialogOpen      = false;
    string formError       = "";
    string search          = "";
    string filterGroup     = "all";
    string filterStatus    = "all";
    string importSummary   = "";
    bool   importHasWarning = false;
    bool   csvGuideOpen    = false;
    bool   dragActive      = false;
    bool   confirmDeleteOpen = false;
    bool   isLoading      = true;
    int    pendingDeleteGuestId;
    string confirmDeleteMessage = "Delete this guest? This cannot be undone.";
    string loadError = "";
    ImportResult? importResult = null;
    Dictionary<string, string> guestFieldErrors = new();
    DietaryRequirements plusOneDietary = DietaryRequirements.Standard;
    const string PlusOneNotePrefix = "Plus one for guest ";
    const string CoupleNotePrefix = "Wedding couple:";
    const string BrideCoupleNote = "Wedding couple: bride";
    const string GroomCoupleNote = "Wedding couple: groom";
    static readonly Regex GuestNamePattern = new(@"^[\p{L}\p{M}][\p{L}\p{M}' -]*$", RegexOptions.Compiled);
    readonly EmailAddressAttribute emailValidator = new();
    List<GuestMenuOption> availableMenuOptions = [new(DietaryRequirements.Standard, "Standard")];

    static readonly CsvGuideColumn[] guestCsvColumns =
    {
        new() { Name = "FirstName", Required = true, ValidValues = "Any text" },
        new() { Name = "LastName", Required = true, ValidValues = "Any text" },
        new() { Name = "Email", ValidValues = "Duplicate check" },
        new() { Name = "Phone", ValidValues = "Any format" },
        new() { Name = "Age", ValidValues = "Number" },
        new() { Name = "Gender", ValidValues = "male, female, other" },
        new() { Name = "Dietary", ValidValues = "standard, vegan, vegetarian, fasting" },
        new() { Name = "Group", ValidValues = "family, friends, colleagues" },
        new() { Name = "Status", ValidValues = "confirmed, pending" },
        new() { Name = "PlusOne", ValidValues = "Yes, No" },
    };

    List<GuestDto> guests = new();

    GuestCreateDto newGuest = EmptyGuestCreateDto();

    protected override async Task OnParametersSetAsync()
    {
        await EnsureEventAndLoadGuests();
    }

    IEnumerable<GuestDto> FilteredGuests => guests.Where(g =>
    {
        var name = $"{g.FirstName} {g.LastName}".ToLower();
        var matchSearch = string.IsNullOrEmpty(search) || name.Contains(search.ToLower()) || g.Email.Contains(search, StringComparison.OrdinalIgnoreCase);
        var matchGroup  = filterGroup == "all" || g.Group == ToGroup(filterGroup);
        var matchStatus = filterStatus == "all" || g.RsvpStatus == ToRsvpStatus(filterStatus);
        return matchSearch && matchGroup && matchStatus;
    })
    .OrderBy(g => g.FirstName)
    .ThenBy(g => g.LastName);

    async Task EnsureEventAndLoadGuests()
    {
        loadError = "";
        isLoading = true;

        try
        {
            if (await RedirectAdminAsync())
                return;

            var ownEvent = (await Api.GetEventsAsync()).OrderByDescending(e => e.EventId).FirstOrDefault();
            if (ownEvent is null)
            {
                guests.Clear();
                loadError = "No event exists yet. Create an event first, then add guests.";
                return;
            }

            if (EventId <= 0 || EventId != ownEvent.EventId)
            {
                EventId = ownEvent.EventId;
                Nav.NavigateTo($"/guests/{EventId}", replace: true);
                return;
            }

            await LoadAvailableMenuOptionsAsync(ownEvent.MenuIds);
            guests = await Api.GetGuestsAsync(EventId);
            await EnsureCoupleRowsAsync(ownEvent);
            await EnsurePlusOneRowsAsync();
            await NormalizeGuestMenuPreferencesAsync();
        }
        catch (Exception ex)
        {
            guests.Clear();
            loadError = $"Could not load guests: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    static GuestCreateDto EmptyGuestCreateDto() => new()
    {
        FirstName = "",
        LastName = "",
        Email = "",
        Group = GuestGroup.Friends,
        DietaryRequirements = DietaryRequirements.Standard,
        RsvpStatus = RsvpStatus.Pending
    };

    static GuestCreateDto CleanCreateDto(GuestCreateDto guest) => new()
    {
        TableId = guest.TableId,
        FirstName = guest.FirstName.Trim(),
        LastName = guest.LastName.Trim(),
        Age = guest.Age,
        Email = guest.Email.Trim(),
        Phone = string.IsNullOrWhiteSpace(guest.Phone) ? null : guest.Phone.Trim(),
        Gender = guest.Gender,
        RsvpStatus = guest.RsvpStatus,
        Group = guest.Group,
        DietaryRequirements = guest.DietaryRequirements,
        HasPlusOne = guest.HasPlusOne,
        SeatNumber = guest.SeatNumber,
        Notes = string.IsNullOrWhiteSpace(guest.Notes) ? null : guest.Notes,
    };

    static GuestUpdateDto ToUpdateDto(GuestDto guest) => new()
    {
        TableId = guest.TableId,
        FirstName = guest.FirstName.Trim(),
        LastName = guest.LastName.Trim(),
        Age = guest.Age,
        Email = guest.Email.Trim(),
        Phone = string.IsNullOrWhiteSpace(guest.Phone) ? null : guest.Phone.Trim(),
        Gender = guest.Gender,
        RsvpStatus = guest.RsvpStatus,
        Group = guest.Group,
        DietaryRequirements = guest.DietaryRequirements,
        HasPlusOne = guest.HasPlusOne,
        SeatNumber = guest.SeatNumber,
        Notes = string.IsNullOrWhiteSpace(guest.Notes) ? null : guest.Notes,
    };

    static GuestCreateDto BuildPlusOneCreateDto(GuestDto owner, DietaryRequirements dietary) => new()
    {
        FirstName = "Companion",
        LastName = $"of {owner.FirstName} {owner.LastName}".Trim(),
        Email = $"plusone-{owner.EventId}-{owner.GuestId}@wedding.local",
        Phone = null,
        Age = null,
        Gender = null,
        RsvpStatus = owner.RsvpStatus,
        Group = owner.Group,
        DietaryRequirements = dietary,
        HasPlusOne = false,
        Notes = PlusOneNote(owner.GuestId)
    };

    static string PlusOneNote(int ownerId) => $"{PlusOneNotePrefix}{ownerId}";

    static bool IsPlusOneGuest(GuestDto? guest) =>
        guest?.Notes?.StartsWith(PlusOneNotePrefix, StringComparison.OrdinalIgnoreCase) == true;

    static bool IsCoupleGuest(GuestDto? guest) =>
        guest?.Notes?.StartsWith(CoupleNotePrefix, StringComparison.OrdinalIgnoreCase) == true;

    static int? PlusOneOwnerId(GuestDto guest)
    {
        if (!IsPlusOneGuest(guest))
            return null;

        var idText = guest.Notes![PlusOneNotePrefix.Length..].Trim();
        return int.TryParse(idText, out var ownerId) ? ownerId : null;
    }

    async Task<bool> RedirectAdminAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!authState.User.IsInRole("Admin"))
            return false;

        Nav.NavigateTo("/admin", replace: true);
        return true;
    }

    GuestDto? FindPlusOneFor(int ownerId) =>
        guests.FirstOrDefault(g => string.Equals(g.Notes?.Trim(), PlusOneNote(ownerId), StringComparison.OrdinalIgnoreCase));

    async Task EnsureCoupleRowsAsync(EventDto eventItem)
    {
        await EnsureCoupleRowAsync(eventItem, BrideCoupleNote, eventItem.BrideName, "Bride", Gender.Female);
        await EnsureCoupleRowAsync(eventItem, GroomCoupleNote, eventItem.GroomName, "Groom", Gender.Male);
    }

    async Task EnsureCoupleRowAsync(EventDto eventItem, string note, string? fullName, string fallbackRole, Gender gender)
    {
        var existing = guests.FirstOrDefault(g => string.Equals(g.Notes?.Trim(), note, StringComparison.OrdinalIgnoreCase));
        var dietary = existing?.DietaryRequirements ?? DefaultAvailableDietary();
        var desired = BuildCoupleCreateDto(eventItem.EventId, fullName, fallbackRole, note, gender, dietary);

        if (existing is null)
        {
            var created = await Api.CreateGuestAsync(EventId, desired);
            if (created is not null)
                guests.Add(created);
            return;
        }

        if (existing.FirstName == desired.FirstName &&
            existing.LastName == desired.LastName &&
            existing.Email == desired.Email &&
            existing.RsvpStatus == RsvpStatus.Confirmed &&
            existing.Group == GuestGroup.Family &&
            existing.HasPlusOne == false &&
            existing.Gender == gender)
        {
            return;
        }

        existing.FirstName = desired.FirstName;
        existing.LastName = desired.LastName;
        existing.Email = desired.Email;
        existing.RsvpStatus = RsvpStatus.Confirmed;
        existing.Group = GuestGroup.Family;
        existing.HasPlusOne = false;
        existing.Gender = gender;
        existing.Notes = note;
        await Api.UpdateGuestAsync(EventId, existing.GuestId, ToUpdateDto(existing));
    }

    static GuestCreateDto BuildCoupleCreateDto(
        int eventId,
        string? fullName,
        string fallbackRole,
        string note,
        Gender gender,
        DietaryRequirements dietary)
    {
        var (firstName, lastName) = CoupleNameParts(fullName, fallbackRole);
        return new()
        {
            FirstName = firstName,
            LastName = lastName,
            Email = $"couple-{fallbackRole.ToLowerInvariant()}-{eventId}@wedding.local",
            Gender = gender,
            RsvpStatus = RsvpStatus.Confirmed,
            Group = GuestGroup.Family,
            DietaryRequirements = dietary,
            HasPlusOne = false,
            Notes = note
        };
    }

    static (string FirstName, string LastName) CoupleNameParts(string? fullName, string fallbackRole)
    {
        var name = string.IsNullOrWhiteSpace(fullName) ? fallbackRole : fullName.Trim();
        if (!GuestNamePattern.IsMatch(name))
            name = fallbackRole;

        var parts = name.Split(' ', 2, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 0)
            return (fallbackRole, "Partner");

        if (parts.Length == 1)
            return (parts[0], fallbackRole);

        return (parts[0], parts[1]);
    }

    async Task EnsurePlusOneRowsAsync()
    {
        var ownersMissingPlusOneRows = guests
            .Where(g => g.HasPlusOne && !IsPlusOneGuest(g) && FindPlusOneFor(g.GuestId) is null)
            .Where(g => !IsCoupleGuest(g))
            .ToList();

        foreach (var owner in ownersMissingPlusOneRows)
        {
            var plusOne = await Api.CreateGuestAsync(EventId, BuildPlusOneCreateDto(owner, owner.DietaryRequirements));
            if (plusOne != null)
                guests.Add(plusOne);
        }
    }

    static Gender? ToGender(string value) => value switch
    {
        "male" => Gender.Male,
        "female" => Gender.Female,
        "other" => Gender.Other,
        _ => null,
    };

    static GuestGroup ToGroup(string value) => value switch
    {
        "family" => GuestGroup.Family,
        "friends" => GuestGroup.Friends,
        "colleagues" => GuestGroup.Colleagues,
        _ => GuestGroup.Other,
    };

    static DietaryRequirements ToDietary(string value) => value switch
    {
        "standard" => DietaryRequirements.Standard,
        "casual" => DietaryRequirements.Standard,
        "vegan" => DietaryRequirements.Vegan,
        "vegetarian" => DietaryRequirements.Vegetarian,
        "fasting" => DietaryRequirements.Fasting,
        _ => DietaryRequirements.Standard,
    };

    void OpenDialog()
    {
        newGuest = EmptyGuestCreateDto();
        newGuest.DietaryRequirements = DefaultAvailableDietary();
        plusOneDietary = DefaultAvailableDietary();
        formError = "";
        guestFieldErrors.Clear();
        dialogOpen = true;
    }
    void CloseDialog() { dialogOpen = false; formError = ""; guestFieldErrors.Clear(); }

    bool IsDuplicate(string fn, string ln, string email, string phone) =>
        guests.Any(g =>
            $"{g.FirstName.ToLower()} {g.LastName.ToLower()}" == $"{fn.Trim().ToLower()} {ln.Trim().ToLower()}"
            || (!string.IsNullOrWhiteSpace(email) && g.Email.Trim().ToLower() == email.Trim().ToLower())
            || (!string.IsNullOrWhiteSpace(phone) && (g.Phone ?? "").Trim() == phone.Trim()));

    async Task AddGuest()
    {
        formError = "";
        guestFieldErrors.Clear();
        ValidateGuestDraft(newGuest, guestFieldErrors);
        if (guestFieldErrors.Count > 0) { formError = "Please fix the highlighted fields."; return; }
        newGuest.RsvpStatus = RsvpStatus.Pending;
        try
        {
            var wantsPlusOne = newGuest.HasPlusOne;
            var ownerToCreate = CleanCreateDto(newGuest);
            ownerToCreate.DietaryRequirements = NormalizeDietaryForSelectedMenus(ownerToCreate.DietaryRequirements);
            ownerToCreate.HasPlusOne = wantsPlusOne;
            var created = await Api.CreateGuestAsync(EventId, ownerToCreate);
            if (created != null)
            {
                guests.Add(created);
                if (wantsPlusOne)
                {
                    var plusOne = await Api.CreateGuestAsync(EventId, BuildPlusOneCreateDto(created, NormalizeDietaryForSelectedMenus(plusOneDietary)));
                    if (plusOne != null)
                        guests.Add(plusOne);
                }
            }
            CloseDialog();
        }
        catch (Exception ex)
        {
            formError = $"Could not add guest: {ex.Message}";
        }
    }

    async Task SetDietary(int id, DietaryRequirements dietary)
    {
        var g = guests.FirstOrDefault(x => x.GuestId == id);
        if (g == null) return;

        dietary = NormalizeDietaryForSelectedMenus(dietary);
        var previous = g.DietaryRequirements;
        g.DietaryRequirements = dietary;
        try
        {
            await Api.UpdateGuestAsync(EventId, id, ToUpdateDto(g));
        }
        catch (Exception ex)
        {
            g.DietaryRequirements = previous;
            importSummary = $"Could not update menu preference: {ex.Message}";
            importHasWarning = true;
        }
    }

    Task SetDietary((int Id, DietaryRequirements Dietary) change) => SetDietary(change.Id, change.Dietary);

    async Task SetStatus(int id, RsvpStatus status)
    {
        var g = guests.FirstOrDefault(x => x.GuestId == id);
        if (g == null) return;

        var previous = g.RsvpStatus;
        g.RsvpStatus = status;
        try
        {
            await Api.UpdateGuestAsync(EventId, id, ToUpdateDto(g));
        }
        catch (Exception ex)
        {
            g.RsvpStatus = previous;
            importSummary = $"Could not update guest status: {ex.Message}";
            importHasWarning = true;
        }
    }

    Task SetStatus((int Id, RsvpStatus Status) change) => SetStatus(change.Id, change.Status);

    async Task TogglePlusOne(int id)
    {
        var g = guests.FirstOrDefault(x => x.GuestId == id);
        if (g is null) return;

        var previous = g.HasPlusOne;
        var linkedPlusOne = FindPlusOneFor(g.GuestId);
        var shouldAddPlusOne = !g.HasPlusOne;
        g.HasPlusOne = shouldAddPlusOne;
        try
        {
            await Api.UpdateGuestAsync(EventId, id, ToUpdateDto(g));
            if (shouldAddPlusOne && linkedPlusOne is null)
            {
                var createdPlusOne = await Api.CreateGuestAsync(EventId, BuildPlusOneCreateDto(g, g.DietaryRequirements));
                if (createdPlusOne != null)
                    guests.Add(createdPlusOne);
            }
            else if (!shouldAddPlusOne && linkedPlusOne is not null)
            {
                await Api.DeleteGuestAsync(EventId, linkedPlusOne.GuestId);
                guests.Remove(linkedPlusOne);
            }
        }
        catch (Exception ex)
        {
            g.HasPlusOne = previous;
            importSummary = $"Could not update plus one: {ex.Message}";
            importHasWarning = true;
        }
    }

    void RemoveGuest(int id)
    {
        var g = guests.FirstOrDefault(x => x.GuestId == id);
        confirmDeleteMessage = g?.HasPlusOne == true || IsPlusOneGuest(g)
            ? "Delete this guest and their plus one? This cannot be undone."
            : "Delete this guest? This cannot be undone.";
        pendingDeleteGuestId = id;
        confirmDeleteOpen = true;
    }

    async Task ConfirmRemoveGuest()
    {
        var id = pendingDeleteGuestId;
        try
        {
            var guest = guests.FirstOrDefault(g => g.GuestId == id);
            if (guest is not null && IsPlusOneGuest(guest))
            {
                var ownerId = PlusOneOwnerId(guest);
                var owner = ownerId.HasValue ? guests.FirstOrDefault(g => g.GuestId == ownerId.Value) : null;
                if (owner is not null)
                {
                    owner.HasPlusOne = false;
                    await Api.UpdateGuestAsync(EventId, owner.GuestId, ToUpdateDto(owner));
                }
            }
            else if (guest is not null)
            {
                var linkedPlusOne = FindPlusOneFor(guest.GuestId);
                if (linkedPlusOne is not null)
                {
                    await Api.DeleteGuestAsync(EventId, linkedPlusOne.GuestId);
                    guests.Remove(linkedPlusOne);
                }
            }

            await Api.DeleteGuestAsync(EventId, id);
            guests.RemoveAll(g => g.GuestId == id);
            confirmDeleteOpen = false;
        }
        catch (Exception ex)
        {
            confirmDeleteOpen = false;
            importSummary = $"Could not delete guest: {ex.Message}";
            importHasWarning = true;
        }
    }

    async Task ExportCSV()
    {
        var sb = new StringBuilder();
        sb.AppendLine("FirstName,LastName,Email,Phone,Age,Gender,Dietary,Group,Status,PlusOne");
        foreach (var g in guests)
            sb.AppendLine($"{g.FirstName},{g.LastName},{g.Email},{g.Phone},{g.Age},{g.Gender},{DietaryExportLabel(g.DietaryRequirements)},{g.Group},{g.RsvpStatus},{(g.HasPlusOne ? "Yes" : "No")}");
        var base64 = Convert.ToBase64String(Encoding.UTF8.GetBytes(sb.ToString()));
        await JS.InvokeVoidAsync("eval", $"var a=document.createElement('a');a.href='data:text/csv;base64,{base64}';a.download='guest_list.csv';a.click()");
    }

    async Task HandleImport(InputFileChangeEventArgs e)
    {
        dragActive = false;
        var file = e.File;
        if (!file.Name.EndsWith(".csv", StringComparison.OrdinalIgnoreCase))
        { importResult = new ImportResult("Only .csv files are accepted.", true); return; }
        using var reader = new System.IO.StreamReader(file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024));
        var text = await reader.ReadToEndAsync();
        int imported = 0, skipped = 0;
        var guestsToCreate = new List<GuestCreateDto>();
        var validGroups   = new[] { "family", "friends", "colleagues", "other" };
        var validDietary  = new[] { "none", "standard", "casual", "vegan", "vegetarian", "fasting" };
        var validStatuses = new[] { "confirmed", "pending", "declined" };
        foreach (var line in text.Split('\n').Skip(1).Where(l => !string.IsNullOrWhiteSpace(l)))
        {
            var c         = line.TrimEnd('\r').Split(',');
            var firstName = c.ElementAtOrDefault(0)?.Trim() ?? "";
            var lastName  = c.ElementAtOrDefault(1)?.Trim() ?? "";
            var email     = c.ElementAtOrDefault(2)?.Trim() ?? "";
            var phone     = c.ElementAtOrDefault(3)?.Trim() ?? "";
            var ageStr    = c.ElementAtOrDefault(4)?.Trim() ?? "";
            var gender    = c.ElementAtOrDefault(5)?.Trim().ToLower() ?? "";
            var dietary   = c.ElementAtOrDefault(6)?.Trim().ToLower() ?? "";
            var group     = c.ElementAtOrDefault(7)?.Trim().ToLower() ?? "";
            var status    = c.ElementAtOrDefault(8)?.Trim().ToLower() ?? "";
            var plusOne   = c.ElementAtOrDefault(9)?.Trim().ToLower() ?? "";
            var importedGuest = new GuestCreateDto
            {
                FirstName = firstName, LastName = lastName, Email = email, Phone = phone,
                Age = int.TryParse(ageStr, out var age) ? age : null,
                Gender = ToGender(gender),
                DietaryRequirements = NormalizeDietaryForSelectedMenus(validDietary.Contains(dietary) ? ToDietary(dietary) : DietaryRequirements.Standard),
                Group = validGroups.Contains(group) ? ToGroup(group) : GuestGroup.Other,
                RsvpStatus = validStatuses.Contains(status) ? ToRsvpStatus(status) : RsvpStatus.Pending,
                HasPlusOne = plusOne is "yes" or "true" or "1",
            };
            var rowErrors = new Dictionary<string, string>();
            ValidateGuestDraft(importedGuest, rowErrors);
            if (rowErrors.Count > 0) { skipped++; continue; }
            guestsToCreate.Add(CleanCreateDto(importedGuest));
            imported++;
        }

        if (guestsToCreate.Count > 0)
        {
            try
            {
                var result = await Api.CreateGuestsBulkAsync(EventId, guestsToCreate);
                if (result != null)
                {
                    guests.AddRange(result.Guests);
                    imported = result.CreatedCount;
                    await EnsurePlusOneRowsAsync();
                }
            }
            catch (Exception ex)
            {
                importResult = new ImportResult($"Could not import guests: {ex.Message}", true);
                importSummary = importResult.Message;
                importHasWarning = true;
                return;
            }
        }

        var msg = skipped > 0
            ? $"Imported {imported} guest(s). Skipped {skipped} duplicate(s)."
            : $"Successfully imported {imported} guest(s).";
        importResult    = new ImportResult(msg, skipped > 0);
        importSummary   = msg;
        importHasWarning = skipped > 0;
    }

    void ValidateGuestDraft(GuestCreateDto guest, Dictionary<string, string> errors)
    {
        var firstName = guest.FirstName.Trim();
        var lastName = guest.LastName.Trim();
        var email = guest.Email.Trim();
        var phone = guest.Phone?.Trim() ?? "";

        if (string.IsNullOrWhiteSpace(firstName))
            errors[nameof(guest.FirstName)] = "First name is required.";
        else if (!GuestNamePattern.IsMatch(firstName))
            errors[nameof(guest.FirstName)] = "Use only letters, spaces, accents, hyphens, or apostrophes.";

        if (string.IsNullOrWhiteSpace(lastName))
            errors[nameof(guest.LastName)] = "Last name is required.";
        else if (!GuestNamePattern.IsMatch(lastName))
            errors[nameof(guest.LastName)] = "Use only letters, spaces, accents, hyphens, or apostrophes.";

        if (string.IsNullOrWhiteSpace(email))
            errors[nameof(guest.Email)] = "Email is required.";
        else if (!emailValidator.IsValid(email))
            errors[nameof(guest.Email)] = "Enter a valid email address.";

        if (guest.Age is < 0)
            errors[nameof(guest.Age)] = "Age cannot be negative.";

        if (!string.IsNullOrWhiteSpace(email) &&
            guests.Any(g => g.Email.Trim().Equals(email, StringComparison.OrdinalIgnoreCase)))
            errors[nameof(guest.Email)] = "A guest with this email already exists.";

        if (!string.IsNullOrWhiteSpace(phone) &&
            guests.Any(g => string.Equals((g.Phone ?? "").Trim(), phone, StringComparison.OrdinalIgnoreCase)))
            errors[nameof(guest.Phone)] = "A guest with this phone already exists.";

        if (!string.IsNullOrWhiteSpace(firstName) &&
            !string.IsNullOrWhiteSpace(lastName) &&
            guests.Any(g => string.Equals($"{g.FirstName.Trim()} {g.LastName.Trim()}", $"{firstName} {lastName}", StringComparison.OrdinalIgnoreCase)))
            errors[nameof(guest.FirstName)] = "A guest with this full name already exists.";
    }

    async Task DownloadTemplate()
    {
        var csv = "FirstName,LastName,Email,Phone,Age,Gender,Dietary,Group,Status,PlusOne\n" +
                  "Maria,Ionescu,maria@@example.com,+40721000001,30,female,standard,family,confirmed,No\n" +
                  "Andrei,Pop,andrei@@example.com,,28,male,vegetarian,friends,pending,Yes\n";
        var b64 = Convert.ToBase64String(Encoding.UTF8.GetBytes(csv));
        await JS.InvokeVoidAsync("eval", $"var a=document.createElement('a');a.href='data:text/csv;base64,{b64}';a.download='guests_template.csv';a.click()");
    }

    static string DietaryExportLabel(DietaryRequirements dietary) => dietary switch
    {
        DietaryRequirements.Vegan => "vegan",
        DietaryRequirements.Vegetarian => "vegetarian",
        DietaryRequirements.Fasting => "fasting",
        _ => "standard"
    };

    void OpenCsvGuide()
    {
        csvGuideOpen = true;
        importResult = null;
    }

    static RsvpStatus ToRsvpStatus(string value) => value switch
    {
        "confirmed" => RsvpStatus.Confirmed,
        "declined" => RsvpStatus.Declined,
        _ => RsvpStatus.Pending,
    };

    async Task LoadAvailableMenuOptionsAsync(IReadOnlyCollection<int> menuIds)
    {
        if (menuIds.Count == 0)
        {
            availableMenuOptions = [new(DietaryRequirements.Standard, "Standard")];
            return;
        }

        var menus = await Api.GetMenusAsync();
        var selectedTypes = menus
            .Where(menu => menuIds.Contains(menu.MenuId))
            .Select(menu => menu.DietaryType)
            .Distinct()
            .OrderBy(type => type == MenuDietaryType.Standard ? 0 : 1)
            .ThenBy(type => type.ToString())
            .ToList();

        availableMenuOptions = selectedTypes.Count == 0
            ? [new(DietaryRequirements.Standard, "Standard")]
            : selectedTypes.Select(ToGuestMenuOption).ToList();
    }

    async Task NormalizeGuestMenuPreferencesAsync()
    {
        foreach (var guest in guests.ToList())
        {
            var normalized = NormalizeDietaryForSelectedMenus(guest.DietaryRequirements);
            if (normalized == guest.DietaryRequirements)
                continue;

            guest.DietaryRequirements = normalized;
            await Api.UpdateGuestAsync(EventId, guest.GuestId, ToUpdateDto(guest));
        }
    }

    DietaryRequirements DefaultAvailableDietary() =>
        availableMenuOptions.FirstOrDefault()?.Value ?? DietaryRequirements.Standard;

    DietaryRequirements NormalizeDietaryForSelectedMenus(DietaryRequirements dietary)
    {
        if (availableMenuOptions.Any(option => option.Value == dietary))
            return dietary;

        var standard = availableMenuOptions.FirstOrDefault(option => option.Value == DietaryRequirements.Standard);
        if (standard is not null)
            return standard.Value;

        return DefaultAvailableDietary();
    }

    static GuestMenuOption ToGuestMenuOption(MenuDietaryType type) => type switch
    {
        MenuDietaryType.Vegan => new(DietaryRequirements.Vegan, "Vegan"),
        MenuDietaryType.Vegetarian => new(DietaryRequirements.Vegetarian, "Vegetarian"),
        MenuDietaryType.Fasting => new(DietaryRequirements.Fasting, "Fasting"),
        _ => new(DietaryRequirements.Standard, "Standard")
    };
}
