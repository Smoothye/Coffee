@page "/guests"
@layout UserLayout
@using System.Text
@rendermode InteractiveServer
@using WeddingPlannerApp.Components.LayoutPaula
@inject IJSRuntime JS

<PageNav Title="Guest List"
         Subtitle="Manage &amp; track RSVPs"
         IconSvg="@SvgIcons.GuestListNav" />

<ModalShell IsOpen="csvGuideOpen"
            Title="Import Guests"
            ExtraClass="csv-guide-box"
            OnClose="@(() => { csvGuideOpen = false; dragActive = false; })">
    <div class="csv-two-col">
        <div class="csv-left">
            <p class="csv-section-title">Accepted formats</p>
            <div class="csv-formats">
                <span class="csv-format-tag">.csv</span>
                <span class="csv-format-note">Only .csv files are accepted. Excel files must be saved as CSV first.</span>
            </div>
            <p class="csv-section-title" style="margin-top:1rem;">Columns</p>
            <div class="csv-col-table">
                <div class="csv-col-head"><span>Column</span><span>Req.</span><span>Valid values</span></div>
                <div class="csv-col-row"><span class="csv-col-name">FirstName</span><span class="csv-req yes">Yes</span><span class="csv-col-vals">Any text</span></div>
                <div class="csv-col-row"><span class="csv-col-name">LastName</span><span class="csv-req yes">Yes</span><span class="csv-col-vals">Any text</span></div>
                <div class="csv-col-row"><span class="csv-col-name">Email</span><span class="csv-req no">No</span><span class="csv-col-vals">Duplicate check</span></div>
                <div class="csv-col-row"><span class="csv-col-name">Phone</span><span class="csv-req no">No</span><span class="csv-col-vals">Any format</span></div>
                <div class="csv-col-row"><span class="csv-col-name">Age</span><span class="csv-req no">No</span><span class="csv-col-vals">Number</span></div>
                <div class="csv-col-row"><span class="csv-col-name">Gender</span><span class="csv-req no">No</span><span class="csv-col-vals"><span class="csv-tag csv-other">male</span> <span class="csv-tag csv-other">female</span> <span class="csv-tag csv-other">other</span></span></div>
                <div class="csv-col-row"><span class="csv-col-name">Dietary</span><span class="csv-req no">No</span><span class="csv-col-vals"><span class="csv-tag csv-other">none</span> <span class="csv-tag csv-other">vegan</span> <span class="csv-tag csv-other">vegetarian</span> <span class="csv-tag csv-other">gluten-free</span></span></div>
                <div class="csv-col-row"><span class="csv-col-name">Group</span><span class="csv-req no">No</span><span class="csv-col-vals"><span class="csv-tag csv-family">family</span> <span class="csv-tag csv-friends">friends</span> <span class="csv-tag csv-colleagues">colleagues</span></span></div>
                <div class="csv-col-row"><span class="csv-col-name">Status</span><span class="csv-req no">No</span><span class="csv-col-vals"><span class="csv-tag csv-friends">confirmed</span> <span class="csv-tag csv-other">pending</span></span></div>
                <div class="csv-col-row"><span class="csv-col-name">PlusOne</span><span class="csv-req no">No</span><span class="csv-col-vals"><span class="csv-tag csv-friends">Yes</span> <span class="csv-tag csv-other">No</span></span></div>
            </div>
            <div class="csv-rules">
                <p class="csv-rules-title">@SvgIcons.AlertCircle Duplicate rules</p>
                <ul class="csv-rules-list">
                    <li>Same <strong>email</strong> or <strong>phone</strong> → skipped</li>
                    <li>Same <strong>full name</strong> → allowed (shown as duplicate)</li>
                </ul>
            </div>
            <button class="btn-outline" style="margin-top:.75rem;width:100%;justify-content:center;" @onclick="DownloadTemplate">
                @SvgIcons.Download Download blank template
            </button>
        </div>
        <div class="csv-right">
            <p class="csv-section-title">Upload file</p>
            <div class="csv-dropzone @(dragActive ? "csv-dropzone-active" : "")"
                 @ondragenter="@((e) => dragActive = true)"
                 @ondragleave="@((e) => dragActive = false)"
                 @ondragover:preventDefault="true"
                 @ondragover="@((e) => dragActive = true)">
                <div class="csv-drop-inner">
                    @if (importResult == null)
                    {
                        <div class="csv-drop-icon">@SvgIcons.UploadCloud</div>
                        <p class="csv-drop-title">Drag &amp; drop your .csv here</p>
                        <p class="csv-drop-sub">or</p>
                    }
                    else
                    {
                        <div class="csv-drop-icon @(importResult.HasWarning ? "icon-warn" : "icon-ok")">
                            @(importResult.HasWarning ? SvgIcons.AlertCircle : SvgIcons.CheckCircle)
                        </div>
                        <p class="csv-drop-title">@importResult.Message</p>
                        <p class="csv-drop-sub">Upload another file?</p>
                    }
                    <label class="btn-add" style="cursor:pointer;margin-top:.5rem;">
                        @SvgIcons.Upload Browse file
                        <InputFile OnChange="HandleImport" accept=".csv" style="display:none;" />
                    </label>
                    <p class="csv-accepted-note">Accepted: <strong>.csv</strong> only</p>
                </div>
            </div>
            @if (importResult != null)
            {
                <button class="btn-add-guest" style="margin-top:.75rem;"
                        @onclick="@(() => { csvGuideOpen = false; dragActive = false; importResult = null; })">
                    @SvgIcons.Check Done — View Guests
                </button>
            }
        </div>
    </div>
</ModalShell>

<ModalShell IsOpen="dialogOpen" Title="Add New Guest" OnClose="CloseDialog">
    @if (!string.IsNullOrEmpty(formError))
    {
        <div class="error-banner">@SvgIcons.AlertCircle @formError</div>
    }
    <div class="form-grid-2">
        <div class="field"><label>First Name *</label><input class="input" @bind="newGuest.FirstName" @bind:event="oninput" placeholder="First name" /></div>
        <div class="field"><label>Last Name *</label><input class="input" @bind="newGuest.LastName" @bind:event="oninput" placeholder="Last name" /></div>
    </div>
    <div class="form-grid-2">
        <div class="field"><label>Email</label><input class="input" @bind="newGuest.Email" @bind:event="oninput" placeholder="email@example.com" /></div>
        <div class="field"><label>Phone</label><input class="input" @bind="newGuest.Phone" @bind:event="oninput" placeholder="+1234567890" /></div>
    </div>
    <div class="form-grid-3">
        <div class="field"><label>Age</label><input class="input" type="number" min="0" @bind="newGuest.Age" @bind:event="oninput" /></div>
        <div class="field">
            <label>Gender</label>
            <select class="input select-input" @bind="newGuest.Gender">
                <option value="">—</option><option value="male">Male</option>
                <option value="female">Female</option><option value="other">Other</option>
            </select>
        </div>
        <div class="field">
            <label>Dietary</label>
            <select class="input select-input" @bind="newGuest.DietaryRequirements">
                @foreach (var d in DietaryOptions) { <option value="@d.Value">@d.Label</option> }
            </select>
        </div>
        <div class="field">
            <label>Menu</label>
            <select class="input select-input" @bind="newGuest.MenuType">
                @foreach (var m in MenuOptions) { <option value="@m.Value">@m.Label</option> }
            </select>
        </div>
    </div>
    <div class="field">
        <label>Group</label>
        <select class="input select-input" @bind="newGuest.Group">
            <option value="family">Family</option><option value="friends">Friends</option>
            <option value="colleagues">Colleagues</option><option value="other">Other</option>
        </select>
    </div>
    <div class="field">
        <label class="field-label">Plus One</label>
        <div class="plusone-toggle">
            <button type="button" class="toggle-opt @(!newGuest.PlusOne ? "toggle-active-no" : "toggle-inactive")" @onclick="@(() => newGuest.PlusOne = false)">@SvgIcons.XSmall No</button>
            <button type="button" class="toggle-opt @(newGuest.PlusOne ? "toggle-active-yes" : "toggle-inactive")" @onclick="@(() => newGuest.PlusOne = true)">@SvgIcons.Check Yes</button>
        </div>
    </div>
    <button class="btn-add-guest" @onclick="AddGuest">Add Guest</button>
</ModalShell>

@if (!string.IsNullOrEmpty(importSummary))
{
    <div class="import-toast @(importHasWarning ? "import-toast-warn" : "import-toast-ok")">
        @(importHasWarning ? SvgIcons.AlertCircle : SvgIcons.CheckCircle)
        @importSummary
        <button class="import-toast-close" @onclick="@(() => importSummary = "")">@SvgIcons.X</button>
    </div>
}

<div class="guests-wrap">

    <div class="stats-grid">
        <div class="stat-card"><span class="stat-icon">@SvgIcons.Users</span><div><p class="stat-value">@guests.Count</p><p class="stat-label">Total Guests</p></div></div>
        <div class="stat-card"><span class="stat-icon confirmed-icon">@SvgIcons.UserCheck</span><div><p class="stat-value">@guests.Count(g => g.Status == "confirmed")</p><p class="stat-label">Confirmed</p></div></div>
        <div class="stat-card"><span class="stat-icon pending-icon">@SvgIcons.Clock</span><div><p class="stat-value">@guests.Count(g => g.Status == "pending")</p><p class="stat-label">Pending</p></div></div>
        <div class="stat-card"><span class="stat-icon declined-icon">@SvgIcons.UserX</span><div><p class="stat-value">@guests.Count(g => g.Status == "declined")</p><p class="stat-label">Declined</p></div></div>
    </div>

    <div class="toolbar guests-filter-toolbar">
        <div class="search-wrap">
            <span class="search-icon">@SvgIcons.Search</span>
            <input class="input search-input" placeholder="Search guests..." @bind="search" @bind:event="oninput" />
        </div>
        <select class="input select-input filter-select" @bind="filterGroup">
            <option value="all">All Groups</option>
            <option value="family">Family</option><option value="friends">Friends</option>
            <option value="colleagues">Colleagues</option><option value="other">Other</option>
        </select>
    </div>

    <div class="guest-command-bar">
        <button class="btn-outline" @onclick="@(() => { csvGuideOpen = true; importResult = null; })">@SvgIcons.FileText CSV Guide</button>
        <label class="btn-outline" style="cursor:pointer;" title="Import CSV">
            @SvgIcons.Upload Import
            <InputFile OnChange="HandleImport" accept=".csv" style="display:none;" />
        </label>
        <button class="btn-outline" @onclick="ExportCSV">@SvgIcons.Download Export</button>
        <button class="btn-add" @onclick="OpenDialog">@SvgIcons.Plus Add Guest</button>
    </div>

    <div class="guest-list">
        @if (!FilteredGuests.Any())
        {
            <div class="empty-state">
                <span class="empty-state-icon">@SvgIcons.UsersLarge</span>
                <p>No guests found.</p>
            </div>
        }
        else
        {
            @foreach (var guest in FilteredGuests)
            {
                var g = guest;
                <div class="guest-row">
                    <div class="guest-avatar">@g.FirstName[0]@g.LastName[0]</div>
                    <div class="guest-info">
                        <p class="guest-name">@g.FirstName @g.LastName</p>
                        <div class="guest-meta">
                            <span>@g.Email</span>
                            @if (g.IsPlusOne) { <span class="badge plus-one-guest-badge">Plus one</span> }
                            @if (g.DietaryRequirements != "none") { <span class="badge badge-dietary">@g.DietaryRequirements</span> }
                        </div>
                    </div>
                    <div class="guest-actions">
                        <span class="badge @GroupBadgeClass(g.Group)">@g.Group</span>
                        <select class="input select-input guest-menu-select" @bind="g.MenuType">
                            @foreach (var m in MenuOptions) { <option value="@m.Value">@m.Label</option> }
                        </select>
                        @if (!g.IsPlusOne)
                        {
                            <button type="button"
                                    class="plus-one-toggle-row @(g.PlusOne ? "plus-one-active" : "")"
                                    @onclick="@(() => TogglePlusOne(g.Id))">
                                @(g.PlusOne ? "Remove +1" : "Add +1")
                            </button>
                        }
                        <div class="rsvp-btns">
                            <button class="rsvp-btn rsvp-confirmed @(g.Status == "confirmed" ? "rsvp-active" : "rsvp-inactive")" @onclick="@(() => SetStatus(g.Id, "confirmed"))">@SvgIcons.Check</button>
                            <button class="rsvp-btn rsvp-pending @(g.Status == "pending" ? "rsvp-active" : "rsvp-inactive")" @onclick="@(() => SetStatus(g.Id, "pending"))">@SvgIcons.ClockSmall</button>
                            <button class="rsvp-btn rsvp-declined @(g.Status == "declined" ? "rsvp-active" : "rsvp-inactive")" @onclick="@(() => SetStatus(g.Id, "declined"))">@SvgIcons.XSmall</button>
                        </div>
                        <button class="delete-btn" @onclick="@(() => RemoveGuest(g.Id))">@SvgIcons.Trash</button>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {

    bool   dialogOpen      = false;
    string formError       = "";
    string search          = "";
    string filterGroup     = "all";
    string importSummary   = "";
    bool   importHasWarning = false;
    bool   csvGuideOpen    = false;
    bool   dragActive      = false;
    ImportResult? importResult = null;

    record ImportResult(string Message, bool HasWarning);

    record DietaryOption(string Value, string Label);
    static readonly DietaryOption[] DietaryOptions =
    {
        new("none","None"), new("vegan","Vegan"), new("vegetarian","Vegetarian"),
        new("gluten-free","Gluten-Free"), new("halal","Halal"), new("kosher","Kosher"), new("other","Other"),
    };

    record MenuOption(string Value, string Label);
    static readonly MenuOption[] MenuOptions =
    {
        new("casual","Casual"), new("vegetarian","Vegetarian"),
        new("vegan","Vegan"), new("fasting","Fasting"), new("kids","Kids"),
    };

    class Guest
    {
        public int     Id { get; set; }
        public string  FirstName { get; set; } = "";
        public string  LastName  { get; set; } = "";
        public string  Email     { get; set; } = "";
        public string  Phone     { get; set; } = "";
        public int?    Age       { get; set; }
        public string  Gender    { get; set; } = "";
        public string  DietaryRequirements { get; set; } = "none";
        public string  MenuType  { get; set; } = "casual";
        public string  Group     { get; set; } = "friends";
        public string  Status    { get; set; } = "pending";
        public bool    PlusOne   { get; set; }
        public bool    IsPlusOne { get; set; }
        public int?    PlusOneForId { get; set; }
    }

    List<Guest> guests = new()
    {
        new Guest { Id=1, FirstName="Emma",   LastName="Johnson",  Email="emma@email.com",   Phone="+1234567890", Age=28, Gender="female", DietaryRequirements="none",        MenuType="casual",     Group="family",     Status="confirmed" },
        new Guest { Id=2, FirstName="Liam",   LastName="Smith",    Email="liam@email.com",   Phone="+1234567891", Age=30, Gender="male",   DietaryRequirements="vegetarian",  MenuType="vegetarian", Group="friends",    Status="pending"   },
        new Guest { Id=3, FirstName="Sophia", LastName="Williams", Email="sophia@email.com", Phone="+1234567892", Age=26, Gender="female", DietaryRequirements="gluten-free", MenuType="casual",     Group="colleagues", Status="confirmed" },
        new Guest { Id=4, FirstName="Oliver", LastName="Brown",    Email="oliver@email.com", Phone="+1234567893", Age=35, Gender="male",   DietaryRequirements="none",        MenuType="casual",     Group="family",     Status="declined"  },
        new Guest { Id=5, FirstName="Mia",    LastName="Davis",    Email="mia@email.com",    Phone="+1234567894", Age=24, Gender="female", DietaryRequirements="vegan",       MenuType="vegan",      Group="friends",    Status="pending"   },
    };

    Guest newGuest = new();

    IEnumerable<Guest> FilteredGuests => guests.Where(g =>
    {
        var name = $"{g.FirstName} {g.LastName}".ToLower();
        var matchSearch = string.IsNullOrEmpty(search) || name.Contains(search.ToLower()) || g.Email.Contains(search, StringComparison.OrdinalIgnoreCase);
        var matchGroup  = filterGroup == "all" || g.Group == filterGroup;
        return matchSearch && matchGroup;
    });

    void OpenDialog()  { newGuest = new Guest { Group = "friends", DietaryRequirements = "none", MenuType = "casual" }; formError = ""; dialogOpen = true; }
    void CloseDialog() { dialogOpen = false; formError = ""; }

    bool IsDuplicate(string fn, string ln, string email, string phone) =>
        guests.Any(g =>
            $"{g.FirstName.ToLower()} {g.LastName.ToLower()}" == $"{fn.Trim().ToLower()} {ln.Trim().ToLower()}"
            || (!string.IsNullOrWhiteSpace(email) && g.Email.Trim().ToLower() == email.Trim().ToLower())
            || (!string.IsNullOrWhiteSpace(phone) && g.Phone.Trim() == phone.Trim()));

    void AddGuest()
    {
        if (string.IsNullOrWhiteSpace(newGuest.FirstName) || string.IsNullOrWhiteSpace(newGuest.LastName))
        { formError = "Please enter first and last name."; return; }
        if (IsDuplicate(newGuest.FirstName, newGuest.LastName, newGuest.Email, newGuest.Phone))
        { formError = "A guest with the same name, email or phone already exists."; return; }
        newGuest.Id = (int)(DateTime.UtcNow.Ticks % int.MaxValue);
        newGuest.Status = "pending";
        guests.Add(newGuest);
        if (newGuest.PlusOne) AddPlusOneGuest(newGuest);
        CloseDialog();
    }

    void SetStatus(int id, string status) { var g = guests.FirstOrDefault(x => x.Id == id); if (g != null) g.Status = status; }

    void TogglePlusOne(int id)
    {
        var g = guests.FirstOrDefault(x => x.Id == id);
        if (g is null) return;
        if (g.PlusOne) { guests.RemoveAll(x => x.PlusOneForId == id); g.PlusOne = false; }
        else           { g.PlusOne = true; AddPlusOneGuest(g); }
    }

    void AddPlusOneGuest(Guest guest)
    {
        if (guests.Any(g => g.PlusOneForId == guest.Id)) return;
        guests.Add(new Guest
        {
            Id = (int)(DateTime.UtcNow.Ticks % int.MaxValue) + guests.Count + 1,
            FirstName = $"{guest.FirstName}'s", LastName = "+1",
            Group = guest.Group, Status = guest.Status,
            DietaryRequirements = "none", MenuType = guest.MenuType,
            IsPlusOne = true, PlusOneForId = guest.Id,
        });
    }

    void RemoveGuest(int id)
    {
        var g = guests.FirstOrDefault(x => x.Id == id);
        if (g?.PlusOneForId is int ownerId)
        {
            var owner = guests.FirstOrDefault(x => x.Id == ownerId);
            if (owner != null) owner.PlusOne = false;
        }
        guests.RemoveAll(g => g.Id == id || g.PlusOneForId == id);
    }

    async Task ExportCSV()
    {
        var sb = new StringBuilder();
        sb.AppendLine("FirstName,LastName,Email,Phone,Age,Gender,Dietary,Menu,Group,Status,PlusOne");
        foreach (var g in guests)
            sb.AppendLine($"{g.FirstName},{g.LastName},{g.Email},{g.Phone},{g.Age},{g.Gender},{g.DietaryRequirements},{g.MenuType},{g.Group},{g.Status},{(g.PlusOne ? "Yes" : "No")}");
        var base64 = Convert.ToBase64String(Encoding.UTF8.GetBytes(sb.ToString()));
        await JS.InvokeVoidAsync("eval", $"var a=document.createElement('a');a.href='data:text/csv;base64,{base64}';a.download='guest_list.csv';a.click()");
    }

    async Task HandleImport(InputFileChangeEventArgs e)
    {
        dragActive = false;
        var file = e.File;
        if (!file.Name.EndsWith(".csv", StringComparison.OrdinalIgnoreCase))
        { importResult = new ImportResult("Only .csv files are accepted.", true); return; }
        using var reader = new System.IO.StreamReader(file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024));
        var text = await reader.ReadToEndAsync();
        int imported = 0, skipped = 0, counter = 0;
        var validGroups   = new[] { "family", "friends", "colleagues", "other" };
        var validDietary  = new[] { "none", "vegan", "vegetarian", "gluten-free", "halal", "kosher", "other" };
        var validMenus    = MenuOptions.Select(m => m.Value).ToArray();
        var validStatuses = new[] { "confirmed", "pending", "declined" };
        foreach (var line in text.Split('\n').Skip(1).Where(l => !string.IsNullOrWhiteSpace(l)))
        {
            var c         = line.TrimEnd('\r').Split(',');
            var firstName = c.ElementAtOrDefault(0)?.Trim() ?? "";
            var lastName  = c.ElementAtOrDefault(1)?.Trim() ?? "";
            var email     = c.ElementAtOrDefault(2)?.Trim() ?? "";
            var phone     = c.ElementAtOrDefault(3)?.Trim() ?? "";
            var ageStr    = c.ElementAtOrDefault(4)?.Trim() ?? "";
            var gender    = c.ElementAtOrDefault(5)?.Trim().ToLower() ?? "";
            var dietary   = c.ElementAtOrDefault(6)?.Trim().ToLower() ?? "";
            var menu      = c.ElementAtOrDefault(7)?.Trim().ToLower() ?? "";
            var group     = c.ElementAtOrDefault(8)?.Trim().ToLower() ?? "";
            var status    = c.ElementAtOrDefault(9)?.Trim().ToLower() ?? "";
            var plusOne   = c.ElementAtOrDefault(10)?.Trim().ToLower() ?? "";
            if (string.IsNullOrWhiteSpace(firstName) && string.IsNullOrWhiteSpace(lastName)) { skipped++; continue; }
            if (IsDuplicate(firstName, lastName, email, phone)) { skipped++; continue; }
            var imported_guest = new Guest
            {
                Id = (int)(DateTime.UtcNow.Ticks % int.MaxValue) + counter++,
                FirstName = firstName, LastName = lastName, Email = email, Phone = phone,
                Age = int.TryParse(ageStr, out var age) ? age : null,
                Gender = new[] { "male", "female", "other" }.Contains(gender) ? gender : "",
                DietaryRequirements = validDietary.Contains(dietary) ? dietary : "none",
                MenuType  = validMenus.Contains(menu) ? menu : "casual",
                Group     = validGroups.Contains(group) ? group : "other",
                Status    = validStatuses.Contains(status) ? status : "pending",
                PlusOne   = plusOne is "yes" or "true" or "1",
            };
            guests.Add(imported_guest);
            if (imported_guest.PlusOne) AddPlusOneGuest(imported_guest);
            imported++;
        }
        var msg = skipped > 0
            ? $"Imported {imported} guest(s). Skipped {skipped} duplicate(s)."
            : $"Successfully imported {imported} guest(s).";
        importResult    = new ImportResult(msg, skipped > 0);
        importSummary   = msg;
        importHasWarning = skipped > 0;
    }

    async Task DownloadTemplate()
    {
        var csv = "FirstName,LastName,Email,Phone,Age,Gender,Dietary,Menu,Group,Status,PlusOne\n" +
                  "Maria,Ionescu,maria@@example.com,+40721000001,30,female,none,casual,family,confirmed,No\n" +
                  "Andrei,Pop,andrei@@example.com,,28,male,vegetarian,vegetarian,friends,pending,Yes\n";
        var b64 = Convert.ToBase64String(Encoding.UTF8.GetBytes(csv));
        await JS.InvokeVoidAsync("eval", $"var a=document.createElement('a');a.href='data:text/csv;base64,{b64}';a.download='guests_template.csv';a.click()");
    }

    static string GroupBadgeClass(string group) => group switch
    {
        "family"     => "badge-family",
        "friends"    => "badge-friends",
        "colleagues" => "badge-colleagues",
        _            => "badge-other",
    };
}
