<div class="panel">
    <div class="panel-head">
        <div class="panel-head-left">
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--sage-dark)">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
            </svg>
            <h2>Events</h2>
        </div>
    </div>

    <div class="event-list">
        @if (!Events.Any())
        {
            <div class="admin-empty">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                    <line x1="16" y1="2" x2="16" y2="6" />
                    <line x1="8" y1="2" x2="8" y2="6" />
                    <line x1="3" y1="10" x2="21" y2="10" />
                </svg>
                <p>No events submitted yet.</p>
            </div>
        }

        @foreach (var evt in Events)
        {
            var e = evt;
            <div class="event-card">
                <div class="event-card-main">
                    <div class="event-type-icon tile-sage">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                            <line x1="16" y1="2" x2="16" y2="6" />
                            <line x1="8" y1="2" x2="8" y2="6" />
                            <line x1="3" y1="10" x2="21" y2="10" />
                        </svg>
                    </div>
                    <div class="event-info">
                        <p class="event-name">@e.Name</p>
                        <div class="event-meta-row">
                            <span class="event-meta-item">@e.EventDate.ToString("MMM d, yyyy")</span>
                            <span class="event-meta-item">@e.VenueName</span>
                            <span class="event-meta-item">@e.GuestCount guests</span>
                            @if (!string.IsNullOrWhiteSpace(e.OwnerEmail))
                            {
                                <span class="event-meta-item" style="color:var(--sage-dark);font-weight:500;">@e.OwnerEmail</span>
                            }
                        </div>
                    </div>
                    <div class="event-actions">
                        <button class="icon-btn expand" title="@(ExpandedEventId == e.Id ? "Collapse" : "Details")" @onclick="@(() => OnToggleExpand.InvokeAsync(e.Id))">
                            @if (ExpandedEventId == e.Id)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15" /></svg>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg>
                            }
                        </button>
                        <button class="icon-btn delete" title="Delete" @onclick="@(() => OnDelete.InvokeAsync(e.Id))">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="3 6 5 6 21 6" />
                                <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                                <path d="M10 11v6" />
                                <path d="M14 11v6" />
                                <path d="M9 6V4h6v2" />
                            </svg>
                        </button>
                    </div>
                </div>

                @if (ExpandedEventId == e.Id)
                {
                    <div class="event-detail">
                        <div class="detail-item"><span class="detail-label">Event Type</span><span class="detail-value">@e.Type</span></div>
                        <div class="detail-item"><span class="detail-label">Menu</span><span class="detail-value">@(string.IsNullOrWhiteSpace(e.MenuName) ? "Not selected" : e.MenuName)</span></div>
                        <div class="detail-item"><span class="detail-label">Owner Name</span><span class="detail-value">@(string.IsNullOrWhiteSpace(e.OwnerName) ? "-" : e.OwnerName)</span></div>
                        <div class="detail-item"><span class="detail-label">Owner Email</span><span class="detail-value">@(string.IsNullOrWhiteSpace(e.OwnerEmail) ? "-" : e.OwnerEmail)</span></div>
                        <div class="detail-item"><span class="detail-label">Total Budget</span><span class="detail-value">@(e.TotalBudget > 0 ? $"${e.TotalBudget:N0}" : "Not set")</span></div>
                        <div class="detail-item"><span class="detail-label">Created</span><span class="detail-value">@e.CreatedAt.ToString("MMM d, yyyy")</span></div>
                        @if (!string.IsNullOrWhiteSpace(e.Notes))
                        {
                            <div class="detail-item" style="grid-column:1/-1;">
                                <span class="detail-label">Notes</span>
                                <span class="detail-value notes-text">@e.Notes</span>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public IReadOnlyList<AdminEventModel> Events { get; set; } = [];
    [Parameter] public int? ExpandedEventId { get; set; }
    [Parameter] public EventCallback<int> OnToggleExpand { get; set; }
    [Parameter] public EventCallback<int> OnDelete { get; set; }
}
