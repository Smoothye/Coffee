<div class="panel">
    <div class="panel-head">
        <div class="panel-head-left">
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--sage-dark)">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                <circle cx="12" cy="10" r="3" />
            </svg>
            <h2>Venues</h2>
        </div>
        <button class="btn-add" @onclick="@(() => OnAddVenue.InvokeAsync())">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:.3rem">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            Add Venue
        </button>
    </div>

    <div class="venue-list">
        @foreach (var item in Venues)
        {
            var venue = item;
            <div class="venue-tile">
                @if (!string.IsNullOrEmpty(venue.ImagePath))
                {
                    <img src="@venue.ImagePath" alt="@venue.Name" class="venue-tile-img" />
                }
                else
                {
                    <div class="venue-tile-img venue-tile-img-placeholder">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="18" height="18" rx="2" />
                            <circle cx="8.5" cy="8.5" r="1.5" />
                            <polyline points="21 15 16 10 5 21" />
                        </svg>
                    </div>
                }
                <div class="venue-tile-info">
                    <h4>@venue.Name</h4>
                    <p>@venue.Type - @venue.Address</p>
                    @if (venue.Latitude.HasValue && venue.Longitude.HasValue)
                    {
                        <p style="color:var(--muted);font-size:.76rem;margin-top:.15rem;">@venue.Latitude.Value.ToString("0.#####"), @venue.Longitude.Value.ToString("0.#####")</p>
                    }
                    @if (venue.EstimatedPrice > 0)
                    {
                        <p style="color:var(--sage-dark);font-weight:600;margin-top:.2rem;">est. $@venue.EstimatedPrice.ToString("N0")</p>
                    }
                    @if (venue.Rating.HasValue)
                    {
                        <div class="admin-score-pill" title="Admin venue score">
                            <span>Admin score</span>
                            <strong>@venue.Rating/5</strong>
                        </div>
                    }
                    @if (venue.Tags.Count > 0)
                    {
                        <div class="admin-venue-tags">
                            @foreach (var tag in venue.Tags.Take(4))
                            {
                                <span>@tag</span>
                            }
                            @if (venue.Tags.Count > 4)
                            {
                                <span>+@(venue.Tags.Count - 4)</span>
                            }
                        </div>
                    }
                </div>
                <div style="display:flex;flex-direction:column;align-items:flex-end;gap:.4rem;flex-shrink:0;padding:.5rem .75rem .5rem 0;">
                    <span class="venue-tile-cap">@venue.MinCapacity-@venue.MaxCapacity guests</span>
                    <button class="icon-btn expand" title="Edit venue" @onclick="@(() => OnEditVenue.InvokeAsync(venue.Id))">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 20h9" />
                            <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z" />
                        </svg>
                    </button>
                    <button class="icon-btn delete" title="Remove venue" @onclick="@(() => OnDeleteVenue.InvokeAsync(venue.Id))">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="3 6 5 6 21 6" />
                            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                            <path d="M10 11v6" />
                            <path d="M14 11v6" />
                            <path d="M9 6V4h6v2" />
                        </svg>
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public IReadOnlyList<AdminVenueModel> Venues { get; set; } = [];
    [Parameter] public EventCallback OnAddVenue { get; set; }
    [Parameter] public EventCallback<int> OnEditVenue { get; set; }
    [Parameter] public EventCallback<int> OnDeleteVenue { get; set; }
}
