<div class="stats-row">
    <div class="stat-tile">
        <div class="stat-tile-icon tile-sage">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
            </svg>
        </div>
        <div>
            <p class="stat-tile-val">@TotalEvents</p>
            <p class="stat-tile-label">Total Events</p>
        </div>
    </div>
    <div class="stat-tile">
        <div class="stat-tile-icon tile-green">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
            </svg>
        </div>
        <div>
            <p class="stat-tile-val">@UpcomingEvents</p>
            <p class="stat-tile-label">Upcoming</p>
        </div>
    </div>
    <div class="stat-tile">
        <div class="stat-tile-icon tile-blue">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
            </svg>
        </div>
        <div>
            <p class="stat-tile-val">@TotalGuests</p>
            <p class="stat-tile-label">Guest records</p>
        </div>
    </div>
    <div class="stat-tile">
        <div class="stat-tile-icon tile-amber">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                <circle cx="12" cy="10" r="3" />
            </svg>
        </div>
        <div>
            <p class="stat-tile-val">@TotalVenues</p>
            <p class="stat-tile-label">Venues</p>
        </div>
    </div>
    <div class="stat-tile">
        <div class="stat-tile-icon tile-sage">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2" />
                <path d="M7 2v20" />
                <path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7" />
            </svg>
        </div>
        <div>
            <p class="stat-tile-val">@TotalMenus</p>
            <p class="stat-tile-label">Menus</p>
        </div>
    </div>
</div>

@code {
    [Parameter] public int TotalEvents { get; set; }
    [Parameter] public int UpcomingEvents { get; set; }
    [Parameter] public int TotalGuests { get; set; }
    [Parameter] public int TotalVenues { get; set; }
    [Parameter] public int TotalMenus { get; set; }
}
