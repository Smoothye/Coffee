@rendermode InteractiveServer
@implements IDisposable
@page "/suppliers"
@page "/suppliers/{EventId:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@layout PaulaLayout
@using System.Text
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Authorization
@using WeddingPlannerApp.Components.LayoutPaula
@using WeddingPlannerApp.Components.PagesPaula.SupplierComponents
@using WeddingPlannerApp.DTOs.Supplier
@inject IJSRuntime JS
@inject WeddingPlannerApp.Services.WeddingApiClient Api
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<PageNav Title="Suppliers"
         Subtitle="@($"{eventSuppliers.Count(s => s.CollaborationStatus == "confirmed")} confirmed - {eventSuppliers.Count(s => s.CollaborationStatus == "pending")} pending")"
         IconSvg="@SvgIcons.SuppliersNav" />

@if (!string.IsNullOrWhiteSpace(loadError))
{
    <div class="error-banner">@SvgIcons.AlertCircle @loadError</div>
}

<CsvGuideModal IsOpen="csvGuideOpen"
               Title="Import Suppliers"
               IntroNote="Use a .csv file with Name, Category, Phone, Email, Description, BasePrice, Advance, RemainingPaid, Status and Notes columns."
               Columns="supplierCsvColumns"
               OnClose="@(() => csvGuideOpen = false)">
    <LeftFooter>
        <button class="btn-outline" style="margin-top:.75rem;width:100%;justify-content:center;" @onclick="DownloadTemplate">
            @SvgIcons.Download Download blank template
        </button>
    </LeftFooter>
    <UploadContent>
        <p class="csv-section-title">Upload file</p>
        <label class="csv-dropzone" style="cursor:pointer;">
            <div class="csv-drop-inner">
                <div class="csv-drop-icon">@SvgIcons.UploadCloud</div>
                <p class="csv-drop-title">Browse a .csv file</p>
                <p class="csv-drop-sub">Suppliers will be added to this list</p>
                <InputFile OnChange="ImportCSV" accept=".csv" style="display:none;" />
            </div>
        </label>
        @if (!string.IsNullOrEmpty(importSummary))
        {
            <div class="import-toast @(importHasWarning ? "import-toast-warn" : "import-toast-ok")" style="position:static;margin-top:.75rem;">
                @importSummary
            </div>
        }
    </UploadContent>
</CsvGuideModal>

<ModalShell IsOpen="addSupplierOpen" Title="Add Supplier" OnClose="CloseAddSupplier">
    @if (!string.IsNullOrEmpty(formError))
    {
        <div class="error-banner">@formError</div>
    }
    <div class="form-grid-2">
        <div class="field">
            <label>Name *</label>
            <input class="input @(HasFormError(nameof(draftSupplier.Name)) ? "field-invalid" : "")" @bind="draftSupplier.Name" @bind:event="oninput" placeholder="Supplier name" />
            @FormFieldError(nameof(draftSupplier.Name))
        </div>
        <div class="field">
            <label>Category *</label>
            <select class="input select-input @(HasFormError(nameof(draftSupplier.Category)) ? "field-invalid" : "")" @bind="draftSupplier.Category">
                @foreach (var c in categories)
                {
                    <option value="@c">@c</option>
                }
            </select>
            @FormFieldError(nameof(draftSupplier.Category))
        </div>
    </div>
    <div class="form-grid-2">
        <div class="field">
            <label>Phone</label>
            <input class="input" @bind="draftSupplier.Phone" @bind:event="oninput" placeholder="+40..." />
        </div>
        <div class="field">
            <label>Email</label>
            <input class="input @(HasFormError(nameof(draftSupplier.Email)) ? "field-invalid" : "")" type="email" @bind="draftSupplier.Email" @bind:event="oninput" placeholder="supplier@example.com" />
            @FormFieldError(nameof(draftSupplier.Email))
        </div>
    </div>
    <div class="field">
        <label>Description</label>
        <input class="input" @bind="draftSupplier.Description" @bind:event="oninput" placeholder="Short notes" />
    </div>
    <div class="form-grid-2">
        <div class="field">
            <label>Base price</label>
            <input class="input @(HasFormError(nameof(draftSupplier.Price)) ? "field-invalid" : "")" type="number" min="0" step="50" @bind="draftSupplier.Price" @bind:event="oninput" />
            @FormFieldError(nameof(draftSupplier.Price))
        </div>
        <div class="field">
            <label>Advance</label>
            <input class="input @(HasFormError(nameof(draftSupplier.Advance)) ? "field-invalid" : "")" type="number" min="0" step="50" @bind="draftSupplier.Advance" @bind:event="oninput" />
            @FormFieldError(nameof(draftSupplier.Advance))
        </div>
    </div>
    <button class="btn-add-guest" disabled="@savingSupplier" @onclick="AddSupplier">@SvgIcons.Plus @(savingSupplier ? "Adding..." : "Add Supplier")</button>
</ModalShell>

<ConfirmDialog IsOpen="confirmRemoveOpen"
               Title="Remove supplier?"
               Message="This supplier will leave your contacted list and will be removed from budget tracking."
               ConfirmText="Remove supplier"
               OnCancel="@(() => confirmRemoveOpen = false)"
               OnConfirm="ConfirmRemoveStatus" />

<div class="suppliers-page">
    <SupplierStats Available="@allSuppliers.Count"
                   Confirmed="@eventSuppliers.Count(s => s.CollaborationStatus == "confirmed")"
                   Pending="@eventSuppliers.Count(s => s.CollaborationStatus == "pending")"
                   NotSelected="@allSuppliers.Count(s => !eventSuppliers.Any(es => es.SupplierId == s.Id))"
                   PaidTotal="@PaidTotal"
                   UnpaidTotal="@UnpaidTotal" />

    <SupplierToolbar Search="@search"
                     SearchChanged="@((value) => search = value)"
                     Category="@filterCat"
                     CategoryChanged="@((value) => filterCat = value)"
                     Status="@filterStatus"
                     StatusChanged="@((value) => filterStatus = value)"
                     Categories="categories"
                     OnCsvGuide="@(() => csvGuideOpen = true)"
                     OnImport="ImportCSV"
                     OnExport="ExportCSV"
                     OnAddSupplier="OpenAddSupplier" />

    <div class="supplier-grid">
        @foreach (var supplier in filteredSuppliers)
        {
            var sid = supplier.Id;
            <SupplierCard Supplier="supplier"
                          Status="@GetStatus(sid)"
                          EventSupplier="GetEventSupplier(sid)"
                          OnSetStatus="SetStatus"
                          OnRemainingPaidChanged="SetRemainingPaid"
                          OnRemoveStatus="RemoveStatus"
                          OnSyncBudget="SyncSupplier" />
        }
        @if (!filteredSuppliers.Any())
        {
            <div class="suppliers-empty">
                <span class="suppliers-empty-icon">@((MarkupString)SvgIcons.SuppliersNav)</span>
                <p>No suppliers yet.</p>
                <span>Add suppliers manually or import a CSV when you are ready.</span>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public int EventId { get; set; }

    static readonly string[] categories = { "Cake", "Candy Bar", "Flowers", "Photography", "Music/DJ", "Catering", "Decorations", "Rentals", "Other" };

    static readonly CsvGuideColumn[] supplierCsvColumns =
    {
        new() { Name = "Name", Required = true, ValidValues = "Any text" },
        new() { Name = "Category", Required = true, ValidValues = "Cake, Candy Bar, Flowers, Photography, Music/DJ, Catering, Decorations, Rentals, Other" },
        new() { Name = "Phone", ValidValues = "Any format" },
        new() { Name = "Email", ValidValues = "Used for duplicate check" },
        new() { Name = "Description", ValidValues = "Short notes" },
        new() { Name = "BasePrice", ValidValues = "Number, cannot be negative" },
        new() { Name = "Advance", ValidValues = "Number, cannot be negative and cannot exceed BasePrice" },
        new() { Name = "RemainingPaid", ValidValues = "Yes/No, true/false, paid/unpaid" },
        new() { Name = "Status", ValidValues = "pending, confirmed or empty" },
        new() { Name = "Notes", ValidValues = "Optional event-specific notes" },
    };

    readonly List<SupplierModel> allSuppliers = [];
    readonly List<EventSupplierModel> eventSuppliers = [];
    readonly EmailAddressAttribute emailValidator = new();

    IEnumerable<SupplierModel> ActiveSuppliers => allSuppliers.Where(s => GetStatus(s.Id) != null);
    decimal PaidTotal => ActiveSuppliers.Sum(PaidAmount);
    decimal UnpaidTotal => ActiveSuppliers.Sum(UnpaidAmount);

    bool csvGuideOpen = false;
    bool addSupplierOpen = false;
    bool confirmRemoveOpen = false;
    bool savingSupplier = false;
    int pendingRemoveSupplierId;
    string formError = "";
    string loadError = "";
    string importSummary = "";
    bool importHasWarning = false;
    SupplierModel draftSupplier = new() { Category = "Other" };
    Dictionary<string, string> formFieldErrors = new();

    string _search = "";
    string search { get => _search; set { _search = value; ApplyFilters(); } }

    string _filterCat = "";
    string filterCat { get => _filterCat; set { _filterCat = value; ApplyFilters(); } }

    string _filterStatus = "all";
    string filterStatus { get => _filterStatus; set { _filterStatus = value; ApplyFilters(); } }

    List<SupplierModel> filteredSuppliers = [];

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            if (authState.User.IsInRole("Admin"))
            {
                Nav.NavigateTo("/admin", replace: true);
                return;
            }

            var ownEvent = (await Api.GetEventsAsync()).OrderByDescending(e => e.EventId).FirstOrDefault();
            if (ownEvent is null)
            {
                Nav.NavigateTo("/onboarding", replace: true);
                return;
            }

            if (EventId <= 0 || EventId != ownEvent.EventId)
                EventId = ownEvent.EventId;

            await LoadSuppliers();
        }
        catch (Exception ex)
        {
            loadError = $"Could not load suppliers: {ex.Message}";
        }
    }

    async Task LoadSuppliers()
    {
        allSuppliers.Clear();
        eventSuppliers.Clear();

        var suppliers = await Api.GetSuppliersAsync(EventId);
        allSuppliers.AddRange(suppliers.Select(ToModel));
        eventSuppliers.AddRange(suppliers
            .Where(s => s.CollaborationStatus is not null)
            .Select(s => new EventSupplierModel
            {
                SupplierId = s.SupplierId,
                CollaborationStatus = s.CollaborationStatus,
                RemainingPaid = s.RemainingPaid,
                Notes = s.EventNotes
            }));

        ApplyFilters();
    }

    void ApplyFilters()
    {
        var q = allSuppliers.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(_search))
            q = q.Where(s => s.Name.Contains(_search, StringComparison.OrdinalIgnoreCase) || s.Category.Contains(_search, StringComparison.OrdinalIgnoreCase));
        if (!string.IsNullOrEmpty(_filterCat))
            q = q.Where(s => s.Category == _filterCat);
        if (_filterStatus != "all")
        {
            q = _filterStatus switch
            {
                "confirmed" => q.Where(s => eventSuppliers.Any(e => e.SupplierId == s.Id && e.CollaborationStatus == "confirmed")),
                "pending" => q.Where(s => eventSuppliers.Any(e => e.SupplierId == s.Id && e.CollaborationStatus == "pending")),
                "none" => q.Where(s => !eventSuppliers.Any(e => e.SupplierId == s.Id)),
                _ => q
            };
        }
        filteredSuppliers = q.OrderBy(s => s.Name).ToList();
    }

    void OpenAddSupplier()
    {
        draftSupplier = new SupplierModel { Category = "Other" };
        formError = "";
        formFieldErrors.Clear();
        addSupplierOpen = true;
    }

    void CloseAddSupplier()
    {
        addSupplierOpen = false;
        formError = "";
        formFieldErrors.Clear();
    }

    async Task AddSupplier()
    {
        formError = "";
        formFieldErrors.Clear();
        ValidateSupplierDraft(draftSupplier, formFieldErrors);

        if (formFieldErrors.Count > 0)
        {
            formError = "Please fix the highlighted fields.";
            return;
        }

        savingSupplier = true;
        try
        {
            var created = await Api.CreateSupplierAsync(EventId, new SupplierCreateDto
            {
                Name = draftSupplier.Name.Trim(),
                Category = draftSupplier.Category.Trim(),
                Phone = NullIfBlank(draftSupplier.Phone),
                Email = NullIfBlank(draftSupplier.Email),
                Description = NullIfBlank(draftSupplier.Description),
                Price = draftSupplier.Price,
                Advance = draftSupplier.Advance
            });

            if (created is not null)
            {
                allSuppliers.Add(ToModel(created));
                ApplyFilters();
            }

            CloseAddSupplier();
        }
        catch (Exception ex)
        {
            formError = $"Could not add supplier: {ex.Message}";
        }
        finally
        {
            savingSupplier = false;
        }
    }

    string? GetStatus(int id) => eventSuppliers.FirstOrDefault(e => e.SupplierId == id)?.CollaborationStatus;
    EventSupplierModel? GetEventSupplier(int id) => eventSuppliers.FirstOrDefault(e => e.SupplierId == id);

    Task SetStatus((int SupplierId, string Status) change) => SetStatus(change.SupplierId, change.Status);

    async Task SetStatus(int supplierId, string status)
    {
        var es = eventSuppliers.FirstOrDefault(e => e.SupplierId == supplierId);
        if (es is null)
        {
            es = new EventSupplierModel { SupplierId = supplierId };
            eventSuppliers.Add(es);
        }

        es.CollaborationStatus = status;
        await SaveSupplierStatus(supplierId);
        if (_filterStatus != "all") ApplyFilters();
    }

    async Task SetRemainingPaid((int SupplierId, bool RemainingPaid) change)
    {
        var es = eventSuppliers.FirstOrDefault(e => e.SupplierId == change.SupplierId);
        if (es is null)
            return;

        es.RemainingPaid = change.RemainingPaid;
        await SaveSupplierStatus(change.SupplierId);
    }

    void RemoveStatus(int supplierId)
    {
        pendingRemoveSupplierId = supplierId;
        confirmRemoveOpen = true;
    }

    async Task ConfirmRemoveStatus()
    {
        try
        {
            await Api.UpdateSupplierStatusAsync(EventId, pendingRemoveSupplierId, new EventSupplierStatusUpdateDto
            {
                CollaborationStatus = null
            });

            eventSuppliers.RemoveAll(e => e.SupplierId == pendingRemoveSupplierId);
            if (_filterStatus != "all") ApplyFilters();
            confirmRemoveOpen = false;
        }
        catch (Exception ex)
        {
            loadError = $"Could not remove supplier from event: {ex.Message}";
        }
    }

    async Task SyncSupplier(SupplierModel supplier)
    {
        if (supplier.Advance > supplier.Price)
        {
            loadError = "Advance cannot be greater than base price.";
            return;
        }

        try
        {
            await Api.UpdateSupplierAsync(EventId, supplier.Id, new SupplierUpdateDto
            {
                Name = supplier.Name,
                Category = supplier.Category,
                Phone = NullIfBlank(supplier.Phone),
                Email = NullIfBlank(supplier.Email),
                Description = NullIfBlank(supplier.Description),
                Price = supplier.Price,
                Advance = supplier.Advance,
                RemainingPaid = GetEventSupplier(supplier.Id)?.RemainingPaid == true
            });
            await SaveSupplierStatus(supplier.Id);
            loadError = "";
        }
        catch (Exception ex)
        {
            loadError = $"Could not sync supplier budget: {ex.Message}";
        }
    }

    async Task SaveSupplierStatus(int supplierId)
    {
        var supplier = allSuppliers.FirstOrDefault(s => s.Id == supplierId);
        var es = GetEventSupplier(supplierId);
        if (supplier is null || es?.CollaborationStatus is null)
            return;

        await Api.UpdateSupplierStatusAsync(EventId, supplierId, new EventSupplierStatusUpdateDto
        {
            CollaborationStatus = es.CollaborationStatus,
            Advance = supplier.Advance,
            RemainingPaid = es.RemainingPaid,
            Notes = es.Notes
        });
    }

    async Task ExportCSV()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Name,Category,Phone,Email,Description,BasePrice,Advance,RemainingPaid,Status,Notes");
        foreach (var s in allSuppliers)
        {
            var es = GetEventSupplier(s.Id);
            sb.AppendLine($"{Csv(s.Name)},{Csv(s.Category)},{Csv(s.Phone)},{Csv(s.Email)},{Csv(s.Description)},{s.Price},{s.Advance},{(es?.RemainingPaid == true ? "yes" : "no")},{es?.CollaborationStatus ?? ""},{Csv(es?.Notes ?? "")}");
        }
        var base64 = Convert.ToBase64String(Encoding.UTF8.GetBytes(sb.ToString()));
        await JS.InvokeVoidAsync("eval", $"var a=document.createElement('a');a.href='data:text/csv;base64,{base64}';a.download='suppliers.csv';a.click()");
    }

    async Task ImportCSV(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (!file.Name.EndsWith(".csv", StringComparison.OrdinalIgnoreCase))
        { importSummary = "Only .csv files are accepted."; importHasWarning = true; return; }

        using var reader = new System.IO.StreamReader(file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024));
        var text = await reader.ReadToEndAsync();
        int imported = 0, duplicateSkipped = 0, invalidSkipped = 0;
        var lines = CsvImportHelper.NonEmptyLines(text);
        if (lines.Count <= 1)
        {
            importSummary = "No supplier rows found in this CSV.";
            importHasWarning = true;
            return;
        }

        var delimiter = CsvImportHelper.DetectDelimiter(lines[0]);
        foreach (var line in lines.Skip(1))
        {
            var c = CsvImportHelper.ParseFields(line, delimiter);
            var supplier = new SupplierModel
            {
                Name = c.ElementAtOrDefault(0)?.Trim() ?? "",
                Category = c.ElementAtOrDefault(1)?.Trim() ?? "",
                Phone = c.ElementAtOrDefault(2)?.Trim() ?? "",
                Email = c.ElementAtOrDefault(3)?.Trim() ?? "",
                Description = c.ElementAtOrDefault(4)?.Trim() ?? "",
                Price = decimal.TryParse(c.ElementAtOrDefault(5), out var price) ? price : 0,
                Advance = decimal.TryParse(c.ElementAtOrDefault(6), out var advance) ? advance : 0,
            };
            var remainingPaid = ParsePaid(c.ElementAtOrDefault(7));
            var status = ParseSupplierStatus(c.ElementAtOrDefault(8));
            var notes = c.ElementAtOrDefault(9)?.Trim();

            var rowErrors = new Dictionary<string, string>();
            ValidateSupplierDraft(supplier, rowErrors);
            if (rowErrors.Count > 0)
            {
                if (CsvImportHelper.ContainsOnlyDuplicateErrors(rowErrors))
                    duplicateSkipped++;
                else
                    invalidSkipped++;
                continue;
            }

            var created = await Api.CreateSupplierAsync(EventId, new SupplierCreateDto
            {
                Name = supplier.Name.Trim(),
                Category = supplier.Category.Trim(),
                Phone = NullIfBlank(supplier.Phone),
                Email = NullIfBlank(supplier.Email),
                Description = NullIfBlank(supplier.Description),
                Price = supplier.Price,
                Advance = supplier.Advance
            });

            if (created is null)
            {
                invalidSkipped++;
                continue;
            }

            allSuppliers.Add(ToModel(created));
            if (status is not null)
            {
                eventSuppliers.Add(new EventSupplierModel
                {
                    SupplierId = created.SupplierId,
                    CollaborationStatus = status,
                    RemainingPaid = remainingPaid,
                    Notes = string.IsNullOrWhiteSpace(notes) ? null : notes
                });
                await SaveSupplierStatus(created.SupplierId);
            }
            imported++;
        }
        importSummary = CsvImportHelper.BuildImportMessage("supplier", imported, duplicateSkipped, invalidSkipped);
        importHasWarning = duplicateSkipped > 0 || invalidSkipped > 0;
        ApplyFilters();
    }

    async Task DownloadTemplate()
    {
        var csv = "Name,Category,Phone,Email,Description,BasePrice,Advance,RemainingPaid,Status,Notes\n";
        var b64 = Convert.ToBase64String(Encoding.UTF8.GetBytes(csv));
        await JS.InvokeVoidAsync("eval", $"var a=document.createElement('a');a.href='data:text/csv;base64,{b64}';a.download='suppliers_template.csv';a.click()");
    }

    void ValidateSupplierDraft(SupplierModel supplier, Dictionary<string, string> errors)
    {
        var name = supplier.Name.Trim();
        var category = supplier.Category.Trim();
        var email = supplier.Email.Trim();

        if (string.IsNullOrWhiteSpace(name))
            errors[nameof(supplier.Name)] = "Supplier name is required.";

        if (string.IsNullOrWhiteSpace(category))
            errors[nameof(supplier.Category)] = "Category is required.";
        else if (!categories.Contains(category))
            errors[nameof(supplier.Category)] = "Choose one of the available categories.";

        if (allSuppliers.Any(s => s.Name.Trim().Equals(name, StringComparison.OrdinalIgnoreCase) && s.Id != supplier.Id))
            errors[nameof(supplier.Name)] = "A supplier with this name already exists.";

        if (!string.IsNullOrWhiteSpace(email))
        {
            if (!emailValidator.IsValid(email))
            {
                errors[nameof(supplier.Email)] = "Enter a valid email address.";
            }
            else if (allSuppliers.Any(s => !string.IsNullOrWhiteSpace(s.Email) &&
                                           s.Email.Trim().Equals(email, StringComparison.OrdinalIgnoreCase) &&
                                           s.Id != supplier.Id))
            {
                errors[nameof(supplier.Email)] = "A supplier with this email already exists.";
            }
        }

        if (supplier.Price < 0)
            errors[nameof(supplier.Price)] = "Base price cannot be negative.";

        if (supplier.Advance < 0)
            errors[nameof(supplier.Advance)] = "Advance cannot be negative.";
        else if (supplier.Advance > supplier.Price)
            errors[nameof(supplier.Advance)] = "Advance cannot be greater than base price.";
    }

    decimal PaidAmount(SupplierModel supplier)
    {
        var status = GetStatus(supplier.Id);
        if (status != "confirmed")
            return 0;

        var remainingPaid = GetEventSupplier(supplier.Id)?.RemainingPaid == true;
        return Math.Min(supplier.Advance, supplier.Price) + (remainingPaid ? supplier.Remaining : 0);
    }

    decimal UnpaidAmount(SupplierModel supplier)
    {
        var status = GetStatus(supplier.Id);
        if (status is null)
            return 0;
        if (status == "pending")
            return supplier.Price;

        return GetEventSupplier(supplier.Id)?.RemainingPaid == true ? 0 : supplier.Remaining;
    }

    static bool ParsePaid(string? value)
    {
        var text = value?.Trim().ToLowerInvariant();
        return text is "yes" or "true" or "paid" or "1";
    }

    static string? ParseSupplierStatus(string? value)
    {
        var text = value?.Trim().ToLowerInvariant();
        return text is "pending" or "confirmed" ? text : null;
    }

    static SupplierModel ToModel(SupplierDto supplier) => new()
    {
        Id = supplier.SupplierId,
        Name = supplier.Name,
        Category = supplier.Category,
        Phone = supplier.Phone ?? "",
        Email = supplier.Email ?? "",
        Description = supplier.Description ?? "",
        Price = supplier.Price,
        Advance = supplier.Advance,
        RemainingPaid = supplier.RemainingPaid
    };

    static string? NullIfBlank(string value) => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    static string Csv(string value) =>
        value.Contains(',') || value.Contains('"') || value.Contains('\n')
            ? $"\"{value.Replace("\"", "\"\"")}\""
            : value;

    bool HasFormError(string field) => formFieldErrors.ContainsKey(field);

    RenderFragment FormFieldError(string field) => builder =>
    {
        if (!formFieldErrors.TryGetValue(field, out var message)) return;
        builder.OpenElement(0, "p");
        builder.AddAttribute(1, "class", "field-error");
        builder.AddContent(2, message);
        builder.CloseElement();
    };

    public void Dispose() { }
}
