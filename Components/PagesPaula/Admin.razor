@page "/admin"
@layout PaulaLayout
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject IWebHostEnvironment Env
@inject WeddingPlannerApp.Services.WeddingApiClient Api
@using Microsoft.AspNetCore.Components.Forms
@using WeddingPlannerApp.DTOs.Event
@using WeddingPlannerApp.DTOs.Venue
@using WeddingPlannerApp.Models
@using WeddingPlannerApp.Services
@using WeddingPlannerApp.Components.PagesPaula.AdminComponents

<div class="admin-wrap">
    <nav class="tables-nav">
        <div class="tables-nav-brand">
            <div class="tables-nav-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="7" height="7" />
                    <rect x="14" y="3" width="7" height="7" />
                    <rect x="14" y="14" width="7" height="7" />
                    <rect x="3" y="14" width="7" height="7" />
                </svg>
            </div>
            <div>
                <span class="tables-nav-title">Application Manager</span>
                <span class="tables-nav-sub">Review events &amp; manage venues</span>
            </div>
        </div>
        <div class="tables-nav-actions">
            <button class="btn-signout" @onclick="SignOut">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16 17 21 12 16 7" />
                    <line x1="21" y1="12" x2="9" y2="12" />
                </svg>
                Sign Out
            </button>
        </div>
    </nav>

    <div class="admin-body">
        <AdminStatsRow TotalEvents="@events.Count"
                       UpcomingEvents="@UpcomingEventCount"
                       TotalGuests="@TotalGuestCount"
                       TotalBudget="@TotalBudget" />

        <AdminEventsPanel Events="EventList"
                          ExpandedEventId="expandedEventId"
                          OnToggleExpand="ToggleExpand"
                          OnDelete="DeleteEvent" />

        <AdminVenuesPanel Venues="venues"
                          OnAddVenue="OpenNewVenueModal"
                          OnDeleteVenue="DeleteVenue" />
    </div>
</div>

@if (showVenueModal)
{
    <div class="modal-backdrop" @onclick="CloseVenueModal">
        <div class="modal-box" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Add New Venue</h3>
                <button class="modal-close" @onclick="CloseVenueModal">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                </button>
            </div>

            @if (!string.IsNullOrEmpty(venueModalError))
            {
                <div class="error-banner">@venueModalError</div>
            }

            <div class="form-grid-2">
                <div class="field">
                    <label>Venue Name</label>
                    <input class="input @(HasVenueError(nameof(newVenue.Name)) ? "field-invalid" : "")" placeholder="Rosewood Gardens" @bind="newVenue.Name" @bind:event="oninput" />
                    @VenueFieldError(nameof(newVenue.Name))
                </div>
                <div class="field admin-primary-tag">
                    <label>Primary Type</label>
                    <div class="admin-primary-tag-value">@PrimaryVenueTag</div>
                    <p class="admin-field-hint">The first selected tag is used as the venue type.</p>
                </div>
            </div>

            <div class="field admin-tags-field">
                <label>Venue Tags</label>
                <div class="admin-tag-picker @(HasVenueError(nameof(newVenue.Tags)) ? "field-invalid" : "")">
                    @foreach (var tag in venueTypes)
                    {
                        <button type="button"
                                class="admin-tag-chip @(IsVenueTagSelected(tag) ? "admin-tag-chip-selected" : "")"
                                @onclick="@(() => ToggleVenueTag(tag))">
                            @tag
                        </button>
                    }
                </div>
                @VenueFieldError(nameof(newVenue.Tags))
            </div>

            <div class="field">
                <label>Address</label>
                <input class="input @(HasVenueError(nameof(newVenue.Address)) ? "field-invalid" : "")" placeholder="123 Rose Lane, City" @bind="newVenue.Address" @bind:event="oninput" />
                @VenueFieldError(nameof(newVenue.Address))
            </div>

            <div class="form-grid-2">
                <div class="field">
                    <label>Latitude *</label>
                    <input type="number" class="input @(HasVenueError(nameof(newVenue.Latitude)) ? "field-invalid" : "")" min="-90" max="90" step="0.000001" placeholder="44.4268" @bind="newVenue.Latitude" @bind:event="oninput" />
                    @VenueFieldError(nameof(newVenue.Latitude))
                </div>
                <div class="field">
                    <label>Longitude *</label>
                    <input type="number" class="input @(HasVenueError(nameof(newVenue.Longitude)) ? "field-invalid" : "")" min="-180" max="180" step="0.000001" placeholder="26.1025" @bind="newVenue.Longitude" @bind:event="oninput" />
                    @VenueFieldError(nameof(newVenue.Longitude))
                </div>
            </div>

            <div class="field">
                <label>Venue Image</label>
                <div class="venue-upload-zone @(uploadDragActive ? "venue-upload-active" : "") @(HasVenueError(nameof(newVenue.ImagePath)) ? "field-invalid" : "")"
                     @ondragenter="@(() => uploadDragActive = true)"
                     @ondragleave="@(() => uploadDragActive = false)"
                     @ondragover:preventDefault="true"
                     @ondragover="@(() => uploadDragActive = true)">

                    @if (!string.IsNullOrEmpty(newVenue.ImagePath))
                    {
                        <div style="position:relative;width:100%;height:100%;">
                            <img src="@newVenue.ImagePath" alt="preview" class="venue-upload-preview" />
                            <button type="button" class="venue-upload-clear" @onclick="ClearImage" @onclick:stopPropagation="true">
                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="18" y1="6" x2="6" y2="18" />
                                    <line x1="6" y1="6" x2="18" y2="18" />
                                </svg>
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="venue-upload-inner">
                            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color:var(--sage-light)">
                                <rect x="3" y="3" width="18" height="18" rx="2" />
                                <circle cx="8.5" cy="8.5" r="1.5" />
                                <polyline points="21 15 16 10 5 21" />
                            </svg>
                            <p class="venue-upload-title">Drag &amp; drop or browse</p>
                            <p class="venue-upload-sub">JPG, PNG, WebP - max 5 MB</p>
                            <label class="btn-outline" style="cursor:pointer;margin-top:.35rem;font-size:.82rem;padding:.35rem .8rem;">
                                Browse
                                <InputFile OnChange="HandleVenueImageUpload" accept=".jpg,.jpeg,.png,.webp" style="display:none;" />
                            </label>
                        </div>
                    }
                </div>
                @if (!string.IsNullOrEmpty(uploadError))
                {
                    <p style="font-size:.78rem;color:var(--error);margin:.35rem 0 0;">@uploadError</p>
                }
                @VenueFieldError(nameof(newVenue.ImagePath))
            </div>

            <div class="form-grid-3">
                <div class="field">
                    <label>Min Guests</label>
                    <input type="number" class="input @(HasVenueError(nameof(newVenue.MinCapacity)) ? "field-invalid" : "")" min="1" @bind="newVenue.MinCapacity" @bind:event="oninput" />
                    @VenueFieldError(nameof(newVenue.MinCapacity))
                </div>
                <div class="field">
                    <label>Max Guests</label>
                    <input type="number" class="input @(HasVenueError(nameof(newVenue.MaxCapacity)) ? "field-invalid" : "")" min="1" @bind="newVenue.MaxCapacity" @bind:event="oninput" />
                    @VenueFieldError(nameof(newVenue.MaxCapacity))
                </div>
                <div class="field">
                    <label>Est. Price ($)</label>
                    <input type="number" class="input @(HasVenueError(nameof(newVenue.EstimatedPrice)) ? "field-invalid" : "")" min="0" @bind="newVenue.EstimatedPrice" @bind:event="oninput" />
                    @VenueFieldError(nameof(newVenue.EstimatedPrice))
                </div>
            </div>

            <button class="btn-add-guest" @onclick="AddVenue">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:.35rem">
                    <line x1="12" y1="5" x2="12" y2="19" />
                    <line x1="5" y1="12" x2="19" y2="12" />
                </svg>
                Add Venue
            </button>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(toastMessage))
{
    <div class="toast @(toastIsError ? "toast-error" : "toast-success")">
        @if (toastIsError)
        {
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <line x1="12" y1="8" x2="12" y2="12" />
                <line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
        }
        else
        {
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                <polyline points="22 4 12 14.01 9 11.01" />
            </svg>
        }
        @toastMessage
    </div>
}

<ConfirmDialog IsOpen="confirmOpen"
               Title="@confirmTitle"
               Message="@confirmMessage"
               ConfirmText="@confirmText"
               OnCancel="CloseConfirm"
               OnConfirm="ConfirmDelete" />

@code {
    readonly string[] venueTypes =
    [
        "Garden",
        "OpenSpace",
        "Indoor",
        "Outdoor",
        "Ballroom",
        "BanquetHall",
        "Restaurant",
        "Hotel",
        "Barn",
        "Beach",
        "Vineyard",
        "Rooftop",
        "Historic",
        "Luxury",
        "Rustic",
        "Modern",
        "Waterfront",
        "MountainView",
        "Forest",
        "Chapel",
        "Castle",
        "Resort",
        "CountryClub",
        "SmallCapacity",
        "LargeCapacity",
        "BudgetFriendly",
        "Premium",
    ];

    List<AdminEventModel> events = new();
    List<AdminVenueModel> venues = new();

    int? expandedEventId = null;

    bool showVenueModal = false;
    string venueModalError = "";
    AdminVenueModel newVenue = new();
    bool uploadDragActive = false;
    string uploadError = "";
    Dictionary<string, string> venueFieldErrors = new();

    string toastMessage = "";
    bool toastIsError = false;
    System.Timers.Timer? toastTimer;
    bool confirmOpen;
    string confirmTitle = "";
    string confirmMessage = "";
    string confirmText = "Delete";
    string pendingDeleteType = "";
    int pendingDeleteId;

    IReadOnlyList<AdminEventModel> EventList => events.OrderBy(e => e.EventDate).ToList();
    int UpcomingEventCount => events.Count(e => e.EventDate.Date >= DateTime.Today);
    int TotalGuestCount => events.Sum(e => e.GuestCount);
    decimal TotalBudget => events.Sum(e => e.TotalBudget);

    static AdminVenueModel ToAdminVenue(VenueDto venue) => new()
    {
        Id = venue.VenueId,
        Name = venue.Name,
        Type = venue.Tags?.ToString() ?? "Venue",
        Address = venue.Address,
        MinCapacity = venue.MinCapacity,
        MaxCapacity = venue.MaxCapacity,
        EstimatedPrice = venue.EstimatedPrice,
        Latitude = venue.Latitude,
        Longitude = venue.Longitude,
        ImagePath = venue.ImagePath ?? "",
        Tags = venue.Tags is null ? [] : [venue.Tags.Value.ToString()]
    };

    static AdminEventModel ToAdminEvent(EventDto eventItem, IReadOnlyDictionary<int, string> venueNames, int guestCount) => new()
    {
        Id = eventItem.EventId,
        Name = eventItem.Name,
        Type = "Wedding",
        EventDate = eventItem.EventDate,
        VenueId = eventItem.VenueId,
        VenueName = venueNames.GetValueOrDefault(eventItem.VenueId, $"Venue #{eventItem.VenueId}"),
        GuestCount = guestCount,
        TotalBudget = eventItem.TotalBudget,
        MenuName = eventItem.MenuId > 0 ? $"Menu #{eventItem.MenuId}" : "Not selected",
        Notes = eventItem.Notes ?? "",
        CreatedAt = eventItem.CreatedAt
    };

    void ToggleExpand(int id) =>
        expandedEventId = expandedEventId == id ? null : id;

    void DeleteEvent(int id)
    {
        var item = events.FirstOrDefault(e => e.Id == id);
        OpenConfirm("Delete event?", $"Delete \"{item?.Name ?? "this event"}\"? This cannot be undone.", "Delete event", "event", id);
    }

    void OpenNewVenueModal()
    {
        newVenue = new AdminVenueModel { Type = "Garden", Tags = new() { "Garden" } };
        venueModalError = "";
        uploadError = "";
        venueFieldErrors.Clear();
        uploadDragActive = false;
        showVenueModal = true;
    }

    void CloseVenueModal()
    {
        showVenueModal = false;
        venueModalError = "";
        uploadError = "";
        venueFieldErrors.Clear();
    }

    void ClearImage() => newVenue.ImagePath = "";

    static string Slugify(string name) =>
        System.Text.RegularExpressions.Regex
            .Replace(name.ToLowerInvariant().Trim(), @"[^a-z0-9]+", "-")
            .Trim('-');

    async Task HandleVenueImageUpload(InputFileChangeEventArgs e)
    {
        uploadError = "";
        uploadDragActive = false;

        var file = e.File;
        var allowed = new[] { "image/jpeg", "image/png", "image/webp" };

        if (!allowed.Contains(file.ContentType))
        {
            uploadError = "Only JPG, PNG and WebP images are accepted.";
            return;
        }

        const long maxSize = 5 * 1024 * 1024;
        if (file.Size > maxSize)
        {
            uploadError = "Image must be under 5 MB.";
            return;
        }

        var slug = !string.IsNullOrWhiteSpace(newVenue.Name)
            ? Slugify(newVenue.Name)
            : Guid.NewGuid().ToString("N")[..8];

        var folder = Path.Combine(Env.WebRootPath, "images", "venues", slug);
        Directory.CreateDirectory(folder);

        var existing = Directory.GetFiles(folder).Length;
        var ext = Path.GetExtension(file.Name).ToLowerInvariant();
        var fileName = $"{existing + 1}{ext}";
        var filePath = Path.Combine(folder, fileName);

        await using var fs = new FileStream(filePath, FileMode.Create);
        await file.OpenReadStream(maxSize).CopyToAsync(fs);

        newVenue.ImageFolder = slug;
        newVenue.ImagePath = $"/images/venues/{slug}/{fileName}";
    }

    async Task AddVenue()
    {
        venueModalError = "";
        venueFieldErrors.Clear();
        if (string.IsNullOrWhiteSpace(newVenue.Name)) venueFieldErrors[nameof(newVenue.Name)] = "Venue name is required.";
        if (newVenue.Tags.Count == 0) venueFieldErrors[nameof(newVenue.Tags)] = "Select at least one venue tag.";
        if (string.IsNullOrWhiteSpace(newVenue.Address)) venueFieldErrors[nameof(newVenue.Address)] = "Address is required.";
        if (newVenue.MinCapacity <= 0) venueFieldErrors[nameof(newVenue.MinCapacity)] = "Min guests must be greater than 0.";
        if (newVenue.MaxCapacity < newVenue.MinCapacity) venueFieldErrors[nameof(newVenue.MaxCapacity)] = "Max guests must be at least the min guests value.";
        if (newVenue.EstimatedPrice < 0) venueFieldErrors[nameof(newVenue.EstimatedPrice)] = "Estimated price cannot be negative.";
        if (newVenue.Latitude is null) venueFieldErrors[nameof(newVenue.Latitude)] = "Latitude is required.";
        else if (newVenue.Latitude is < -90 or > 90) venueFieldErrors[nameof(newVenue.Latitude)] = "Latitude must be between -90 and 90.";
        if (newVenue.Longitude is null) venueFieldErrors[nameof(newVenue.Longitude)] = "Longitude is required.";
        else if (newVenue.Longitude is < -180 or > 180) venueFieldErrors[nameof(newVenue.Longitude)] = "Longitude must be between -180 and 180.";
        if (string.IsNullOrWhiteSpace(newVenue.ImagePath)) venueFieldErrors[nameof(newVenue.ImagePath)] = "Venue image is required.";
        if (venueFieldErrors.Count > 0) { venueModalError = "Please fix the highlighted fields."; return; }

        newVenue.Type = PrimaryVenueTag;
        var latitude = newVenue.Latitude.GetValueOrDefault();
        var longitude = newVenue.Longitude.GetValueOrDefault();

        try
        {
            var created = await Api.CreateVenueAsync(new VenueCreateDto
            {
                Name = newVenue.Name.Trim(),
                Address = newVenue.Address.Trim(),
                Description = $"A {newVenue.Type.ToLowerInvariant()} venue added by the admin team.",
                MinCapacity = newVenue.MinCapacity,
                MaxCapacity = newVenue.MaxCapacity,
                EstimatedPrice = newVenue.EstimatedPrice,
                Latitude = latitude,
                Longitude = longitude,
                ImagePath = newVenue.ImagePath,
                Tags = ToVenueTag(PrimaryVenueTag)
            });

            if (created != null)
                venues.Add(ToAdminVenue(created));

            CloseVenueModal();
            ShowToast($"\"{newVenue.Name}\" added. Planners will see it during onboarding.");
        }
        catch (Exception ex)
        {
            venueModalError = $"Could not add venue: {ex.Message}";
        }
    }

    void DeleteVenue(int id)
    {
        var item = venues.FirstOrDefault(v => v.Id == id);
        OpenConfirm("Delete venue?", $"Delete \"{item?.Name ?? "this venue"}\"? This cannot be undone.", "Delete venue", "venue", id);
    }

    void OpenConfirm(string title, string message, string confirmTextValue, string type, int id)
    {
        confirmTitle = title;
        confirmMessage = message;
        confirmText = confirmTextValue;
        pendingDeleteType = type;
        pendingDeleteId = id;
        confirmOpen = true;
    }

    void CloseConfirm() => confirmOpen = false;

    async Task ConfirmDelete()
    {
        if (pendingDeleteType == "event")
        {
            try
            {
                await Api.DeleteEventAsync(pendingDeleteId);
                events.RemoveAll(x => x.Id == pendingDeleteId);
                if (expandedEventId == pendingDeleteId) expandedEventId = null;
                ShowToast("Event removed.");
            }
            catch (Exception ex)
            {
                ShowToast($"Could not delete event: {ex.Message}", error: true);
            }
        }
        else if (pendingDeleteType == "venue")
        {
            try
            {
                await Api.DeleteVenueAsync(pendingDeleteId);
                venues.RemoveAll(x => x.Id == pendingDeleteId);
                ShowToast("Venue removed.");
            }
            catch (Exception ex)
            {
                ShowToast($"Could not delete venue: {ex.Message}", error: true);
            }
        }

        CloseConfirm();
    }

    void SignOut() => Nav.NavigateTo("/");

    string PrimaryVenueTag => newVenue.Tags.FirstOrDefault() ?? "Select a tag";

    bool IsVenueTagSelected(string tag) => newVenue.Tags.Contains(tag);

    void ToggleVenueTag(string tag)
    {
        if (newVenue.Tags.Contains(tag))
        {
            newVenue.Tags.Remove(tag);
            return;
        }

        newVenue.Tags.Add(tag);
    }

    bool HasVenueError(string field) => venueFieldErrors.ContainsKey(field);

    RenderFragment VenueFieldError(string field) => builder =>
    {
        if (!venueFieldErrors.TryGetValue(field, out var message)) return;
        builder.OpenElement(0, "p");
        builder.AddAttribute(1, "class", "field-error");
        builder.AddContent(2, message);
        builder.CloseElement();
    };

    void ShowToast(string msg, bool error = false)
    {
        toastMessage = msg;
        toastIsError = error;
        toastTimer?.Dispose();
        toastTimer = new System.Timers.Timer(3000);
        toastTimer.Elapsed += async (_, _) =>
        {
            toastMessage = "";
            toastTimer?.Dispose();
            await InvokeAsync(StateHasChanged);
        };
        toastTimer.AutoReset = false;
        toastTimer.Start();
    }

    protected override async Task OnInitializedAsync() => await LoadAdminData();

    async Task LoadAdminData()
    {
        try
        {
            var venueDtos = await Api.GetVenuesAsync();
            venues = venueDtos.Select(ToAdminVenue).ToList();
            var venueNames = venueDtos.ToDictionary(v => v.VenueId, v => v.Name);

            var eventDtos = await Api.GetEventsAsync();
            var loadedEvents = new List<AdminEventModel>();
            foreach (var eventDto in eventDtos)
            {
                var guestCount = 0;
                try
                {
                    guestCount = (await Api.GetGuestsAsync(eventDto.EventId)).Count;
                }
                catch
                {
                    guestCount = eventDto.EstimatedGuests;
                }

                loadedEvents.Add(ToAdminEvent(eventDto, venueNames, guestCount));
            }

            events = loadedEvents;
        }
        catch (Exception ex)
        {
            ShowToast($"Could not load admin data: {ex.Message}", error: true);
        }
    }

    static VenueTag? ToVenueTag(string tag) =>
        Enum.TryParse<VenueTag>(tag, ignoreCase: true, out var venueTag) ? venueTag : null;

    public void Dispose()
    {
        toastTimer?.Dispose();
    }
}
