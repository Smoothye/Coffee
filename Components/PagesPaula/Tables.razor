@page "/tables"
@layout PaulaLayout
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject IJSRuntime JS
@using System.Text
@using WeddingPlannerApp.Components.PagesPaula.TableComponents
@implements IDisposable

<PageNav Title="Table Plan"
         Subtitle="Drag guests to seats"
         IconSvg="@SvgIcons.TablesNav" />

@if (!string.IsNullOrEmpty(toastMsg))
{
    <div class="toast @(toastError ? "toast-error" : "toast-success")">
        @(toastError ? SvgIcons.AlertCircle : SvgIcons.CheckCircle)
        @toastMsg
    </div>
}

<CsvGuideModal IsOpen="csvGuideOpen"
               Title="Import Guests"
               AcceptedTitle="Accepted formats"
               Columns="tableCsvColumns"
               OnClose="@CloseCsvGuide">
    <LeftFooter>
        <div class="csv-rules">
            <p class="csv-rules-title">@SvgIcons.AlertCircle Duplicate rules</p>
            <ul class="csv-rules-list">
                <li>Same <strong>email</strong> or <strong>phone</strong> &rarr; skipped</li>
                <li>Same <strong>full name</strong> &rarr; allowed (shown as duplicate)</li>
                <li>Invalid <strong>Group</strong> &rarr; defaults to <span class="csv-tag csv-other">other</span></li>
            </ul>
        </div>
        <button class="btn-outline" style="margin-top:.75rem;width:100%;justify-content:center;" @onclick="DownloadTemplate">
            @SvgIcons.Download Download blank template
        </button>
    </LeftFooter>
    <UploadContent>
        <p class="csv-section-title">Upload file</p>
        <div class="csv-dropzone @(dragActive ? "csv-dropzone-active" : "")"
             @ondragenter="@((e) => dragActive = true)"
             @ondragleave="@((e) => dragActive = false)"
             @ondragover:preventDefault="true"
             @ondragover="@((e) => dragActive = true)">
            <div class="csv-drop-inner">
                @if (csvImportResult == null)
                {
                    <div class="csv-drop-icon">@SvgIcons.UploadCloud</div>
                    <p class="csv-drop-title">Drag &amp; drop your .csv here</p>
                    <p class="csv-drop-sub">or</p>
                }
                else
                {
                    <div class="csv-drop-icon @(csvImportResult.HasWarning ? "icon-warn" : "icon-ok")">
                        @(csvImportResult.HasWarning ? SvgIcons.AlertCircle : SvgIcons.CheckCircle)
                    </div>
                    <p class="csv-drop-title">@csvImportResult.Message</p>
                    <p class="csv-drop-sub">Upload another file?</p>
                }
                <label class="btn-add" style="cursor:pointer;margin-top:.5rem;">
                    @SvgIcons.Upload Browse file
                    <InputFile OnChange="ImportCSV" accept=".csv" style="display:none;" />
                </label>
                <p class="csv-accepted-note">Accepted: <strong>.csv</strong> only</p>
            </div>
        </div>
        @if (csvImportResult != null)
        {
            <button class="btn-add-guest" style="margin-top:.75rem;" @onclick="CloseCsvGuide">
                @SvgIcons.CheckSmall Done - View Tables
            </button>
        }
    </UploadContent>
</CsvGuideModal>

<TableAddGuestModal IsOpen="addGuestOpen"
                    Tables="tables"
                    Error="@addGuestError"
                    DuplicateWarning="@dupWarning"
                    FieldErrors="@addGuestFieldErrors"
                    FirstName="@ng_FirstName"
                    FirstNameChanged="@((value) => ng_FirstName = value)"
                    LastName="@ng_LastName"
                    LastNameChanged="@((value) => ng_LastName = value)"
                    Email="@ng_Email"
                    EmailChanged="@((value) => ng_Email = value)"
                    Phone="@ng_Phone"
                    PhoneChanged="@((value) => ng_Phone = value)"
                    Group="@ng_Group"
                    GroupChanged="@((value) => ng_Group = value)"
                    AssignTo="@ng_AssignTo"
                    AssignToChanged="@((value) => ng_AssignTo = value)"
                    OnClose="CloseAddGuest"
                    OnAdd="AddGuest" />

<TableHeadConfigModal IsOpen="headConfigOpen"
                      BrideName="@pendingBrideName"
                      BrideNameChanged="@((value) => pendingBrideName = value)"
                      GroomName="@pendingGroomName"
                      GroomNameChanged="@((value) => pendingGroomName = value)"
                      GodparentCount="@pendingGodparentCount"
                      GodparentCountChanged="@((value) => pendingGodparentCount = value)"
                      OnClose="@(() => headConfigOpen = false)"
                      OnApply="ApplyHeadConfig" />

<TableSeatPickerModal IsOpen="@(seatPickerOpen && pickerTable != null)"
                      Title="@SeatPickerTitle"
                      Guests="PickerGuests().ToList()"
                      SeatedGuestIds="SeatedGuestIds"
                      Groups="GroupDefs"
                      Search="@pickerSearch"
                      SearchChanged="@((value) => pickerSearch = value)"
                      OnAssign="AssignGuestToSeat"
                      OnClose="CloseSeatPicker" />

<div class="tables-page">

    <TableSeatingCanvas Tables="tables"
                        Groups="GroupDefs"
                        HeadLabels="HeadLabels()"
                        BrideName="@brideName"
                        GroomName="@groomName"
                        GodparentCouples="@godparentCouples"
                        SeatedCount="seatedCount"
                        TotalGuests="totalGuests"
                        TotalSeats="totalSeats"
                        SeatContent="RenderSeat"
                        OnConfigureHeadTable="OpenHeadConfig"
                        OnCsvGuide="OpenCsvGuide"
                        OnImport="ImportCSV"
                        OnExport="ExportCSV"
                        OnAddTable="AddTable"
                        OnRemoveTable="RemoveTable"
                        OnResizeTable="ResizeTable" />

    <TableGuestPool Guests="pool"
                    Groups="GroupDefs"
                    DragOver="dragOverPool"
                    OnStartDrag="StartPoolDrag"
                    OnDragEnd="@(() => draggedGuest = null)"
                    OnDragOver="@(() => dragOverPool = true)"
                    OnDragLeave="@(() => dragOverPool = false)"
                    OnDrop="DropOnPool"
                    OnRemove="RemoveFromPool" />

</div>

<ConfirmDialog IsOpen="confirmDeleteOpen"
               Title="@confirmDeleteTitle"
               Message="@confirmDeleteMessage"
               ConfirmText="@confirmDeleteText"
               OnCancel="@(() => confirmDeleteOpen = false)"
               OnConfirm="ConfirmDelete" />

@code {
    static readonly CsvGuideColumn[] tableCsvColumns =
    {
        new() { Name = "FirstName", Required = true, ValidValues = "Any text" },
        new() { Name = "LastName", Required = true, ValidValues = "Any text" },
        new() { Name = "Group", ValidValues = "family, friends, colleagues, other" },
        new() { Name = "Email", ValidValues = "Duplicate check" },
        new() { Name = "Phone", ValidValues = "Duplicate check" },
        new() { Name = "Table", ValidValues = "Ignored on import" },
        new() { Name = "Seat", ValidValues = "Ignored on import" },
    };

    static readonly Dictionary<string, GroupColors> GroupDefs = new()
    {
        ["family"] = new("#fff1f2", "#fda4af", "#be123c", "#f43f5e", "#fda4af", "#fb7185"),
        ["friends"] = new("#f0fdf4", "#6ee7b7", "#065f46", "#10b981", "#6ee7b7", "#34d399"),
        ["colleagues"] = new("#f5f3ff", "#c4b5fd", "#5b21b6", "#8b5cf6", "#c4b5fd", "#a78bfa"),
        ["other"] = new("#fffbeb", "#fcd34d", "#92400e", "#f59e0b", "#fcd34d", "#fbbf24"),
    };
    int godparentCouples = 2;
    string brideName = "Bride";
    string groomName = "Groom";
    List<EventTable> tables = new();
    List<TableGuest> pool = new();
    TableGuest? draggedGuest = null;
    DragSource? dragSource = null;
    string? dragOverSeat = null;
    bool dragOverPool = false;
    bool addGuestOpen = false;
    string addGuestError = "";
    string dupWarning = "";
    Dictionary<string, string> addGuestFieldErrors = new();
    string ng_FirstName = "";
    string ng_LastName = "";
    string ng_Email = "";
    string ng_Phone = "";
    string ng_Group = "friends";
    string ng_AssignTo = "pool";
    bool headConfigOpen = false;
    int pendingGodparentCount = 2;
    string pendingBrideName = "Bride";
    string pendingGroomName = "Groom";
    bool csvGuideOpen = false;
    bool dragActive = false;
    CsvImportResult? csvImportResult = null;
    string toastMsg = "";
    bool toastError = false;
    System.Timers.Timer? toastTimer;
    bool confirmDeleteOpen = false;
    string confirmDeleteTitle = "Delete item?";
    string confirmDeleteMessage = "";
    string confirmDeleteText = "Delete";
    string pendingDeleteType = "";
    int pendingDeleteId;

    // Seat picker popover
    bool seatPickerOpen = false;
    EventTable? pickerTable = null;
    int pickerSeatIndex = -1;
    string pickerSearch = "";

    string SeatPickerTitle
    {
        get
        {
            if (pickerTable is null)
                return "Assign guest";

            var seatLabel = pickerTable.IsHeadTable
                ? (HeadLabels().ElementAtOrDefault(pickerSeatIndex) ?? $"Seat {pickerSeatIndex + 1}")
                : $"Seat {pickerSeatIndex + 1}";

            return $"Assign to {pickerTable.Name} - {seatLabel}";
        }
    }

    IReadOnlySet<int> SeatedGuestIds =>
        tables.SelectMany(t => t.Seats)
              .Where(g => g is not null)
              .Select(g => g!.Id)
              .ToHashSet();

    void CloseCsvGuide()
    {
        csvGuideOpen = false;
        dragActive = false;
        csvImportResult = null;
    }

    void OpenCsvGuide()
    {
        csvGuideOpen = true;
        csvImportResult = null;
    }

    void OpenSeatPicker(EventTable table, int idx)
    {
        pickerTable = table;
        pickerSeatIndex = idx;
        pickerSearch = "";
        seatPickerOpen = true;
    }

    void CloseSeatPicker()
    {
        seatPickerOpen = false;
        pickerTable = null;
        pickerSeatIndex = -1;
        pickerSearch = "";
    }

    void AssignGuestToSeat(TableGuest guest)
    {
        if (pickerTable == null || pickerSeatIndex < 0) return;
        if (IsLockedHeadSeat(pickerTable, pickerSeatIndex))
        {
            ShowToast("Bride and groom stay at the head table.", error: true);
            CloseSeatPicker();
            return;
        }

        // If guest is currently seated somewhere else, free that seat
        foreach (var t in tables)
        {
            for (int i = 0; i < t.Seats.Count; i++)
            {
                if (t.Seats[i]?.Id == guest.Id)
                {
                    t.Seats[i] = null;
                    goto found;
                }
            }
        }
        // Otherwise remove from pool
        pool.RemoveAll(g => g.Id == guest.Id);

    found:
        pickerTable.Seats[pickerSeatIndex] = guest;
        ShowToast($"{guest.FirstName} {guest.LastName} seated!");
        CloseSeatPicker();
    }

    IEnumerable<TableGuest> PickerGuests()
    {
        var all = pool.Concat(
            tables.SelectMany(t => t.Seats.Where(s => s != null).Cast<TableGuest>())
        ).Where(g => !IsLockedHeadGuest(g));
        if (!string.IsNullOrWhiteSpace(pickerSearch))
        {
            var q = pickerSearch.Trim().ToLower();
            all = all.Where(g =>
                g.FirstName.ToLower().Contains(q) ||
                g.LastName.ToLower().Contains(q) ||
                $"{g.FirstName} {g.LastName}".ToLower().Contains(q));
        }
        return all;
    }

    protected override void OnInitialized()
    {
        BuildHeadTable();
        tables.AddRange(new[]
        {
            MakeTable(1, "Table 1", 6),
            MakeTable(2, "Table 2", 6),
            MakeTable(3, "Table 3", 8),
        });
        pool = new List<TableGuest>();
    }

    void BuildHeadTable()
    {
        var capacity = 2 + godparentCouples * 2;
        var existing = tables.FirstOrDefault(t => t.IsHeadTable);
        var oldSeats = existing?.Seats ?? new List<TableGuest?>();

        var ht = new EventTable
        {
            Id = 0,
            Name = "Head Table",
            IsHeadTable = true,
            Capacity = capacity,
            Seats = new List<TableGuest?>(Enumerable.Repeat<TableGuest?>(null, capacity))
        };

        for (int i = 0; i < Math.Min(oldSeats.Count, capacity); i++)
            ht.Seats[i] = oldSeats[i];

        ht.Seats[0] = MakeGuest(-1, brideName, "", "family");
        ht.Seats[1] = MakeGuest(-2, groomName, "", "family");

        if (existing != null)
        {
            for (int i = capacity; i < oldSeats.Count; i++)
                if (oldSeats[i] != null) pool.Add(oldSeats[i]!);
            tables.Remove(existing);
        }

        tables.Insert(0, ht);
    }

    static EventTable MakeTable(int id, string name, int cap) => new()
    {
        Id = id,
        Name = name,
        Capacity = cap,
        Seats = new List<TableGuest?>(Enumerable.Repeat<TableGuest?>(null, cap))
    };

    static TableGuest MakeGuest(int id, string fn, string ln, string group) =>
        new() { Id = id, FirstName = fn, LastName = ln, Group = group };

    List<string> HeadLabels()
    {
        var labels = new List<string> { brideName, groomName };
        for (int i = 1; i <= godparentCouples; i++)
        {
            labels.Add($"Godmother {i}");
            labels.Add($"Godfather {i}");
        }
        return labels;
    }

    void OpenHeadConfig()
    {
        pendingGodparentCount = godparentCouples;
        pendingBrideName = brideName;
        pendingGroomName = groomName;
        headConfigOpen = true;
    }

    void ApplyHeadConfig()
    {
        godparentCouples = pendingGodparentCount;
        brideName = string.IsNullOrWhiteSpace(pendingBrideName) ? "Bride" : pendingBrideName.Trim();
        groomName = string.IsNullOrWhiteSpace(pendingGroomName) ? "Groom" : pendingGroomName.Trim();
        BuildHeadTable();
        headConfigOpen = false;
        ShowToast($"Head table updated — {2 + godparentCouples * 2} seats total.");
    }

    void StartDrag(TableGuest guest, DragSource source)
    {
        if (IsLockedHeadGuest(guest))
        {
            draggedGuest = null;
            dragSource = null;
            return;
        }

        draggedGuest = guest;
        dragSource = source;
    }

    void StartPoolDrag(TableGuest guest) =>
        StartDrag(guest, new DragSource { Type = "pool" });

    void DropOnSeat(EventTable targetTable, int seatIndex)
    {
        if (draggedGuest == null || dragSource == null) return;
        dragOverSeat = null;

        var existing = targetTable.Seats[seatIndex];
        if (IsLockedHeadSeat(targetTable, seatIndex) || IsLockedHeadGuest(existing))
        {
            ShowToast("Bride and groom stay at the head table.", error: true);
            draggedGuest = null;
            dragSource = null;
            return;
        }

        if (dragSource.Type == "pool")
        {
            pool.RemoveAll(g => g.Id == draggedGuest.Id);
            if (existing != null) pool.Add(existing);
        }
        else
        {
            var srcTable = tables.FirstOrDefault(t => t.Id == dragSource.TableId);
            if (srcTable != null)
            {
                srcTable.Seats[dragSource.SeatIndex] = existing;
            }
        }

        targetTable.Seats[seatIndex] = draggedGuest;
        draggedGuest = null;
        dragSource = null;
    }

    void DropOnPool()
    {
        dragOverPool = false;
        if (draggedGuest == null || dragSource == null) return;
        if (IsLockedHeadGuest(draggedGuest))
        {
            draggedGuest = null;
            dragSource = null;
            ShowToast("Bride and groom stay at the head table.", error: true);
            return;
        }
        if (dragSource.Type == "pool") { draggedGuest = null; dragSource = null; return; }

        var srcTable = tables.FirstOrDefault(t => t.Id == dragSource.TableId);
        if (srcTable != null)
            srcTable.Seats[dragSource.SeatIndex] = null;

        if (!pool.Any(g => g.Id == draggedGuest.Id))
            pool.Add(draggedGuest);

        draggedGuest = null;
        dragSource = null;
    }

    void RemoveFromSeat(EventTable table, int idx)
    {
        var g = table.Seats[idx];
        if (g == null) return;
        if (IsLockedHeadSeat(table, idx) || IsLockedHeadGuest(g))
        {
            ShowToast("Bride and groom stay at the head table.", error: true);
            return;
        }
        table.Seats[idx] = null;
        pool.Add(g);
    }

    void CloseAddGuest()
    {
        addGuestOpen = false;
        addGuestError = "";
        addGuestFieldErrors.Clear();
        dupWarning = "";
        ng_FirstName = ng_LastName = ng_Email = ng_Phone = "";
        ng_Group = "friends";
        ng_AssignTo = "pool";
    }

    void AddGuest()
    {
        addGuestError = "";
        addGuestFieldErrors.Clear();
        dupWarning = "";

        if (string.IsNullOrWhiteSpace(ng_FirstName) || string.IsNullOrWhiteSpace(ng_LastName))
        {
            if (string.IsNullOrWhiteSpace(ng_FirstName)) addGuestFieldErrors["FirstName"] = "First name is required.";
            if (string.IsNullOrWhiteSpace(ng_LastName)) addGuestFieldErrors["LastName"] = "Last name is required.";
        }

        var allGuests = AllGuests().ToList();
        var dupByEmail = !string.IsNullOrWhiteSpace(ng_Email) &&
                         allGuests.Any(g => !string.IsNullOrWhiteSpace(g.Email) &&
                                            g.Email.Trim().ToLower() == ng_Email.Trim().ToLower());
        var dupByPhone = !string.IsNullOrWhiteSpace(ng_Phone) &&
                         allGuests.Any(g => !string.IsNullOrWhiteSpace(g.Phone) &&
                                            g.Phone.Trim() == ng_Phone.Trim());

        if (!string.IsNullOrWhiteSpace(ng_Email) && !ng_Email.Contains('@'))
            addGuestFieldErrors["Email"] = "Enter a valid email address.";
        if (dupByEmail)
            addGuestFieldErrors["Email"] = "A guest with this email already exists.";
        if (dupByPhone)
            addGuestFieldErrors["Phone"] = "A guest with this phone number already exists.";
        if (addGuestFieldErrors.Count > 0) { addGuestError = "Please fix the highlighted fields."; return; }

        var sameName = allGuests.Where(g =>
            g.FirstName.Trim().ToLower() == ng_FirstName.Trim().ToLower() &&
            g.LastName.Trim().ToLower() == ng_LastName.Trim().ToLower()).ToList();

        int dupIdx = 0;
        if (sameName.Count > 0)
        {
            dupIdx = sameName.Count + 1;
            if (sameName[0].DupIndex == 0)
                sameName[0].DupIndex = 1;
            dupWarning = $"Another guest named \"{ng_FirstName} {ng_LastName}\" already exists. " +
                         $"This one will be shown as \"{ng_FirstName} {ng_LastName} #{dupIdx}\".";
        }

        var guest = new TableGuest
        {
            Id = (int)(DateTime.UtcNow.Ticks % int.MaxValue),
            FirstName = ng_FirstName.Trim(),
            LastName = ng_LastName.Trim(),
            Group = ng_Group,
            Email = ng_Email.Trim(),
            Phone = ng_Phone.Trim(),
            DupIndex = dupIdx,
        };

        if (ng_AssignTo == "pool")
        {
            pool.Add(guest);
        }
        else if (int.TryParse(ng_AssignTo, out var tableId))
        {
            var tgt = tables.FirstOrDefault(t => t.Id == tableId);
            var firstEmpty = tgt?.Seats.FindIndex(s => s == null) ?? -1;
            if (firstEmpty >= 0)
                tgt!.Seats[firstEmpty] = guest;
            else
            { pool.Add(guest); ShowToast("Table full — added to pool instead.", error: true); }
        }

        if (string.IsNullOrEmpty(dupWarning))
        {
            CloseAddGuest();
            ShowToast("Guest added!");
        }
        else
        {
            ng_FirstName = ng_LastName = ng_Email = ng_Phone = "";
            ng_Group = "friends";
            ng_AssignTo = "pool";
            ShowToast($"Guest added as #{dupIdx}.");
        }
    }

    void RemoveFromPool(int id)
    {
        OpenDeleteConfirm("Remove guest?", "Remove this guest from the table plan?", "Remove guest", "pool", id);
    }

    void AddTable()
    {
        var roundTables = tables.Where(t => !t.IsHeadTable).ToList();
        var newId = tables.Count > 0 ? tables.Max(t => t.Id) + 1 : 1;
        var newCount = roundTables.Count + 1;
        var headCap = tables.FirstOrDefault(t => t.IsHeadTable)?.Capacity ?? 0;
        var guestsToSeat = Math.Max(0, totalGuests - headCap);
        int idealCap = newCount > 0
            ? (int)Math.Ceiling((double)guestsToSeat / newCount)
            : 6;

        idealCap = Math.Clamp(idealCap, 2, 10);

        foreach (var tbl in roundTables)
        {
            var currentFilled = tbl.Seats.Count(s => s != null);
            var newCap = Math.Max(idealCap, currentFilled);
            newCap = Math.Clamp(newCap, 2, 10);

            if (newCap > tbl.Capacity)
            {
                while (tbl.Seats.Count < newCap) tbl.Seats.Add(null);
            }
            else if (newCap < tbl.Capacity)
            {
                for (int i = tbl.Seats.Count - 1; i >= newCap; i--)
                {
                    if (tbl.Seats[i] != null) pool.Add(tbl.Seats[i]!);
                    tbl.Seats.RemoveAt(i);
                }
            }
            tbl.Capacity = tbl.Seats.Count;
        }

        tables.Add(MakeTable(newId, $"Table {newCount}", idealCap));
        ShowToast($"Table added — {newCount} tables, ~{idealCap} seats each.");
    }

    void ResizeTable(int id, int delta)
    {
        var tbl = tables.FirstOrDefault(t => t.Id == id);
        if (tbl == null || tbl.IsHeadTable) return;

        var newCap = Math.Clamp(tbl.Capacity + delta, 2, 10);
        if (newCap == tbl.Capacity) return;

        if (delta < 0)
        {
            var last = tbl.Seats[newCap];
            if (last != null) pool.Add(last);
            tbl.Seats.RemoveAt(newCap);
        }
        else
        {
            tbl.Seats.Add(null);
        }

        tbl.Capacity = newCap;
    }

    void ResizeTable(TableResizeRequest request) =>
        ResizeTable(request.TableId, request.Delta);

    void RemoveTable(int id)
    {
        var tbl = tables.FirstOrDefault(t => t.Id == id);
        if (tbl == null || tbl.IsHeadTable) return;
        OpenDeleteConfirm("Delete table?", "Delete this table? Seated guests will be returned to the pool.", "Delete table", "table", id);
    }

    void OpenDeleteConfirm(string title, string message, string confirmText, string type, int id)
    {
        confirmDeleteTitle = title;
        confirmDeleteMessage = message;
        confirmDeleteText = confirmText;
        pendingDeleteType = type;
        pendingDeleteId = id;
        confirmDeleteOpen = true;
    }

    void ConfirmDelete()
    {
        if (pendingDeleteType == "pool")
        {
            pool.RemoveAll(g => g.Id == pendingDeleteId);
            ShowToast("Guest removed.");
        }
        else if (pendingDeleteType == "table")
        {
            var tbl = tables.FirstOrDefault(t => t.Id == pendingDeleteId);
            if (tbl != null && !tbl.IsHeadTable)
            {
                pool.AddRange(tbl.Seats.Where(s => s != null).Cast<TableGuest>());
                tables.Remove(tbl);
                ShowToast("Table removed, guests returned to pool.");
            }
        }

        confirmDeleteOpen = false;
    }

    int seatedCount => tables.Sum(t => t.Seats.Count(s => s != null));
    int totalGuests => pool.Count + seatedCount;
    int totalSeats => tables.Sum(t => t.Capacity);

    async Task DownloadTemplate()
    {
        var csv = "FirstName,LastName,Group,Email,Phone\n" +
                  "Maria,Ionescu,family,maria@email.com,+40721000001\n" +
                  "Andrei,Pop,friends,,\n";
        var b64 = Convert.ToBase64String(Encoding.UTF8.GetBytes(csv));
        await JS.InvokeVoidAsync("eval",
            $"var a=document.createElement('a');a.href='data:text/csv;base64,{b64}';a.download='guests_template.csv';a.click()");
        csvGuideOpen = false;
        ShowToast("Template downloaded!");
    }

    async Task ExportCSV()
    {
        var sb = new StringBuilder();
        sb.AppendLine("FirstName,LastName,Group,Email,Phone,Table,Seat");
        foreach (var t in tables)
            for (int i = 0; i < t.Seats.Count; i++)
                if (t.Seats[i] is { } g)
                    sb.AppendLine($"{g.FirstName},{g.LastName},{g.Group},{g.Email},{g.Phone},{t.Name},Seat {i + 1}");
        foreach (var g in pool)
            sb.AppendLine($"{g.FirstName},{g.LastName},{g.Group},{g.Email},{g.Phone},Unassigned,");

        var b64 = Convert.ToBase64String(Encoding.UTF8.GetBytes(sb.ToString()));
        await JS.InvokeVoidAsync("eval",
            $"var a=document.createElement('a');a.href='data:text/csv;base64,{b64}';a.download='seating_chart.csv';a.click()");
        ShowToast("Seating chart exported!");
    }

    async Task ImportCSV(InputFileChangeEventArgs e)
    {
        using var reader = new System.IO.StreamReader(e.File.OpenReadStream());
        var content = await reader.ReadToEndAsync();

        var result = TableCsvImport.Parse(content, AllGuests());
        pool.AddRange(result.Guests);
        csvImportResult = new CsvImportResult(result.Message, result.HasWarning);
        dragActive = false;
        ShowToast(result.Message, error: result.Skipped > 0 && result.Imported == 0);
    }

    IEnumerable<TableGuest> AllGuests() =>
        pool.Concat(tables.SelectMany(t => t.Seats.Where(s => s != null).Cast<TableGuest>()));

    static bool IsLockedHeadGuest(TableGuest? guest) =>
        guest?.Id is -1 or -2;

    static bool IsLockedHeadSeat(EventTable table, int seatIndex) =>
        table.IsHeadTable && seatIndex is 0 or 1;

    RenderFragment RenderSeat(TableGuest? guest, EventTable table, int idx, string? label) =>
    @<div class="seat-wrap @(dragOverSeat == $"{table.Id}-{idx}" ? "seat-wrap-over" : "")"
          @ondragover:preventDefault="@(!IsLockedHeadSeat(table, idx))"
          @ondragover="@((e) => { if (!IsLockedHeadSeat(table, idx)) dragOverSeat = $"{table.Id}-{idx}"; })"
          @ondragleave="@((e) => dragOverSeat = null)"
          @ondrop="@((e) => { DropOnSeat(table, idx); dragOverSeat = null; })">
        @if (guest != null)
        {
            var g = guest;
            var isLocked = IsLockedHeadGuest(g);
            var col = GroupDefs[g.Group];
            var title = $"{g.FirstName} {g.LastName}{(g.DupIndex > 0 ? $" #{g.DupIndex}" : "")} — {label ?? $"Seat {idx + 1}"}";
            <div class="seat-guest @(dragOverSeat == $"{table.Id}-{idx}" ? "seat-guest-over" : "")"
                 style="background:linear-gradient(135deg,@col.SeatFrom,@col.SeatTo);box-shadow:0 2px 8px rgba(0,0,0,.2);"
                 title="@title"
                 draggable="@(!isLocked)"
                 @ondragstart="@(() => StartDrag(g, new DragSource { Type = "table", TableId = table.Id, SeatIndex = idx }))"
                 @ondragend="@(() => draggedGuest = null)">
                @TableDisplay.Initials(g)
                @if (g.DupIndex > 0)
                {
                    <span class="dup-badge">#@g.DupIndex</span>
                }
            </div>
            @if (!isLocked)
            {
                <button class="seat-remove" title="Return to pool"
                        @onclick="@(() => RemoveFromSeat(table, idx))"
                        @onclick:stopPropagation="true">
                    @SvgIcons.XSmall
                </button>
            }
        }
        else
        {
            var isLockedSeat = IsLockedHeadSeat(table, idx);
            <div class="seat-empty @(dragOverSeat == $"{table.Id}-{idx}" ? "seat-empty-over" : "") @(isLockedSeat ? "seat-empty-locked" : "seat-empty-clickable")"
                 title="@(label != null ? label : $"Seat {idx + 1}") — click to assign or drop a guest"
                 @onclick="@(() => { if (!isLockedSeat) OpenSeatPicker(table, idx); })"
                 @onclick:stopPropagation="true">
                <span class="seat-empty-num">@(label != null ? label.Split(' ').Select(w => w[0].ToString()).Aggregate((a, b) => a + b) : (idx + 1).ToString())</span>
                @if (!isLockedSeat)
                {
                    <span class="seat-empty-plus">+</span>
                }
            </div>
        }
    </div>;

    void ShowToast(string msg, bool error = false)
    {
        toastMsg = msg;
        toastError = error;
        toastTimer?.Dispose();
        toastTimer = new System.Timers.Timer(3200);
        toastTimer.Elapsed += async (_, _) =>
        {
            toastMsg = "";
            toastTimer?.Dispose();
            await InvokeAsync(StateHasChanged);
        };
        toastTimer.AutoReset = false;
        toastTimer.Start();
    }

    public void Dispose() => toastTimer?.Dispose();
}
