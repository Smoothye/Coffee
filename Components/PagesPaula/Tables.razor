    async Task ExportCSV()
    {
        var sb = new StringBuilder();
        sb.AppendLine("FirstName,LastName,Group,Email,Phone,PlusOne,Table,Seat");

        foreach (var t in tables)
        {
            for (int i = 0; i < t.Seats.Count; i++)
            {
                if (t.Seats[i] is { } g)
                {
                    sb.AppendLine($"{g.FirstName},{g.LastName},{g.Group},{g.Email},{g.Phone},{g.PlusOne},{t.Name},Seat {i + 1}");
                }
            }
        }

        foreach (var g in pool)
        {
            sb.AppendLine($"{g.FirstName},{g.LastName},{g.Group},{g.Email},{g.Phone},{g.PlusOne},Unassigned,");
        }

        var b64 = Convert.ToBase64String(Encoding.UTF8.GetBytes(sb.ToString()));
        await JS.InvokeVoidAsync("eval",
            $"var a=document.createElement('a');a.href='data:text/csv;base64,{b64}';a.download='seating_chart.csv';a.click()");

        ShowToast("Seating chart exported!");
    }

    async Task ImportCSV(InputFileChangeEventArgs e)
    {
        using var reader = new System.IO.StreamReader(e.File.OpenReadStream());
        var content = await reader.ReadToEndAsync();

        var result = TableCsvImport.Parse(content, AllGuests());
        try
        {
            var created = await Api.CreateGuestsBulkAsync(EventId, result.Guests.Select(ToCreateDto));
            if (created != null)
                pool.AddRange(created.Guests.Select(ToTableGuest));
        }
        catch (Exception ex)
        {
            csvImportResult = new CsvImportResult($"Could not import guests: {ex.Message}", true);
            dragActive = false;
            ShowToast(csvImportResult.Message, error: true);
            return;
        }

        csvImportResult = new CsvImportResult(result.Message, result.HasWarning);
        dragActive = false;
        ShowToast(result.Message, error: result.Skipped > 0 && result.Imported == 0);
    }

    IEnumerable<TableGuest> AllGuests() =>
        pool.Concat(tables.SelectMany(t => t.Seats.Where(s => s != null).Cast<TableGuest>()));

    static string CoupleDisplayName(string? name, string fallback) =>
        string.IsNullOrWhiteSpace(name) ? fallback : name.Trim();

    static bool IsCoupleGuest(GuestDto guest) =>
        guest.Notes?.StartsWith(CoupleNotePrefix, StringComparison.OrdinalIgnoreCase) == true;

    static int ReadGodparentCount(string? notes)
    {
        if (string.IsNullOrWhiteSpace(notes))
            return 2;

        var start = notes.IndexOf(HeadConfigPrefix, StringComparison.OrdinalIgnoreCase);
        if (start < 0)
            return 2;

        start += HeadConfigPrefix.Length;
        var end = notes.IndexOf(HeadConfigSuffix, start, StringComparison.OrdinalIgnoreCase);
        if (end < 0)
            return 2;

        return int.TryParse(notes[start..end], out var count)
            ? Math.Clamp(count, 1, 4)
            : 2;
    }

    static string? WithHeadConfig(string? notes, int godparentCount)
    {
        var cleaned = RemoveHeadConfig(notes).Trim();
        var marker = $"{HeadConfigPrefix}{Math.Clamp(godparentCount, 1, 4)}{HeadConfigSuffix}";
        var next = string.IsNullOrWhiteSpace(cleaned) ? marker : $"{cleaned} {marker}";
        return next.Length <= 256 ? next : marker;
    }

    static string RemoveHeadConfig(string? notes)
    {
        if (string.IsNullOrWhiteSpace(notes))
            return "";

        var start = notes.IndexOf(HeadConfigPrefix, StringComparison.OrdinalIgnoreCase);
        if (start < 0)
            return notes;

        var end = notes.IndexOf(HeadConfigSuffix, start, StringComparison.OrdinalIgnoreCase);
        if (end < 0)
            return notes[..start];

        return (notes[..start] + notes[(end + HeadConfigSuffix.Length)..]).Trim();
    }

    static bool IsLockedHeadGuest(TableGuest? guest) =>
        guest?.Id is -1 or -2;

    int BrideSeatIndex() => Math.Max(0, godparentCouples);

    int GroomSeatIndex() => Math.Max(1, godparentCouples + 1);

    bool IsCoupleSeat(int seatIndex) =>
        seatIndex == BrideSeatIndex() || seatIndex == GroomSeatIndex();

    bool IsLockedHeadSeat(EventTable table, int seatIndex) =>
        table.IsHeadTable && IsCoupleSeat(seatIndex);

    bool IsLockedHeadSource(DragSource? source) =>
        source?.Type == "table" &&
        tables.FirstOrDefault(t => t.Id == source.TableId)?.IsHeadTable == true &&
        headTableLocked;

    RenderFragment RenderSeat(TableGuest? guest, EventTable table, int idx, string? label) =>
    @<div class="seat-wrap @(dragOverSeat == $"{table.Id}-{idx}" ? "seat-wrap-over" : "")"
          @ondragover:preventDefault="@(!IsLockedHeadSeat(table, idx))"
          @ondragover="@((e) => { if (!IsLockedHeadSeat(table, idx)) dragOverSeat = $"{table.Id}-{idx}"; })"
          @ondragleave="@((e) => dragOverSeat = null)"
          @ondrop="@(async (e) => { await DropOnSeat(table, idx); dragOverSeat = null; })">
        @if (guest != null)
        {
            var g = guest;
            var isCouple = IsLockedHeadGuest(g);
            var isHeadLocked = headTableLocked && table.IsHeadTable;
            var isLocked = isCouple || isHeadLocked;
            var col = GroupDefs[g.Group];
            var title = $"{g.FirstName} {g.LastName}{(g.DupIndex > 0 ? $" #{g.DupIndex}" : "")} - {label ?? $"Seat {idx + 1}"}";
            <div class="seat-guest @(isCouple ? "seat-guest-couple" : isHeadLocked ? "seat-guest-head-locked" : "") @(dragOverSeat == $"{table.Id}-{idx}" ? "seat-guest-over" : "")"
                 style="background:linear-gradient(135deg,@col.SeatFrom,@col.SeatTo);box-shadow:0 2px 8px rgba(0,0,0,.2);"
                 title="@title"
                 draggable="@(!isLocked)"
                 @ondragstart="@(() => StartDrag(g, new DragSource { Type = "table", TableId = table.Id, SeatIndex = idx }))"
                 @ondragend="@(() => draggedGuest = null)">
                @TableDisplay.Initials(g)
                @if (g.DupIndex > 0)
                {
                    <span class="dup-badge">#@g.DupIndex</span>
                }
            </div>
            @if (!isLocked)
            {
                <button class="seat-remove" title="Return to pool"
                        @onclick="@(() => RemoveFromSeat(table, idx))"
                        @onclick:stopPropagation="true">
                    @SvgIcons.XSmall
                </button>
            }
        }
        else
        {
            var isLockedSeat = IsLockedHeadSeat(table, idx);
            <div class="seat-empty @(dragOverSeat == $"{table.Id}-{idx}" ? "seat-empty-over" : "") @(isLockedSeat ? "seat-empty-locked" : "seat-empty-clickable")"
                 title="@(label != null ? label : $"Seat {idx + 1}") - click to assign or drop a guest"
                 @onclick="@(() => { if (!isLockedSeat) OpenSeatPicker(table, idx); })"
                 @onclick:stopPropagation="true">
                <span class="seat-empty-num">@(label != null ? label.Split(' ').Select(w => w[0].ToString()).Aggregate((a, b) => a + b) : (idx + 1).ToString())</span>
                @if (!isLockedSeat)
                {
                    <span class="seat-empty-plus">+</span>
                }
            </div>
        }
    </div>;

    void ShowToast(string msg, bool error = false)
    {
        toastMsg = msg;
        toastError = error;
        toastTimer?.Dispose();
        toastTimer = new System.Timers.Timer(3200);
        toastTimer.Elapsed += async (_, _) =>
        {
            toastMsg = "";
            toastTimer?.Dispose();
            await InvokeAsync(StateHasChanged);
        };
        toastTimer.AutoReset = false;
        toastTimer.Start();
    }

    public void Dispose() => toastTimer?.Dispose();
}


