@page "/tables"
@page "/tables/{EventId:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@layout PaulaLayout
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject WeddingPlannerApp.Services.WeddingApiClient Api
@using System.Text
@using Microsoft.AspNetCore.Components.Authorization
@using WeddingPlannerApp.DTOs.Event
@using WeddingPlannerApp.DTOs.Guest
@using WeddingPlannerApp.Models
@using WeddingPlannerApp.Components.PagesPaula.TableComponents
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable

<PageNav Title="Table Plan"
         Subtitle="Drag guests to seats"
         IconSvg="@SvgIcons.TablesNav" />

@if (!string.IsNullOrEmpty(toastMsg))
{
    <div class="toast @(toastError ? "toast-error" : "toast-success")">
        @(toastError ? SvgIcons.AlertCircle : SvgIcons.CheckCircle)
        @toastMsg
    </div>
}

<CsvGuideModal IsOpen="csvGuideOpen"
               Title="Import Guests"
               AcceptedTitle="Accepted formats"
               Columns="tableCsvColumns"
               OnClose="@CloseCsvGuide">
    <LeftFooter>
        <div class="csv-rules">
            <p class="csv-rules-title">@SvgIcons.AlertCircle Duplicate rules</p>
            <ul class="csv-rules-list">
                <li>Same <strong>email</strong> or <strong>phone</strong> &rarr; skipped</li>
                <li>Same <strong>full name</strong> &rarr; allowed (shown as duplicate)</li>
                <li>Invalid <strong>Group</strong> &rarr; defaults to <span class="csv-tag csv-other">other</span></li>
            </ul>
        </div>
        <button class="btn-outline" style="margin-top:.75rem;width:100%;justify-content:center;" @onclick="DownloadTemplate">
            @SvgIcons.Download Download blank template
        </button>
    </LeftFooter>
    <UploadContent>
        <p class="csv-section-title">Upload file</p>
        <div class="csv-dropzone @(dragActive ? "csv-dropzone-active" : "")"
             @ondragenter="@((e) => dragActive = true)"
             @ondragleave="@((e) => dragActive = false)"
             @ondragover:preventDefault="true"
             @ondragover="@((e) => dragActive = true)">
            <div class="csv-drop-inner">
                @if (csvImportResult == null)
                {
                    <div class="csv-drop-icon">@SvgIcons.UploadCloud</div>
                    <p class="csv-drop-title">Drag &amp; drop your .csv here</p>
                    <p class="csv-drop-sub">or</p>
                }
                else
                {
                    <div class="csv-drop-icon @(csvImportResult.HasWarning ? "icon-warn" : "icon-ok")">
                        @(csvImportResult.HasWarning ? SvgIcons.AlertCircle : SvgIcons.CheckCircle)
                    </div>
                    <p class="csv-drop-title">@csvImportResult.Message</p>
                    <p class="csv-drop-sub">Upload another file?</p>
                }
                <label class="btn-add" style="cursor:pointer;margin-top:.5rem;">
                    @SvgIcons.Upload Browse file
                    <InputFile OnChange="ImportCSV" accept=".csv" style="display:none;" />
                </label>
                <p class="csv-accepted-note">Accepted: <strong>.csv</strong> only</p>
            </div>
        </div>
        @if (csvImportResult != null)
        {
            <button class="btn-add-guest" style="margin-top:.75rem;" @onclick="CloseCsvGuide">
                @SvgIcons.CheckSmall Done - View Tables
            </button>
        }
    </UploadContent>
</CsvGuideModal>

<TableAddGuestModal IsOpen="addGuestOpen"
                    Tables="tables"
                    Error="@addGuestError"
                    DuplicateWarning="@dupWarning"
                    FieldErrors="@addGuestFieldErrors"
                    FirstName="@ng_FirstName"
                    FirstNameChanged="@((value) => ng_FirstName = value)"
                    LastName="@ng_LastName"
                    LastNameChanged="@((value) => ng_LastName = value)"
                    Email="@ng_Email"
                    EmailChanged="@((value) => ng_Email = value)"
                    Phone="@ng_Phone"
                    PhoneChanged="@((value) => ng_Phone = value)"
                    Group="@ng_Group"
                    GroupChanged="@((value) => ng_Group = value)"
                    AssignTo="@ng_AssignTo"
                    AssignToChanged="@((value) => ng_AssignTo = value)"
                    OnClose="CloseAddGuest"
                    OnAdd="AddGuest" />

<TableHeadConfigModal IsOpen="headConfigOpen"
                      BrideName="@pendingBrideName"
                      BrideNameChanged="@((value) => pendingBrideName = value)"
                      GroomName="@pendingGroomName"
                      GroomNameChanged="@((value) => pendingGroomName = value)"
                      GodparentCount="@pendingGodparentCount"
                      GodparentCountChanged="@((value) => pendingGodparentCount = value)"
                      OnClose="@(() => headConfigOpen = false)"
                      OnApply="ApplyHeadConfig" />

<TableSeatPickerModal IsOpen="@(seatPickerOpen && pickerTable != null)"
                      Title="@SeatPickerTitle"
                      Guests="PickerGuests().ToList()"
                      SeatedGuestIds="SeatedGuestIds"
                      Groups="GroupDefs"
                      Search="@pickerSearch"
                      SearchChanged="@((value) => pickerSearch = value)"
                      OnAssign="AssignGuestToSeat"
                      OnClose="CloseSeatPicker" />

<div class="tables-page">

    <TableSeatingCanvas Tables="tables"
                        Groups="GroupDefs"
                        HeadLabels="HeadLabels()"
                        BrideName="@brideName"
                        GroomName="@groomName"
                        GodparentCouples="@godparentCouples"
                        HeadTableLocked="@headTableLocked"
                        SeatedCount="seatedCount"
                        TotalGuests="totalGuests"
                        TotalSeats="totalSeats"
                        SeatContent="RenderSeat"
                        OnConfigureHeadTable="OpenHeadConfig"
                        OnToggleHeadLock="@(() => headTableLocked = !headTableLocked)"
                        OnCsvGuide="OpenCsvGuide"
                        OnImport="ImportCSV"
                        OnExport="ExportCSV"
                        OnAddTable="AddTable"
                        OnRemoveTable="RemoveTable"
                        OnResizeTable="ResizeTable" />

    <TableGuestPool Guests="pool"
                    Groups="GroupDefs"
                    DragOver="dragOverPool"
                    OnStartDrag="StartPoolDrag"
                    OnDragEnd="@(() => draggedGuest = null)"
                    OnDragOver="@(() => dragOverPool = true)"
                    OnDragLeave="@(() => dragOverPool = false)"
                    OnDrop="DropOnPool"
                    OnAutoArrange="AutoArrangeGuests"
                    OnRemove="RemoveFromPool" />

</div>

<ConfirmDialog IsOpen="confirmDeleteOpen"
               Title="@confirmDeleteTitle"
               Message="@confirmDeleteMessage"
               ConfirmText="@confirmDeleteText"
               OnCancel="@(() => confirmDeleteOpen = false)"
               OnConfirm="ConfirmDelete" />

@code {
    [Parameter] public int EventId { get; set; }

    static readonly CsvGuideColumn[] tableCsvColumns =
    {
        new() { Name = "FirstName", Required = true, ValidValues = "Any text" },
        new() { Name = "LastName", Required = true, ValidValues = "Any text" },
        new() { Name = "Group", ValidValues = "family, friends, colleagues, other" },
        new() { Name = "Email", ValidValues = "Duplicate check" },
        new() { Name = "Phone", ValidValues = "Duplicate check" },
        new() { Name = "Table", ValidValues = "Ignored on import" },
        new() { Name = "Seat", ValidValues = "Ignored on import" },
    };

    static readonly Dictionary<string, GroupColors> GroupDefs = new()
    {
        ["family"] = new("#fff1f2", "#fda4af", "#be123c", "#f43f5e", "#fda4af", "#fb7185"),
        ["friends"] = new("#f0fdf4", "#6ee7b7", "#065f46", "#10b981", "#6ee7b7", "#34d399"),
        ["colleagues"] = new("#f5f3ff", "#c4b5fd", "#5b21b6", "#8b5cf6", "#c4b5fd", "#a78bfa"),
        ["other"] = new("#fffbeb", "#fcd34d", "#92400e", "#f59e0b", "#fcd34d", "#fbbf24"),
    };
    const string CoupleNotePrefix = "Wedding couple:";
    const string HeadConfigPrefix = "[[head-godparents:";
    const string HeadConfigSuffix = "]]";
    int godparentCouples = 2;
    bool headTableLocked = true;
    string brideName = "Bride";
    string groomName = "Groom";
    List<EventTable> tables = new();
    List<TableGuest> pool = new();
    TableGuest? draggedGuest = null;
    DragSource? dragSource = null;
    string? dragOverSeat = null;
    bool dragOverPool = false;
    bool addGuestOpen = false;
    string addGuestError = "";
    string dupWarning = "";
    Dictionary<string, string> addGuestFieldErrors = new();
    string ng_FirstName = "";
    string ng_LastName = "";
    string ng_Email = "";
    string ng_Phone = "";
    string ng_Group = "friends";
    string ng_AssignTo = "pool";
    bool headConfigOpen = false;
    int pendingGodparentCount = 2;
    string pendingBrideName = "Bride";
    string pendingGroomName = "Groom";
    bool csvGuideOpen = false;
    bool dragActive = false;
    CsvImportResult? csvImportResult = null;
    string toastMsg = "";
    bool toastError = false;
    System.Timers.Timer? toastTimer;
    bool confirmDeleteOpen = false;
    string confirmDeleteTitle = "Delete item?";
    string confirmDeleteMessage = "";
    string confirmDeleteText = "Delete";
    string pendingDeleteType = "";
    int pendingDeleteId;
    string loadError = "";
    EventDto? currentEvent;
    bool seatPickerOpen = false;
    EventTable? pickerTable = null;
    int pickerSeatIndex = -1;
    string pickerSearch = "";

    string SeatPickerTitle
    {
        get
        {
            if (pickerTable is null)
                return "Assign guest";

            var seatLabel = pickerTable.IsHeadTable
                ? (HeadLabels().ElementAtOrDefault(pickerSeatIndex) ?? $"Seat {pickerSeatIndex + 1}")
                : $"Seat {pickerSeatIndex + 1}";

            return $"Assign to {pickerTable.Name} - {seatLabel}";
        }
    }

    IReadOnlySet<int> SeatedGuestIds =>
        tables.SelectMany(t => t.Seats)
              .Where(g => g is not null)
              .Select(g => g!.Id)
              .ToHashSet();

    void CloseCsvGuide()
    {
        csvGuideOpen = false;
        dragActive = false;
        csvImportResult = null;
    }

    void OpenCsvGuide()
    {
        csvGuideOpen = true;
        csvImportResult = null;
    }

    void OpenSeatPicker(EventTable table, int idx)
    {
        pickerTable = table;
        pickerSeatIndex = idx;
        pickerSearch = "";
        seatPickerOpen = true;
    }

    void CloseSeatPicker()
    {
        seatPickerOpen = false;
        pickerTable = null;
        pickerSeatIndex = -1;
        pickerSearch = "";
    }

    async Task AutoArrangeGuests()
    {
        var allMovableGuests = pool
            .OrderBy(g => GroupPriority(g.Group))
            .ThenBy(g => g.PlusOne)
            .ThenBy(g => g.LastName)
            .ThenBy(g => g.FirstName)
            .ToList();

        if (!allMovableGuests.Any())
        {
            ShowToast("No guests in pool to arrange.", error: true);
            return;
        }

        pool.Clear();

        foreach (var guest in allMovableGuests)
        {
            var placed = TryPlaceGuestNearSimilarGroup(guest);

            if (!placed)
            {
                pool.Add(guest);
            }
            else
            {
                await PersistGuestPlacement(guest, guest.TableId, guest.SeatNumber);
            }
        }

        ShowToast(pool.Count == 0
            ? "Guests arranged automatically!"
            : $"Guests arranged. {pool.Count} guest(s) left in pool.",
            error: pool.Count > 0);
    }

    bool TryPlaceGuestNearSimilarGroup(TableGuest guest)
    {
        var candidateTables = tables
            .Where(t => !t.IsHeadTable)
            .Select(t => new
            {
                Table = t,
                EmptySeat = t.Seats.FindIndex(s => s == null),
                SameGroupCount = t.Seats.Count(s => s?.Group == guest.Group),
                PlusOneCount = t.Seats.Count(s => s?.PlusOne == true),
                FilledCount = t.Seats.Count(s => s != null)
            })
            .Where(x => x.EmptySeat >= 0)
            .OrderByDescending(x => x.SameGroupCount)
            .ThenBy(x => guest.PlusOne ? x.PlusOneCount : 0)
            .ThenBy(x => x.FilledCount)
            .ToList();

        var bestTable = candidateTables.FirstOrDefault();

        if (bestTable == null)
            return false;

        bestTable.Table.Seats[bestTable.EmptySeat] = guest;
        guest.TableId = bestTable.Table.Id;
        guest.SeatNumber = bestTable.EmptySeat + 1;
        return true;
    }

    int GroupPriority(string group) => group switch
    {
        "family" => 1,
        "friends" => 2,
        "colleagues" => 3,
        "other" => 4,
        _ => 5
    };

    async Task AssignGuestToSeat(TableGuest guest)
    {
        if (pickerTable == null || pickerSeatIndex < 0) return;
        if (IsLockedHeadSeat(pickerTable, pickerSeatIndex))
        {
            ShowToast("Bride and groom stay at the head table.", error: true);
            CloseSeatPicker();
            return;
        }
        if (headTableLocked && pickerTable.IsHeadTable && pickerTable.Seats[pickerSeatIndex] is not null)
        {
            ShowToast("Unlock the head table before changing those seats.", error: true);
            CloseSeatPicker();
            return;
        }

        foreach (var t in tables)
        {
            for (int i = 0; i < t.Seats.Count; i++)
            {
                if (t.Seats[i]?.Id == guest.Id)
                {
                    t.Seats[i] = null;
                    goto found;
                }
            }
        }
        pool.RemoveAll(g => g.Id == guest.Id);

    found:
        pickerTable.Seats[pickerSeatIndex] = guest;
        await PersistGuestPlacement(guest, pickerTable.Id, pickerSeatIndex + 1);
        ShowToast($"{guest.FirstName} {guest.LastName} seated!");
        CloseSeatPicker();
    }

    Task PersistGuestPlacement(TableGuest guest, int? tableId, int? seatNumber)
    {
        // WeddingTable API is not exposed yet, so the visual seating plan stays local for now.
        guest.TableId = tableId;
        guest.SeatNumber = seatNumber;
        return Task.CompletedTask;
    }

    IEnumerable<TableGuest> PickerGuests()
    {
        var all = pool.Concat(
            tables.SelectMany(t => t.Seats.Where(s => s != null).Cast<TableGuest>())
        ).Where(g => !IsLockedHeadGuest(g));
        if (!string.IsNullOrWhiteSpace(pickerSearch))
        {
            var q = pickerSearch.Trim().ToLower();
            all = all.Where(g =>
                g.FirstName.ToLower().Contains(q) ||
                g.LastName.ToLower().Contains(q) ||
                $"{g.FirstName} {g.LastName}".ToLower().Contains(q));
        }
        return all;
    }

    protected override async Task OnInitializedAsync()
    {
        BuildHeadTable();
        pool = new List<TableGuest>();
        await EnsureEventAndLoadGuests();
    }

    async Task EnsureEventAndLoadGuests()
    {
        try
        {
            if (await RedirectAdminAsync())
                return;

            var ownEvent = (await Api.GetEventsAsync()).OrderByDescending(e => e.EventId).FirstOrDefault();
            if (ownEvent is null)
            {
                loadError = "No event exists yet. Create an event first, then plan tables.";
                ShowToast(loadError, error: true);
                return;
            }

            if (EventId <= 0 || EventId != ownEvent.EventId)
            {
                EventId = ownEvent.EventId;
                Nav.NavigateTo($"/tables/{EventId}", replace: true);
                return;
            }

            currentEvent = ownEvent;
            brideName = CoupleDisplayName(ownEvent.BrideName, "Bride");
            groomName = CoupleDisplayName(ownEvent.GroomName, "Groom");
            godparentCouples = ReadGodparentCount(ownEvent.Notes);
            pendingGodparentCount = godparentCouples;
            BuildHeadTable();

            var guests = await Api.GetGuestsAsync(EventId);
            ConfigureRoundTablesForGuests(guests);
            LoadGuestsIntoPlan(guests);
        }
        catch (Exception ex)
        {
            loadError = $"Could not load table guests: {ex.Message}";
            ShowToast(loadError, error: true);
        }
    }

    void ConfigureRoundTablesForGuests(IReadOnlyList<GuestDto> guests)
    {
        var existingRoundTables = tables.Where(t => !t.IsHeadTable).ToList();
        foreach (var table in existingRoundTables)
            tables.Remove(table);

        var activeGuests = guests
            .Where(g => g.RsvpStatus != RsvpStatus.Declined)
            .Where(g => !IsCoupleGuest(g))
            .ToList();

        var assignedTableIds = activeGuests
            .Where(g => g.TableId.HasValue && g.TableId.Value > 0)
            .Select(g => g.TableId!.Value)
            .Distinct()
            .OrderBy(id => id)
            .ToList();

        if (assignedTableIds.Count > 0)
        {
            foreach (var tableId in assignedTableIds)
            {
                var assignedSeats = activeGuests
                    .Where(g => g.TableId == tableId)
                    .Select(g => g.SeatNumber ?? 0)
                    .Where(seat => seat > 0)
                    .DefaultIfEmpty(0)
                    .Max();
                var assignedCount = activeGuests.Count(g => g.TableId == tableId);
                var capacity = Math.Clamp(Math.Max(assignedSeats, assignedCount), 2, 10);
                tables.Add(MakeTable(tableId, $"Table {tables.Count(t => !t.IsHeadTable) + 1}", capacity));
            }
        }

        var unassignedGuests = activeGuests.Count(g => !g.TableId.HasValue || g.TableId < 0);
        var remainingSeats = Math.Max(0, unassignedGuests);
        while (remainingSeats > 0)
        {
            var capacity = Math.Min(8, remainingSeats);
            if (capacity < 2)
                capacity = 2;

            var newId = tables.Count > 0 ? tables.Max(t => t.Id) + 1 : 1;
            tables.Add(MakeTable(newId, $"Table {tables.Count(t => !t.IsHeadTable) + 1}", capacity));
            remainingSeats -= capacity;
        }
    }

    async Task<bool> RedirectAdminAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!authState.User.IsInRole("Admin"))
            return false;

        Nav.NavigateTo("/admin", replace: true);
        return true;
    }

    void LoadGuestsIntoPlan(IEnumerable<GuestDto> guestDtos)
    {
        pool.Clear();
        foreach (var table in tables.Where(t => !t.IsHeadTable))
        {
            for (var i = 0; i < table.Seats.Count; i++)
                table.Seats[i] = null;
        }

        foreach (var dto in guestDtos.Where(g => g.RsvpStatus != RsvpStatus.Declined && !IsCoupleGuest(g)))
        {
            var guest = ToTableGuest(dto);
            var table = dto.TableId.HasValue
                ? tables.FirstOrDefault(t => t.Id == dto.TableId.Value)
                : null;
            var seatIndex = dto.SeatNumber.GetValueOrDefault() - 1;

            if (table != null && seatIndex >= 0 && seatIndex < table.Seats.Count && table.Seats[seatIndex] == null)
            {
                table.Seats[seatIndex] = guest;
            }
            else
            {
                pool.Add(guest);
            }
        }
    }

    void BuildHeadTable()
    {
        var capacity = 2 + godparentCouples * 2;
        var existing = tables.FirstOrDefault(t => t.IsHeadTable);
        var oldSeats = existing?.Seats ?? new List<TableGuest?>();
        var movableHeadGuests = oldSeats
            .Where(g => g is not null && !IsLockedHeadGuest(g))
            .Cast<TableGuest>()
            .ToList();

        var ht = new EventTable
        {
            Id = 0,
            Name = "Head Table",
            IsHeadTable = true,
            Capacity = capacity,
            Seats = new List<TableGuest?>(Enumerable.Repeat<TableGuest?>(null, capacity))
        };

        var movableIndex = 0;
        for (int i = 0; i < capacity && movableIndex < movableHeadGuests.Count; i++)
        {
            if (IsCoupleSeat(i))
                continue;

            ht.Seats[i] = movableHeadGuests[movableIndex++];
        }

        ht.Seats[BrideSeatIndex()] = MakeGuest(-1, brideName, "", "family");
        ht.Seats[GroomSeatIndex()] = MakeGuest(-2, groomName, "", "family");

        if (existing != null)
        {
            for (; movableIndex < movableHeadGuests.Count; movableIndex++)
                pool.Add(movableHeadGuests[movableIndex]);

            tables.Remove(existing);
        }

        tables.Insert(0, ht);
    }

    static EventTable MakeTable(int id, string name, int cap) => new()
    {
        Id = id,
        Name = name,
        Capacity = cap,
        Seats = new List<TableGuest?>(Enumerable.Repeat<TableGuest?>(null, cap))
    };

    static TableGuest MakeGuest(int id, string fn, string ln, string group) =>
        new() { Id = id, FirstName = fn, LastName = ln, Group = group };

    static TableGuest ToTableGuest(GuestDto dto) => new()
    {
        Id = dto.GuestId,
        FirstName = dto.FirstName,
        LastName = dto.LastName,
        Group = dto.Group.ToString().ToLowerInvariant(),
        Email = dto.Email,
        Phone = dto.Phone ?? "",
        Age = dto.Age,
        Gender = dto.Gender?.ToString().ToLowerInvariant() ?? "",
        PlusOne = dto.HasPlusOne,
        TableId = dto.TableId,
        SeatNumber = dto.SeatNumber,
        Status = dto.RsvpStatus.ToString().ToLowerInvariant(),
        DietaryRequirements = ToDietaryValue(dto.DietaryRequirements),
        Notes = dto.Notes,
    };

    static GuestCreateDto ToCreateDto(TableGuest guest) => new()
    {
        TableId = guest.TableId,
        FirstName = guest.FirstName.Trim(),
        LastName = guest.LastName.Trim(),
        Age = guest.Age,
        Email = guest.Email.Trim(),
        Phone = string.IsNullOrWhiteSpace(guest.Phone) ? null : guest.Phone.Trim(),
        Gender = ToGender(guest.Gender),
        RsvpStatus = ToRsvpStatus(guest.Status),
        Group = ToGroup(guest.Group),
        DietaryRequirements = ToDietary(guest.DietaryRequirements),
        HasPlusOne = guest.PlusOne,
        SeatNumber = guest.SeatNumber,
        Notes = guest.Notes,
    };

    static GuestUpdateDto ToUpdateDto(TableGuest guest, int? tableId, int? seatNumber) => new()
    {
        TableId = tableId,
        FirstName = guest.FirstName.Trim(),
        LastName = guest.LastName.Trim(),
        Age = guest.Age,
        Email = guest.Email.Trim(),
        Phone = string.IsNullOrWhiteSpace(guest.Phone) ? null : guest.Phone.Trim(),
        Gender = ToGender(guest.Gender),
        RsvpStatus = ToRsvpStatus(guest.Status),
        Group = ToGroup(guest.Group),
        DietaryRequirements = ToDietary(guest.DietaryRequirements),
        HasPlusOne = guest.PlusOne,
        SeatNumber = seatNumber,
        Notes = guest.Notes,
    };

    static Gender? ToGender(string value) => value switch
    {
        "male" => Gender.Male,
        "female" => Gender.Female,
        "other" => Gender.Other,
        _ => null,
    };

    static RsvpStatus ToRsvpStatus(string value) => value switch
    {
        "confirmed" => RsvpStatus.Confirmed,
        "declined" => RsvpStatus.Declined,
        _ => RsvpStatus.Pending,
    };

    static Group ToGroup(string value) => value switch
    {
        "family" => Group.Family,
        "friends" => Group.Friends,
        "colleagues" => Group.Colleagues,
        _ => Group.Other,
    };

    static DietaryRequirements ToDietary(string value) => value switch
    {
        "standard" => DietaryRequirements.Standard,
        "casual" => DietaryRequirements.Standard,
        "vegan" => DietaryRequirements.Vegan,
        "vegetarian" => DietaryRequirements.Vegetarian,
        "fasting" => DietaryRequirements.Fasting,
        _ => DietaryRequirements.Standard,
    };

    static string ToDietaryValue(DietaryRequirements value) => value switch
    {
        DietaryRequirements.Vegan => "vegan",
        DietaryRequirements.Vegetarian => "vegetarian",
        DietaryRequirements.Fasting => "fasting",
        _ => "standard",
    };

    List<string> HeadLabels()
    {
        var labels = new List<string>();
        for (int i = godparentCouples; i >= 1; i--)
            labels.Add($"Godmother {i}");

        labels.Add(brideName);
        labels.Add(groomName);

        for (int i = 1; i <= godparentCouples; i++)
            labels.Add($"Godfather {i}");

        return labels;
    }

    void OpenHeadConfig()
    {
        pendingGodparentCount = godparentCouples;
        pendingBrideName = brideName;
        pendingGroomName = groomName;
        headConfigOpen = true;
    }

    async Task ApplyHeadConfig()
    {
        godparentCouples = pendingGodparentCount;
        brideName = string.IsNullOrWhiteSpace(pendingBrideName) ? "Bride" : pendingBrideName.Trim();
        groomName = string.IsNullOrWhiteSpace(pendingGroomName) ? "Groom" : pendingGroomName.Trim();
        BuildHeadTable();
        headConfigOpen = false;
        await SaveHeadNamesAsync();
        ShowToast($"Head table updated - {2 + godparentCouples * 2} seats total.");
    }

    async Task SaveHeadNamesAsync()
    {
        if (currentEvent is null)
            return;

        var notes = WithHeadConfig(currentEvent.Notes, godparentCouples);
        await Api.UpdateEventAsync(currentEvent.EventId, new EventUpdateDto
        {
            VenueId = currentEvent.VenueId,
            MenuIds = currentEvent.MenuIds,
            Name = currentEvent.Name,
            BrideName = brideName,
            GroomName = groomName,
            EventDate = currentEvent.EventDate,
            EstimatedGuests = currentEvent.EstimatedGuests,
            TotalBudget = currentEvent.TotalBudget,
            Notes = notes
        });

        currentEvent.BrideName = brideName;
        currentEvent.GroomName = groomName;
        currentEvent.Notes = notes;
    }

    void StartDrag(TableGuest guest, DragSource source)
    {
        if (IsLockedHeadGuest(guest) || IsLockedHeadSource(source))
        {
            draggedGuest = null;
            dragSource = null;
            return;
        }

        draggedGuest = guest;
        dragSource = source;
    }

    void StartPoolDrag(TableGuest guest) =>
        StartDrag(guest, new DragSource { Type = "pool" });

    async Task DropOnSeat(EventTable targetTable, int seatIndex)
    {
        if (draggedGuest == null || dragSource == null) return;
        dragOverSeat = null;

        var existing = targetTable.Seats[seatIndex];
        if (IsLockedHeadSeat(targetTable, seatIndex) || IsLockedHeadGuest(existing))
        {
            ShowToast("Bride and groom stay at the head table.", error: true);
            draggedGuest = null;
            dragSource = null;
            return;
        }
        if ((headTableLocked && targetTable.IsHeadTable && existing is not null) || IsLockedHeadSource(dragSource))
        {
            ShowToast("Unlock the head table before changing those seats.", error: true);
            draggedGuest = null;
            dragSource = null;
            return;
        }

        if (dragSource.Type == "pool")
        {
            pool.RemoveAll(g => g.Id == draggedGuest.Id);
            if (existing != null) pool.Add(existing);
        }
        else
        {
            var srcTable = tables.FirstOrDefault(t => t.Id == dragSource.TableId);
            if (srcTable != null)
            {
                srcTable.Seats[dragSource.SeatIndex] = existing;
            }
        }

        targetTable.Seats[seatIndex] = draggedGuest;
        await PersistGuestPlacement(draggedGuest, targetTable.Id, seatIndex + 1);
        if (existing != null)
        {
            var existingTableId = dragSource.Type == "table" ? (int?)dragSource.TableId : null;
            var existingSeatNumber = dragSource.Type == "table" ? (int?)dragSource.SeatIndex + 1 : null;
            await PersistGuestPlacement(existing, existingTableId, existingSeatNumber);
        }
        draggedGuest = null;
        dragSource = null;
    }

    async Task DropOnPool()
    {
        dragOverPool = false;
        if (draggedGuest == null || dragSource == null) return;
        if (IsLockedHeadGuest(draggedGuest))
        {
            draggedGuest = null;
            dragSource = null;
            ShowToast("Bride and groom stay at the head table.", error: true);
            return;
        }
        if (IsLockedHeadSource(dragSource))
        {
            draggedGuest = null;
            dragSource = null;
            ShowToast("Unlock the head table before changing those seats.", error: true);
            return;
        }

        if (dragSource.Type == "pool") { draggedGuest = null; dragSource = null; return; }

        var srcTable = tables.FirstOrDefault(t => t.Id == dragSource.TableId);
        if (srcTable != null)
            srcTable.Seats[dragSource.SeatIndex] = null;

        if (!pool.Any(g => g.Id == draggedGuest.Id))
            pool.Add(draggedGuest);

        await PersistGuestPlacement(draggedGuest, null, null);

        draggedGuest = null;
        dragSource = null;
    }

    async Task RemoveFromSeat(EventTable table, int idx)
    {
        var g = table.Seats[idx];
        if (g == null) return;
        if (IsLockedHeadSeat(table, idx) || IsLockedHeadGuest(g))
        {
            ShowToast("Bride and groom stay at the head table.", error: true);
            return;
        }
        if (headTableLocked && table.IsHeadTable)
        {
            ShowToast("Unlock the head table before changing those seats.", error: true);
            return;
        }

        table.Seats[idx] = null;
        pool.Add(g);
        await PersistGuestPlacement(g, null, null);
    }

    void CloseAddGuest()
    {
        addGuestOpen = false;
        addGuestError = "";
        addGuestFieldErrors.Clear();
        dupWarning = "";
        ng_FirstName = ng_LastName = ng_Email = ng_Phone = "";
        ng_Group = "friends";
        ng_AssignTo = "pool";
    }

    async Task AddGuest()
    {
        addGuestError = "";
        addGuestFieldErrors.Clear();
        dupWarning = "";

        if (string.IsNullOrWhiteSpace(ng_FirstName) || string.IsNullOrWhiteSpace(ng_LastName))
        {
            if (string.IsNullOrWhiteSpace(ng_FirstName)) addGuestFieldErrors["FirstName"] = "First name is required.";
            if (string.IsNullOrWhiteSpace(ng_LastName)) addGuestFieldErrors["LastName"] = "Last name is required.";
        }

        var allGuests = AllGuests().ToList();
        var dupByEmail = !string.IsNullOrWhiteSpace(ng_Email) &&
                         allGuests.Any(g => !string.IsNullOrWhiteSpace(g.Email) &&
                                            g.Email.Trim().ToLower() == ng_Email.Trim().ToLower());
        var dupByPhone = !string.IsNullOrWhiteSpace(ng_Phone) &&
                         allGuests.Any(g => !string.IsNullOrWhiteSpace(g.Phone) &&
                                            g.Phone.Trim() == ng_Phone.Trim());

        if (!string.IsNullOrWhiteSpace(ng_Email) && !ng_Email.Contains('@'))
            addGuestFieldErrors["Email"] = "Enter a valid email address.";
        if (dupByEmail)
            addGuestFieldErrors["Email"] = "A guest with this email already exists.";
        if (dupByPhone)
            addGuestFieldErrors["Phone"] = "A guest with this phone number already exists.";
        if (addGuestFieldErrors.Count > 0) { addGuestError = "Please fix the highlighted fields."; return; }

        var sameName = allGuests.Where(g =>
            g.FirstName.Trim().ToLower() == ng_FirstName.Trim().ToLower() &&
            g.LastName.Trim().ToLower() == ng_LastName.Trim().ToLower()).ToList();

        int dupIdx = 0;
        if (sameName.Count > 0)
        {
            dupIdx = sameName.Count + 1;
            if (sameName[0].DupIndex == 0)
                sameName[0].DupIndex = 1;
            dupWarning = $"Another guest named \"{ng_FirstName} {ng_LastName}\" already exists. " +
                         $"This one will be shown as \"{ng_FirstName} {ng_LastName} #{dupIdx}\".";
        }

        var guest = new TableGuest
        {
            FirstName = ng_FirstName.Trim(),
            LastName = ng_LastName.Trim(),
            Group = ng_Group,
            Email = ng_Email.Trim(),
            Phone = ng_Phone.Trim(),
            DupIndex = dupIdx,
        };

        if (ng_AssignTo == "pool")
        {
            guest.TableId = null;
            guest.SeatNumber = null;
        }
        else if (int.TryParse(ng_AssignTo, out var tableId))
        {
            var tgt = tables.FirstOrDefault(t => t.Id == tableId);
            var firstEmpty = tgt?.Seats.FindIndex(s => s == null) ?? -1;
            if (firstEmpty >= 0)
            {
                guest.TableId = tableId;
                guest.SeatNumber = firstEmpty + 1;
            }
            else
            {
                guest.TableId = null;
                guest.SeatNumber = null;
                ShowToast("Table full - added to pool instead.", error: true);
            }
        }

        var desiredTableId = guest.TableId;
        var desiredSeatNumber = guest.SeatNumber;
        guest.TableId = null;
        guest.SeatNumber = null;

        try
        {
            var created = await Api.CreateGuestAsync(EventId, ToCreateDto(guest));
            if (created != null)
                guest = ToTableGuest(created);
        }
        catch (Exception ex)
        {
            addGuestError = $"Could not add guest: {ex.Message}";
            return;
        }

        guest.TableId = desiredTableId;
        guest.SeatNumber = desiredSeatNumber;

        if (guest.TableId.HasValue)
        {
            var tgt = tables.FirstOrDefault(t => t.Id == guest.TableId.Value);
            var seatIndex = guest.SeatNumber.GetValueOrDefault() - 1;
            if (tgt != null && seatIndex >= 0 && seatIndex < tgt.Seats.Count && tgt.Seats[seatIndex] == null)
            {
                tgt.Seats[seatIndex] = guest;
                await PersistGuestPlacement(guest, guest.TableId, guest.SeatNumber);
            }
            else
                pool.Add(guest);
        }
        else
        {
            pool.Add(guest);
        }

        if (string.IsNullOrEmpty(dupWarning))
        {
            CloseAddGuest();
            ShowToast("Guest added!");
        }
        else
        {
            ng_FirstName = ng_LastName = ng_Email = ng_Phone = "";
            ng_Group = "friends";
            ng_AssignTo = "pool";
            ShowToast($"Guest added as #{dupIdx}.");
        }
    }

    void RemoveFromPool(int id)
    {
        OpenDeleteConfirm("Remove guest?", "Remove this guest from the table plan?", "Remove guest", "pool", id);
    }

    void AddTable()
    {
        var roundTables = tables.Where(t => !t.IsHeadTable).ToList();
        var newId = tables.Count > 0 ? tables.Max(t => t.Id) + 1 : 1;
        var newCount = roundTables.Count + 1;
        var headCap = tables.FirstOrDefault(t => t.IsHeadTable)?.Capacity ?? 0;
        var guestsToSeat = Math.Max(0, totalGuests - headCap);
        int idealCap = newCount > 0
            ? (int)Math.Ceiling((double)guestsToSeat / newCount)
            : 6;

        idealCap = Math.Clamp(idealCap, 2, 10);

        foreach (var tbl in roundTables)
        {
            var currentFilled = tbl.Seats.Count(s => s != null);
            var newCap = Math.Max(idealCap, currentFilled);
            newCap = Math.Clamp(newCap, 2, 10);

            if (newCap > tbl.Capacity)
            {
                while (tbl.Seats.Count < newCap) tbl.Seats.Add(null);
            }
            else if (newCap < tbl.Capacity)
            {
                for (int i = tbl.Seats.Count - 1; i >= newCap; i--)
                {
                    if (tbl.Seats[i] != null) pool.Add(tbl.Seats[i]!);
                    tbl.Seats.RemoveAt(i);
                }
            }
            tbl.Capacity = tbl.Seats.Count;
        }

        tables.Add(MakeTable(newId, $"Table {newCount}", idealCap));
        ShowToast($"Table added - {newCount} tables, ~{idealCap} seats each.");
    }

    void ResizeTable(int id, int delta)
    {
        var tbl = tables.FirstOrDefault(t => t.Id == id);
        if (tbl == null || tbl.IsHeadTable) return;

        var newCap = Math.Clamp(tbl.Capacity + delta, 2, 10);
        if (newCap == tbl.Capacity) return;

        if (delta < 0)
        {
            var last = tbl.Seats[newCap];
            if (last != null) pool.Add(last);
            tbl.Seats.RemoveAt(newCap);
        }
        else
        {
            tbl.Seats.Add(null);
        }

        tbl.Capacity = newCap;
    }

    void ResizeTable(TableResizeRequest request) =>
        ResizeTable(request.TableId, request.Delta);

    void RemoveTable(int id)
    {
        var tbl = tables.FirstOrDefault(t => t.Id == id);
        if (tbl == null || tbl.IsHeadTable) return;
        OpenDeleteConfirm("Delete table?", "Delete this table? Seated guests will be returned to the pool.", "Delete table", "table", id);
    }

    void OpenDeleteConfirm(string title, string message, string confirmText, string type, int id)
    {
        confirmDeleteTitle = title;
        confirmDeleteMessage = message;
        confirmDeleteText = confirmText;
        pendingDeleteType = type;
        pendingDeleteId = id;
        confirmDeleteOpen = true;
    }

    async Task ConfirmDelete()
    {
        if (pendingDeleteType == "pool")
        {
            try
            {
                await Api.DeleteGuestAsync(EventId, pendingDeleteId);
                pool.RemoveAll(g => g.Id == pendingDeleteId);
                ShowToast("Guest removed.");
            }
            catch (Exception ex)
            {
                ShowToast($"Could not remove guest: {ex.Message}", error: true);
            }
        }
        else if (pendingDeleteType == "table")
        {
            var tbl = tables.FirstOrDefault(t => t.Id == pendingDeleteId);
            if (tbl != null && !tbl.IsHeadTable)
            {
                var seatedGuests = tbl.Seats.Where(s => s != null).Cast<TableGuest>().ToList();
                foreach (var guest in seatedGuests)
                    await PersistGuestPlacement(guest, null, null);

                pool.AddRange(seatedGuests);
                tables.Remove(tbl);
                ShowToast("Table removed, guests returned to pool.");
            }
        }

        confirmDeleteOpen = false;
    }

    int seatedCount => tables.Sum(t => t.Seats.Count(s => s != null));
    int totalGuests => pool.Count + seatedCount;
    int totalSeats => tables.Sum(t => t.Capacity);

