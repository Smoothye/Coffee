@using WeddingPlannerApp.Components.LayoutPaula

<div class="toolbar guests-filter-toolbar">
    <div class="search-wrap">
        <span class="search-icon">@SvgIcons.Search</span>
        <input class="input search-input" placeholder="Search guests..."
               value="@Search"
               @oninput="HandleSearch" />
    </div>
    <label class="budget-filter-field guests-filter-field">
        <span>Group</span>
        <select class="input select-input filter-select"
                value="@Group"
                @onchange="HandleGroup">
            <option value="all">All</option>
            <option value="family">Family</option>
            <option value="friends">Friends</option>
            <option value="colleagues">Colleagues</option>
            <option value="other">Other</option>
        </select>
    </label>
    <label class="budget-filter-field guests-filter-field">
        <span>Status</span>
        <select class="input select-input filter-select"
                value="@Status"
                @onchange="HandleStatus">
            <option value="all">All</option>
            <option value="confirmed">Confirmed</option>
            <option value="pending">Pending</option>
            <option value="declined">Declined</option>
        </select>
    </label>
</div>

@code {
    [Parameter] public string Search { get; set; } = "";
    [Parameter] public EventCallback<string> SearchChanged { get; set; }
    [Parameter] public string Group { get; set; } = "all";
    [Parameter] public EventCallback<string> GroupChanged { get; set; }
    [Parameter] public string Status { get; set; } = "all";
    [Parameter] public EventCallback<string> StatusChanged { get; set; }

    Task HandleSearch(ChangeEventArgs e) => SearchChanged.InvokeAsync(e.Value?.ToString() ?? "");
    Task HandleGroup(ChangeEventArgs e) => GroupChanged.InvokeAsync(e.Value?.ToString() ?? "all");
    Task HandleStatus(ChangeEventArgs e) => StatusChanged.InvokeAsync(e.Value?.ToString() ?? "all");
}
