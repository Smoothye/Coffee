@using WeddingPlannerApp.Components.LayoutPaula
@using WeddingPlannerApp.DTOs.Guest
@using WeddingPlannerApp.Models
@using Microsoft.AspNetCore.Components.Rendering

<div class="guest-list">
    @if (!Guests.Any())
    {
        <div class="empty-state">
            <span class="empty-state-icon">@SvgIcons.UsersLarge</span>
            <p>No guests found.</p>
        </div>
    }
    else
    {
        @foreach (var guest in Guests.Where(g => !IsPlusOneGuest(g)))
        {
            var g = guest;
            var companion = FindCompanion(g.GuestId);
            <div class="guest-row-stack">
                <div class="guest-row">
                    <div class="guest-avatar">@Initials(g)</div>
                    <div class="guest-info">
                        <p class="guest-name">@g.FirstName @g.LastName</p>
                        <div class="guest-meta">
                            <span>@g.Email</span>
                            <span class="guest-tag guest-tag-group @GroupBadgeClass(g.Group)">@g.Group</span>
                            <span class="guest-tag guest-tag-menu @MenuCategoryClass(g.DietaryRequirements)">Menu: @MenuCategoryLabel(g.DietaryRequirements)</span>
                            @if (g.HasPlusOne)
                            {
                                <span class="guest-tag guest-tag-plus">Companion invited</span>
                            }
                        </div>
                    </div>
                    <div class="guest-actions">
                        @MenuSelect(g)
                        <button type="button"
                                class="plus-one-toggle-row @(g.HasPlusOne ? "plus-one-active" : "")"
                                @onclick="@(() => OnTogglePlusOne.InvokeAsync(g.GuestId))">
                            @(g.HasPlusOne ? "Remove companion" : "Add companion")
                        </button>
                        @RsvpButtons(g)
                        <button class="delete-btn" @onclick="@(() => OnRemove.InvokeAsync(g.GuestId))">@SvgIcons.Trash</button>
                    </div>
                </div>

                @if (companion is not null)
                {
                    <div class="guest-companion-row">
                        <div class="guest-companion-avatar">+1</div>
                        <div class="guest-info">
                            <p class="guest-name">Companion</p>
                            <div class="guest-meta">
                                <span>Invited with @g.FirstName @g.LastName</span>
                                <span class="guest-tag guest-tag-menu @MenuCategoryClass(companion.DietaryRequirements)">Menu: @MenuCategoryLabel(companion.DietaryRequirements)</span>
                            </div>
                        </div>
                        <div class="guest-actions">
                            @MenuSelect(companion)
                            @RsvpButtons(companion)
                            <button class="delete-btn" @onclick="@(() => OnRemove.InvokeAsync(companion.GuestId))">@SvgIcons.Trash</button>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public IReadOnlyList<GuestDto> Guests { get; set; } = Array.Empty<GuestDto>();
    [Parameter] public EventCallback<int> OnTogglePlusOne { get; set; }
    [Parameter] public EventCallback<(int Id, RsvpStatus Status)> OnSetStatus { get; set; }
    [Parameter] public EventCallback<(int Id, DietaryRequirements Dietary)> OnSetDietary { get; set; }
    [Parameter] public EventCallback<int> OnRemove { get; set; }
    [Parameter] public IReadOnlyList<GuestMenuOption> MenuOptions { get; set; } = GuestMenuOption.DefaultOptions;
    const string PlusOneNotePrefix = "Plus one for guest ";

    static string Initials(GuestDto guest)
    {
        var first = string.IsNullOrEmpty(guest.FirstName) ? "" : guest.FirstName[0].ToString();
        var last = string.IsNullOrEmpty(guest.LastName) ? "" : guest.LastName[0].ToString();
        return $"{first}{last}";
    }

    static string GroupBadgeClass(Group group) => group switch
    {
        Group.Family => "badge-family",
        Group.Friends => "badge-friends",
        Group.Colleagues => "badge-colleagues",
        _ => "badge-other",
    };

    static string MenuCategoryLabel(DietaryRequirements dietary) => dietary switch
    {
        DietaryRequirements.None => "Standard",
        DietaryRequirements.Vegan => "Vegan",
        DietaryRequirements.Vegetarian => "Vegetarian",
        DietaryRequirements.Other => "Fasting",
        _ => "Standard"
    };

    static string MenuCategoryClass(DietaryRequirements dietary) => dietary switch
    {
        DietaryRequirements.Vegan => "guest-menu-vegan",
        DietaryRequirements.Vegetarian => "guest-menu-vegetarian",
        DietaryRequirements.Other => "guest-menu-fasting",
        _ => "guest-menu-casual"
    };

    static bool IsPlusOneGuest(GuestDto guest) =>
        guest.Notes?.StartsWith(PlusOneNotePrefix, StringComparison.OrdinalIgnoreCase) == true;

    static int? PlusOneOwnerId(GuestDto guest)
    {
        if (!IsPlusOneGuest(guest))
            return null;

        var idText = guest.Notes![PlusOneNotePrefix.Length..].Trim();
        return int.TryParse(idText, out var ownerId) ? ownerId : null;
    }

    GuestDto? FindCompanion(int ownerId) =>
        Guests.FirstOrDefault(g => PlusOneOwnerId(g) == ownerId);

    RenderFragment MenuSelect(GuestDto guest) => builder =>
    {
        builder.OpenElement(0, "select");
        builder.AddAttribute(1, "class", "guest-menu-select");
        builder.AddAttribute(2, "value", guest.DietaryRequirements);
        builder.AddAttribute(3, "title", "Menu preference");
        builder.AddAttribute(4, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, e => ChangeDietary(guest.GuestId, e.Value?.ToString())));
        var seq = 5;
        foreach (var option in MenuOptions)
        {
            AddMenuOption(builder, seq, option.Value, option.Label);
            seq += 3;
        }
        builder.CloseElement();
    };

    static void AddMenuOption(RenderTreeBuilder builder, int seq, DietaryRequirements value, string label)
    {
        builder.OpenElement(seq, "option");
        builder.AddAttribute(seq + 1, "value", value);
        builder.AddContent(seq + 2, label);
        builder.CloseElement();
    }

    RenderFragment RsvpButtons(GuestDto guest) => builder =>
    {
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "rsvp-btns");
        AddRsvpButton(builder, 2, guest, RsvpStatus.Confirmed, "rsvp-confirmed", SvgIcons.Check);
        AddRsvpButton(builder, 6, guest, RsvpStatus.Pending, "rsvp-pending", SvgIcons.ClockSmall);
        AddRsvpButton(builder, 10, guest, RsvpStatus.Declined, "rsvp-declined", SvgIcons.XSmall);
        builder.CloseElement();
    };

    void AddRsvpButton(RenderTreeBuilder builder, int seq, GuestDto guest, RsvpStatus status, string className, RenderFragment icon)
    {
        builder.OpenElement(seq, "button");
        builder.AddAttribute(seq + 1, "class", $"rsvp-btn {className} {(guest.RsvpStatus == status ? "rsvp-active" : "rsvp-inactive")}");
        builder.AddAttribute(seq + 2, "onclick", EventCallback.Factory.Create(this, () => OnSetStatus.InvokeAsync((guest.GuestId, status))));
        builder.AddContent(seq + 3, icon);
        builder.CloseElement();
    }

    async Task ChangeDietary(int guestId, string? value)
    {
        if (Enum.TryParse<DietaryRequirements>(value, out var dietary))
            await OnSetDietary.InvokeAsync((guestId, dietary));
    }
}
