@using WeddingPlannerApp.Components.LayoutPaula

<div class="guest-list">
    @if (!Guests.Any())
    {
        <div class="empty-state">
            <span class="empty-state-icon">@SvgIcons.UsersLarge</span>
            <p>No guests found.</p>
        </div>
    }
    else
    {
        @foreach (var guest in Guests)
        {
            var g = guest;
            <div class="guest-row">
                <div class="guest-avatar">@Initials(g)</div>
                <div class="guest-info">
                    <p class="guest-name">@g.FirstName @g.LastName</p>
                    <div class="guest-meta">
                        <span>@g.Email</span>
                        @if (g.IsPlusOne) { <span class="badge plus-one-guest-badge">Plus one</span> }
                        @if (g.DietaryRequirements != "none") { <span class="badge badge-dietary">@g.DietaryRequirements</span> }
                    </div>
                </div>
                <div class="guest-actions">
                    <span class="badge @GroupBadgeClass(g.Group)">@g.Group</span>
                    <select class="input select-input guest-menu-select" @bind="g.MenuType">
                        @foreach (var menu in MenuOptions) { <option value="@menu.Value">@menu.Label</option> }
                    </select>
                    @if (!g.IsPlusOne)
                    {
                        <button type="button"
                                class="plus-one-toggle-row @(g.PlusOne ? "plus-one-active" : "")"
                                @onclick="@(() => OnTogglePlusOne.InvokeAsync(g.Id))">
                            @(g.PlusOne ? "Remove +1" : "Add +1")
                        </button>
                    }
                    <div class="rsvp-btns">
                        <button class="rsvp-btn rsvp-confirmed @(g.Status == "confirmed" ? "rsvp-active" : "rsvp-inactive")" @onclick="@(() => OnSetStatus.InvokeAsync((g.Id, "confirmed")))">@SvgIcons.Check</button>
                        <button class="rsvp-btn rsvp-pending @(g.Status == "pending" ? "rsvp-active" : "rsvp-inactive")" @onclick="@(() => OnSetStatus.InvokeAsync((g.Id, "pending")))">@SvgIcons.ClockSmall</button>
                        <button class="rsvp-btn rsvp-declined @(g.Status == "declined" ? "rsvp-active" : "rsvp-inactive")" @onclick="@(() => OnSetStatus.InvokeAsync((g.Id, "declined")))">@SvgIcons.XSmall</button>
                    </div>
                    <button class="delete-btn" @onclick="@(() => OnRemove.InvokeAsync(g.Id))">@SvgIcons.Trash</button>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public IReadOnlyList<GuestModel> Guests { get; set; } = Array.Empty<GuestModel>();
    [Parameter] public IReadOnlyList<MenuOption> MenuOptions { get; set; } = Array.Empty<MenuOption>();
    [Parameter] public EventCallback<int> OnTogglePlusOne { get; set; }
    [Parameter] public EventCallback<(int Id, string Status)> OnSetStatus { get; set; }
    [Parameter] public EventCallback<int> OnRemove { get; set; }

    static string Initials(GuestModel guest)
    {
        var first = string.IsNullOrEmpty(guest.FirstName) ? "" : guest.FirstName[0].ToString();
        var last = string.IsNullOrEmpty(guest.LastName) ? "" : guest.LastName[0].ToString();
        return $"{first}{last}";
    }

    static string GroupBadgeClass(string group) => group switch
    {
        "family" => "badge-family",
        "friends" => "badge-friends",
        "colleagues" => "badge-colleagues",
        _ => "badge-other",
    };
}
