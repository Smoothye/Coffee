@using WeddingPlannerApp.Components.LayoutPaula
@using WeddingPlannerApp.DTOs.Guest
@using WeddingPlannerApp.Models

<div class="guest-list">
    @if (!Guests.Any())
    {
        <div class="empty-state">
            <span class="empty-state-icon">@SvgIcons.UsersLarge</span>
            <p>No guests found.</p>
        </div>
    }
    else
    {
        @foreach (var guest in Guests)
        {
            var g = guest;
            <div class="guest-row">
                <div class="guest-avatar">@Initials(g)</div>
                <div class="guest-info">
                    <p class="guest-name">@g.FirstName @g.LastName</p>
                    <div class="guest-meta">
                        <span>@g.Email</span>
                        @if (g.DietaryRequirements != DietaryRequirements.None) { <span class="badge badge-dietary">@DietaryLabel(g.DietaryRequirements)</span> }
                    </div>
                </div>
                <div class="guest-actions">
                    <span class="badge @GroupBadgeClass(g.Group)">@g.Group</span>
                    <button type="button"
                            class="plus-one-toggle-row @(g.HasPlusOne ? "plus-one-active" : "")"
                            @onclick="@(() => OnTogglePlusOne.InvokeAsync(g.GuestId))">
                        @(g.HasPlusOne ? "Remove +1" : "Add +1")
                    </button>
                    <div class="rsvp-btns">
                        <button class="rsvp-btn rsvp-confirmed @(g.RsvpStatus == RsvpStatus.Confirmed ? "rsvp-active" : "rsvp-inactive")" @onclick="@(() => OnSetStatus.InvokeAsync((g.GuestId, RsvpStatus.Confirmed)))">@SvgIcons.Check</button>
                        <button class="rsvp-btn rsvp-pending @(g.RsvpStatus == RsvpStatus.Pending ? "rsvp-active" : "rsvp-inactive")" @onclick="@(() => OnSetStatus.InvokeAsync((g.GuestId, RsvpStatus.Pending)))">@SvgIcons.ClockSmall</button>
                        <button class="rsvp-btn rsvp-declined @(g.RsvpStatus == RsvpStatus.Declined ? "rsvp-active" : "rsvp-inactive")" @onclick="@(() => OnSetStatus.InvokeAsync((g.GuestId, RsvpStatus.Declined)))">@SvgIcons.XSmall</button>
                    </div>
                    <button class="delete-btn" @onclick="@(() => OnRemove.InvokeAsync(g.GuestId))">@SvgIcons.Trash</button>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public IReadOnlyList<GuestDto> Guests { get; set; } = Array.Empty<GuestDto>();
    [Parameter] public EventCallback<int> OnTogglePlusOne { get; set; }
    [Parameter] public EventCallback<(int Id, RsvpStatus Status)> OnSetStatus { get; set; }
    [Parameter] public EventCallback<int> OnRemove { get; set; }

    static string Initials(GuestDto guest)
    {
        var first = string.IsNullOrEmpty(guest.FirstName) ? "" : guest.FirstName[0].ToString();
        var last = string.IsNullOrEmpty(guest.LastName) ? "" : guest.LastName[0].ToString();
        return $"{first}{last}";
    }

    static string GroupBadgeClass(Group group) => group switch
    {
        Group.Family => "badge-family",
        Group.Friends => "badge-friends",
        Group.Colleagues => "badge-colleagues",
        _ => "badge-other",
    };

    static string DietaryLabel(DietaryRequirements dietary) => dietary switch
    {
        DietaryRequirements.GlutenFree => "Gluten-free",
        _ => dietary.ToString()
    };
}
