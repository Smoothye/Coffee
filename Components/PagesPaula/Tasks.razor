@page "/tasks"
@layout UserLayout
@rendermode InteractiveServer
@inject WeddingPlannerApp.Services.WeddingStateService State
@using WeddingPlannerApp.Components.LayoutPaula
@implements IDisposable

<PageNav Title="Tasks"
         Subtitle="@($"{State.Tasks.Count(t => !t.Done)} remaining · {State.Tasks.Count(t => t.Done)} done")"
         IconSvg="@SvgIcons.TasksNav" />

<div class="tasks-page">

    <div class="tasks-progress-card">
        <div class="tasks-progress-top">
            <span class="tasks-progress-label">Overall progress</span>
            <span class="tasks-progress-pct">@doneCount/@totalCount completed</span>
        </div>
        <div class="tasks-progress-bar-wrap">
            <div class="tasks-progress-bar">
                <div class="tasks-progress-fill" style="width:@progressPct%"></div>
            </div>
            <span class="tasks-pct-badge">@progressPct%</span>
        </div>
        <div class="tasks-summary-pills">
            <span class="priority-pill pill-high">
                <span class="priority-dot dot-high"></span>
                @State.Tasks.Count(t => t.Priority == "high" && !t.Done) high priority
            </span>

            <span class="priority-pill pill-medium">
                <span class="priority-dot dot-medium"></span>
                @State.Tasks.Count(t => t.Priority == "medium" && !t.Done) medium
            </span>

            <span class="priority-pill pill-low">
                <span class="priority-dot dot-low"></span>
                @State.Tasks.Count(t => t.Priority == "low" && !t.Done) low
            </span>
        </div>
    </div>

    <div class="toolbar">

        <div class="search-wrap">
            <span class="search-icon">@SvgIcons.Search</span>

            <input class="input search-input"
                   placeholder="Search tasks..."
                   @bind="searchQuery"
                   @bind:event="oninput" />
        </div>

        <select class="input select-input filter-select" @bind="activeFilter">
            @foreach (var f in filters)
            {
                <option value="@f.Key">@f.Label</option>
            }
        </select>

        <select class="input select-input filter-select" @bind="activeCat">
            <option value="">All categories</option>

            @foreach (var cat in categories)
            {
                <option value="@cat">@cat</option>
            }
        </select>

        <div class="toolbar-actions">
            <button class="btn-add" @onclick="@(() => addOpen = true)">
                @SvgIcons.Plus Add Task
            </button>
        </div>
    </div>

    <div class="task-list-wrap">

        @foreach (var task in filteredTasks)
        {
            var t = task;

            <div class="task-card
                @(t.Done ? "task-card-done" : "")
                @(t.IsUrgent ? "task-card-urgent" : "")
                @(t.IsOverdue ? "task-card-overdue" : "")
                priority-border-@t.Priority"
                 @key="t.Id">

                <button class="task-checkbox @(t.Done ? "checkbox-done" : "")"
                        @onclick="@(() => State.ToggleTask(t.Id))">

                    @if (t.Done)
                    {
                        @SvgIcons.CheckSmall
                    }
                </button>

                <div class="task-content">

                    <span class="task-title">@t.Title</span>

                    <div class="task-meta">

                        <span class="task-cat-tag">@t.Category</span>

                        @if (t.IsOverdue)
                        {
                            <span class="task-date-tag tag-overdue">
                                Overdue · @t.DueDate.ToString("MMM d")
                            </span>
                        }
                        else
                        {
                            <span class="task-date-tag @(t.IsUrgent ? "tag-urgent" : "")">
                                @t.DueDate.ToString("MMM d")
                            </span>
                        }

                    </div>
                </div>

                <span class="task-priority-badge badge-@t.Priority">
                    @(char.ToUpper(t.Priority[0]) + t.Priority[1..])
                </span>

                <button class="task-delete"
                        @onclick="@(() => State.RemoveTask(t.Id))"
                        title="Remove">

                    @SvgIcons.Trash
                </button>

            </div>
        }

        @if (!filteredTasks.Any())
        {
            <div class="tasks-empty">
                @SvgIcons.UsersLarge
                <p>No tasks here. Add one!</p>
            </div>
        }

    </div>
</div>

<ModalShell IsOpen="addOpen"
            Title="Add Task"
            OnClose="CloseAdd">

    @if (!string.IsNullOrEmpty(addError))
    {
        <div class="error-banner">@addError</div>
    }

    <div class="field">
        <label>Task title *</label>

        <input class="input"
               placeholder="e.g. Confirm florist order"
               @bind="newTitle"
               @bind:event="oninput" />
    </div>

    <div class="form-grid-2">

        <div class="field">
            <label>Category</label>

            <select class="input select-input" @bind="newCategory">
                @foreach (var c in categories)
                {
                    <option value="@c">@c</option>
                }
            </select>
        </div>

        <div class="field">
            <label>Priority</label>

            <select class="input select-input" @bind="newPriority">
                <option value="high">🔴 High</option>
                <option value="medium">🟡 Medium</option>
                <option value="low">🟢 Low</option>
            </select>
        </div>

    </div>

    <div class="field">
        <label>Due date</label>

        <input type="date"
               class="input"
               @bind="newDueDate"
               min="@DateTime.Today.ToString("yyyy-MM-dd")" />
    </div>

    <button class="btn-add-guest" @onclick="AddTask">
        @SvgIcons.Plus Add Task
    </button>

</ModalShell>

@code {

    record Filter(string Key, string Label);
    List<Filter> filters = new()
    {
    new("all",      "All"),
    new("overdue",  "Overdue"),
    new("urgent",   "Due soon"),
    new("high",     "High priority"),
    new("medium",   "Medium priority"),
    new("low",      "Low priority"),
    new("done",     "Completed"),
};

    static readonly string[] categories = {
        "Venue","Catering","Florals","Music","Photography",
        "Beauty","Invitations","Decor","Tables","Schedule","Travel","General"
    };

    string activeFilter = "all";
    string activeCat = "";
    string searchQuery = "";

    IEnumerable<WeddingPlannerApp.Services.WeddingTask> filteredTasks
    {
        get
        {
            var q = State.Tasks.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                q = q.Where(t =>
                    t.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)
                    || t.Category.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));
            }

            q = activeFilter switch
            {
                "overdue" => q.Where(t =>
                    t.IsOverdue &&
                    !t.Done),

                "urgent" => q.Where(t =>
                    t.IsUrgent &&
                    !t.IsOverdue &&
                    !t.Done),

                "high" => q.Where(t =>
                    t.Priority == "high" &&
                    !t.Done),

                "medium" => q.Where(t =>
                    t.Priority == "medium" &&
                    !t.Done),

                "low" => q.Where(t =>
                    t.Priority == "low" &&
                    !t.Done),

                "done" => q.Where(t =>
                    t.Done),

                _ => q
            };

            if (!string.IsNullOrEmpty(activeCat))
            {
                q = q.Where(t => t.Category == activeCat);
            }

            return q.OrderBy(t => t.Done)
                    .ThenBy(t => t.Priority switch
                    {
                        "high" => 0,
                        "medium" => 1,
                        _ => 2
                    })
                    .ThenBy(t => t.DueDate);
        }
    }

    int totalCount => State.Tasks.Count;
    int doneCount => State.Tasks.Count(t => t.Done);
    int progressPct => totalCount > 0
        ? doneCount * 100 / totalCount
        : 0;

    bool addOpen = false;

    string addError = "";
    string newTitle = "";

    string newCategory = "General";
    string newPriority = "medium";

    DateTime newDueDate = DateTime.Today.AddDays(7);

    void CloseAdd()
    {
        addOpen = false;
        addError = "";
        newTitle = "";

        newCategory = "General";
        newPriority = "medium";

        newDueDate = DateTime.Today.AddDays(7);
    }

    void AddTask()
    {
        addError = "";

        if (string.IsNullOrWhiteSpace(newTitle))
        {
            addError = "Title is required.";
            return;
        }

        State.AddTask(new WeddingPlannerApp.Services.WeddingTask
        {
            Title = newTitle.Trim(),
            Category = newCategory,
            Priority = newPriority,
            DueDate = newDueDate,
        });

        CloseAdd();
    }

    protected override void OnInitialized()
        => State.OnChange += Refresh;

    void Refresh()
        => InvokeAsync(StateHasChanged);

    public void Dispose()
        => State.OnChange -= Refresh;
}