@page "/tasks"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@layout PaulaLayout
@rendermode InteractiveServer
@inject WeddingPlannerApp.Services.WeddingStateService State
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@using Microsoft.AspNetCore.Components.Authorization
@using WeddingPlannerApp.Components.LayoutPaula
@using WeddingPlannerApp.Components.PagesPaula.TaskComponents
@implements IDisposable

<PageNav Title="Tasks"
         Subtitle="@($"{State.Tasks.Count(t => !t.Done)} remaining - {State.Tasks.Count(t => t.Done)} done")"
         IconSvg="@SvgIcons.TasksNav" />

<div class="tasks-page">

    <div class="tasks-progress-card">
        <div class="tasks-progress-top">
            <span class="tasks-progress-label">Overall progress</span>
            <span class="tasks-progress-pct">@doneCount/@totalCount completed</span>
        </div>
        <div class="tasks-progress-bar-wrap">
            <div class="tasks-progress-bar">
                <div class="tasks-progress-fill" style="width:@progressPct%"></div>
            </div>
            <span class="tasks-pct-badge">@progressPct%</span>
        </div>
        <div class="tasks-summary-pills">
            <span class="priority-pill pill-high">
                <span class="priority-dot dot-high"></span>
                @State.Tasks.Count(t => t.Priority == "high" && !t.Done) high priority
            </span>

            <span class="priority-pill pill-medium">
                <span class="priority-dot dot-medium"></span>
                @State.Tasks.Count(t => t.Priority == "medium" && !t.Done) medium
            </span>

            <span class="priority-pill pill-low">
                <span class="priority-dot dot-low"></span>
                @State.Tasks.Count(t => t.Priority == "low" && !t.Done) low
            </span>
        </div>
    </div>

    <div class="tasks-window">
        <div class="toolbar tasks-toolbar">

            <div class="search-wrap">
                <span class="search-icon">@SvgIcons.Search</span>

                <input class="input search-input"
                       placeholder="Search tasks..."
                       @bind="searchQuery"
                       @bind:event="oninput" />
            </div>

            <label class="budget-filter-field">
                <span>Category</span>
                <select class="input select-input filter-select" @bind="activeCat">
                    <option value="">All</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </label>

            <label class="budget-filter-field">
                <span>Status</span>
                <select class="input select-input filter-select" @bind="activeStatus">
                    @foreach (var f in statusFilters)
                    {
                        <option value="@f.Key">@f.Label</option>
                    }
                </select>
            </label>

            <div class="toolbar-actions">
                @if (HasActiveFilters)
                {
                    <button class="btn-outline" @onclick="ResetFilters">
                        Clear filters
                    </button>
                }
                <button class="btn-add" @onclick="@(() => addOpen = true)">
                    @SvgIcons.Plus Add Task
                </button>
            </div>
        </div>

        <div class="task-list-wrap">

            @foreach (var task in filteredTasks)
            {
                var t = task;

                <div class="task-card
                @(t.Done ? "task-card-done" : "")
                @(t.IsUrgent ? "task-card-urgent" : "")
                @(t.IsOverdue ? "task-card-overdue" : "")
                priority-border-@t.Priority"
                 @key="t.Id">

                    <button class="task-checkbox @(t.Done ? "checkbox-done" : "")"
                            @onclick="@(() => State.ToggleTask(t.Id))">

                        @if (t.Done)
                        {
                            @SvgIcons.CheckSmall
                        }
                    </button>

                    <div class="task-content">

                        <span class="task-title">@t.Title</span>

                        <div class="task-meta">

                            <span class="task-cat-tag">@t.Category</span>

                            @if (t.IsOverdue)
                            {
                                <span class="task-date-tag tag-overdue">
                                    Overdue - @t.DueDate.ToString("MMM d")
                                </span>
                            }
                            else
                            {
                                <span class="task-date-tag @(t.IsUrgent ? "tag-urgent" : "")">
                                    @t.DueDate.ToString("MMM d")
                                </span>
                            }

                        </div>
                    </div>

                    <span class="task-priority-badge badge-@t.Priority">
                        @(char.ToUpper(t.Priority[0]) + t.Priority[1..])
                    </span>

                    <button class="task-delete"
                            @onclick="@(() => RemoveTask(t.Id))"
                            title="Remove">

                        @SvgIcons.Trash
                    </button>

                </div>
            }

            @if (!filteredTasks.Any())
            {
                <div class="tasks-empty">
                    @SvgIcons.CheckCircleLarge
                    <p>@(HasActiveFilters ? "No tasks match these filters." : "No tasks added yet.")</p>
                    @if (!HasActiveFilters)
                    {
                        <span>Add a task when you are ready to plan the next step.</span>
                    }
                    @if (HasActiveFilters)
                    {
                        <button class="btn-outline" @onclick="ResetFilters">Clear filters</button>
                    }
                </div>
            }

        </div>
    </div>
</div>

<ModalShell IsOpen="addOpen"
            Title="Add Task"
            OnClose="CloseAdd">

    @if (!string.IsNullOrEmpty(addError))
    {
        <div class="error-banner">@addError</div>
    }

    <div class="field">
        <label>Task title *</label>

        <input class="input @(HasAddError(nameof(newTitle)) ? "field-invalid" : "")"
               placeholder="e.g. Confirm florist order"
               @bind="newTitle"
               @bind:event="oninput" />
        @AddFieldError(nameof(newTitle))
    </div>

    <div class="form-grid-2">

        <div class="field">
            <label>Category</label>

            <select class="input select-input" @bind="newCategory">
                @foreach (var c in categories)
                {
                    <option value="@c">@c</option>
                }
            </select>
        </div>

        <div class="field">
            <label>Priority</label>

            <select class="input select-input" @bind="newPriority">
                <option value="high">High</option>
                <option value="medium">Medium</option>
                <option value="low">Low</option>
            </select>
        </div>

    </div>

    <div class="field">
        <label>Due date</label>

        <input type="date"
               class="input @(HasAddError(nameof(newDueDate)) ? "field-invalid" : "")"
               @bind="newDueDate"
               min="@DateTime.Today.ToString("yyyy-MM-dd")" />
        @AddFieldError(nameof(newDueDate))
    </div>

    <button class="btn-add-guest" @onclick="AddTask">
        @SvgIcons.Plus Add Task
    </button>

</ModalShell>

<ConfirmDialog IsOpen="confirmDeleteOpen"
               Title="Delete task?"
               Message="This task will be removed from your checklist."
               ConfirmText="Delete task"
               OnCancel="@(() => confirmDeleteOpen = false)"
               OnConfirm="ConfirmRemoveTask" />

@code {

    List<TaskFilter> statusFilters = new()
    {
        new("all", "All"),
        new("open", "Open"),
        new("urgent", "Due soon"),
        new("overdue", "Overdue"),
        new("done", "Completed"),
    };

    static readonly string[] categories = {
        "General","Venue","Invitations","Catering","Vendors","Decor","Travel","Details"
    };

    string activeStatus = "all";
    string activeCat = "";
    string searchQuery = "";

    IEnumerable<WeddingPlannerApp.Services.WeddingTask> filteredTasks
    {
        get
        {
            var q = State.Tasks.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                q = q.Where(t =>
                    t.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)
                    || t.Category.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));
            }

            q = activeStatus switch
            {
                "open" => q.Where(t =>
                    !t.Done),

                "overdue" => q.Where(t =>
                    t.IsOverdue &&
                    !t.Done),

                "urgent" => q.Where(t =>
                    t.IsUrgent &&
                    !t.IsOverdue &&
                    !t.Done),

                "done" => q.Where(t =>
                    t.Done),

                _ => q
            };

            if (!string.IsNullOrEmpty(activeCat))
            {
                q = q.Where(t => t.Category == activeCat);
            }

            return q.OrderBy(t => t.Done)
                    .ThenBy(t => t.Priority switch
                    {
                        "high" => 0,
                        "medium" => 1,
                        _ => 2
                    })
                    .ThenBy(t => t.DueDate);
        }
    }

    int totalCount => State.Tasks.Count;
    int doneCount => State.Tasks.Count(t => t.Done);
    int progressPct => totalCount > 0
        ? doneCount * 100 / totalCount
        : 0;

    bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(searchQuery) ||
        !string.IsNullOrWhiteSpace(activeCat) ||
        activeStatus != "all";

    bool addOpen = false;
    bool confirmDeleteOpen = false;
    int pendingDeleteTaskId;

    string addError = "";
    Dictionary<string, string> addFieldErrors = new();
    string newTitle = "";

    string newCategory = "General";
    string newPriority = "medium";

    DateTime newDueDate = DateTime.Today.AddDays(7);

    void CloseAdd()
    {
        addOpen = false;
        addError = "";
        addFieldErrors.Clear();
        newTitle = "";

        newCategory = "General";
        newPriority = "medium";

        newDueDate = DateTime.Today.AddDays(7);
    }

    void AddTask()
    {
        addError = "";
        addFieldErrors.Clear();

        if (string.IsNullOrWhiteSpace(newTitle))
        {
            addFieldErrors[nameof(newTitle)] = "Task title is required.";
        }
        else if (newTitle.Trim().Length > 120)
        {
            addFieldErrors[nameof(newTitle)] = "Task title must be 120 characters or less.";
        }

        if (!string.IsNullOrWhiteSpace(newTitle) &&
            State.Tasks.Any(t =>
                t.Title.Trim().Equals(newTitle.Trim(), StringComparison.OrdinalIgnoreCase) &&
                t.Category == newCategory &&
                t.DueDate.Date == newDueDate.Date))
        {
            addFieldErrors[nameof(newTitle)] = "This task already exists for the selected date and category.";
        }

        if (newDueDate.Date < DateTime.Today)
        {
            addFieldErrors[nameof(newDueDate)] = "Due date cannot be in the past.";
        }

        if (!categories.Contains(newCategory))
        {
            addFieldErrors[nameof(newCategory)] = "Choose one of the available categories.";
        }

        if (newPriority is not ("low" or "medium" or "high"))
        {
            addFieldErrors[nameof(newPriority)] = "Choose one of the available priorities.";
        }

        if (addFieldErrors.Count > 0)
        {
            addError = "Please fix the highlighted fields.";
            return;
        }

        State.AddTask(new WeddingPlannerApp.Services.WeddingTask
        {
            Title = newTitle.Trim(),
            Category = newCategory,
            Priority = newPriority,
            DueDate = newDueDate,
        });

        CloseAdd();
    }

    void RemoveTask(int id)
    {
        pendingDeleteTaskId = id;
        confirmDeleteOpen = true;
    }

    void ConfirmRemoveTask()
    {
        State.RemoveTask(pendingDeleteTaskId);
        confirmDeleteOpen = false;
    }

    void ResetFilters()
    {
        searchQuery = "";
        activeCat = "";
        activeStatus = "all";
    }

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += Refresh;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.IsInRole("Admin"))
            Nav.NavigateTo("/admin", replace: true);
    }

    void Refresh()
        => InvokeAsync(StateHasChanged);

    bool HasAddError(string field) => addFieldErrors.ContainsKey(field);

    RenderFragment AddFieldError(string field) => builder =>
    {
        if (!addFieldErrors.TryGetValue(field, out var message)) return;
        builder.OpenElement(0, "p");
        builder.AddAttribute(1, "class", "field-error");
        builder.AddContent(2, message);
        builder.CloseElement();
    };

    public void Dispose()
        => State.OnChange -= Refresh;
}
