@page "/tasks"
@page "/tasks/{EventId:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@layout PaulaLayout
@rendermode InteractiveServer
@inject WeddingPlannerApp.Services.WeddingApiClient Api
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@using Microsoft.AspNetCore.Components.Authorization
@using WeddingPlannerApp.Components.LayoutPaula
@using WeddingPlannerApp.Components.PagesPaula.TaskComponents
@using WeddingPlannerApp.DTOs.Event
@using WeddingPlannerApp.DTOs.Task

<PageNav Title="Tasks"
         Subtitle="@($"{openCount} remaining - {doneCount} done")"
         IconSvg="@SvgIcons.TasksNav" />

<div class="tasks-page">

    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <div class="error-banner">@SvgIcons.AlertCircle @loadError</div>
    }

    <div class="tasks-progress-card">
        <div class="tasks-progress-top">
            <span class="tasks-progress-label">Overall progress</span>
            <span class="tasks-progress-pct">@doneCount/@totalCount completed</span>
        </div>
        <div class="tasks-progress-bar-wrap">
            <div class="tasks-progress-bar">
                <div class="tasks-progress-fill" style="width:@progressPct%"></div>
            </div>
            <span class="tasks-pct-badge">@progressPct%</span>
        </div>
        <div class="tasks-summary-pills">
            <span class="priority-pill pill-high">
                <span class="priority-dot dot-high"></span>
                @openTasks.Count(t => t.Priority == "high") high priority
            </span>

            <span class="priority-pill pill-medium">
                <span class="priority-dot dot-medium"></span>
                @openTasks.Count(t => t.Priority == "medium") medium
            </span>

            <span class="priority-pill pill-low">
                <span class="priority-dot dot-low"></span>
                @openTasks.Count(t => t.Priority == "low") low
            </span>
        </div>
    </div>

    <div class="tasks-window">
        <div class="toolbar tasks-toolbar">

            <div class="search-wrap">
                <span class="search-icon">@SvgIcons.Search</span>

                <input class="input search-input"
                       placeholder="Search tasks..."
                       @bind="searchQuery"
                       @bind:event="oninput" />
            </div>

            <label class="budget-filter-field">
                <span>Category</span>
                <select class="input select-input filter-select" @bind="activeCat">
                    <option value="">All</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </label>

            <label class="budget-filter-field">
                <span>Status</span>
                <select class="input select-input filter-select" @bind="activeStatus">
                    @foreach (var f in statusFilters)
                    {
                        <option value="@f.Key">@f.Label</option>
                    }
                </select>
            </label>

            <div class="toolbar-actions">
                @if (HasActiveFilters)
                {
                    <button class="btn-outline" @onclick="ResetFilters">
                        Clear filters
                    </button>
                }
                <button class="btn-add" @onclick="@(() => addOpen = true)">
                    @SvgIcons.Plus Add Task
                </button>
            </div>
        </div>

        <div class="task-list-wrap">
            @if (isLoading)
            {
                <div class="tasks-empty">
                    @SvgIcons.CheckCircleLarge
                    <p>Loading tasks...</p>
                </div>
            }
            else
            {
                @foreach (var task in filteredTasks)
                {
                    var t = task;

                    <div class="task-card
                    @(t.Done ? "task-card-done" : "")
                    @(t.IsUrgent ? "task-card-urgent" : "")
                    @(t.IsOverdue ? "task-card-overdue" : "")
                    priority-border-@t.Priority"
                     @key="t.Key">

                        <button class="task-checkbox @(t.Done ? "checkbox-done" : "")"
                                @onclick="@(() => ToggleTask(t))">

                            @if (t.Done)
                            {
                                @SvgIcons.CheckSmall
                            }
                        </button>

                        <div class="task-content">

                            <span class="task-title">@t.Title</span>

                            <div class="task-meta">

                                <span class="task-cat-tag">@t.Category</span>

                                @if (t.IsSystem)
                                {
                                    <span class="task-date-tag tag-urgent">
                                        Required today
                                    </span>
                                }
                                else if (t.IsOverdue)
                                {
                                    <span class="task-date-tag tag-overdue">
                                        Overdue - @t.DueDate.ToString("MMM d")
                                    </span>
                                }
                                else
                                {
                                    <span class="task-date-tag @(t.IsUrgent ? "tag-urgent" : "")">
                                        @t.DueDate.ToString("MMM d")
                                    </span>
                                }

                            </div>
                        </div>

                        <span class="task-priority-badge badge-@t.Priority">
                            @(char.ToUpper(t.Priority[0]) + t.Priority[1..])
                        </span>

                        @if (t.IsSystem)
                        {
                            <button class="btn-outline task-budget-link"
                                    @onclick="OpenBudget"
                                    title="Set budget">
                                Set budget
                            </button>
                        }
                        else
                        {
                            <button class="task-delete"
                                    @onclick="@(() => RemoveTask(t.Id))"
                                    title="Remove">

                                @SvgIcons.Trash
                            </button>
                        }

                    </div>
                }

                @if (!filteredTasks.Any())
                {
                    <div class="tasks-empty">
                        @SvgIcons.CheckCircleLarge
                        <p>@(HasActiveFilters ? "No tasks match these filters." : "No tasks added yet.")</p>
                        @if (!HasActiveFilters)
                        {
                            <span>Add a task when you are ready to plan the next step.</span>
                        }
                        @if (HasActiveFilters)
                        {
                            <button class="btn-outline" @onclick="ResetFilters">Clear filters</button>
                        }
                    </div>
                }
            }
        </div>
    </div>
</div>

<ModalShell IsOpen="addOpen"
            Title="Add Task"
            OnClose="CloseAdd">

    @if (!string.IsNullOrEmpty(addError))
    {
        <div class="error-banner">@addError</div>
    }

    <div class="field">
        <label>Task title *</label>

        <input class="input @(HasAddError(nameof(newTitle)) ? "field-invalid" : "")"
               placeholder="e.g. Confirm florist order"
               @bind="newTitle"
               @bind:event="oninput" />
        @AddFieldError(nameof(newTitle))
    </div>

    <div class="form-grid-2">

        <div class="field">
            <label>Category</label>

            <select class="input select-input" @bind="newCategory">
                @foreach (var c in categories)
                {
                    <option value="@c">@c</option>
                }
            </select>
        </div>

        <div class="field">
            <label>Priority</label>

            <select class="input select-input" @bind="newPriority">
                <option value="high">High</option>
                <option value="medium">Medium</option>
                <option value="low">Low</option>
            </select>
        </div>

    </div>

    <div class="field">
        <label>Due date</label>

        <input type="date"
               class="input @(HasAddError(nameof(newDueDate)) ? "field-invalid" : "")"
               @bind="newDueDate"
               min="@DateTime.Today.ToString("yyyy-MM-dd")" />
        @AddFieldError(nameof(newDueDate))
    </div>

    <button class="btn-add-guest" disabled="@savingTask" @onclick="AddTask">
        @SvgIcons.Plus @(savingTask ? "Adding..." : "Add Task")
    </button>

</ModalShell>

<ConfirmDialog IsOpen="confirmDeleteOpen"
               Title="Delete task?"
               Message="This task will be removed from your checklist."
               ConfirmText="Delete task"
               OnCancel="@(() => confirmDeleteOpen = false)"
               OnConfirm="ConfirmRemoveTask" />

@code {
    [Parameter] public int EventId { get; set; }

    List<TaskFilter> statusFilters = new()
    {
        new("all", "All"),
        new("open", "Open"),
        new("urgent", "Due soon"),
        new("overdue", "Overdue"),
        new("done", "Completed"),
    };

    static readonly string[] categories = {
        "General","Budget","Venue","Invitations","Catering","Vendors","Decor","Travel","Details"
    };

    readonly List<WeddingTaskDto> tasks = [];
    EventDto? currentEvent;
    bool isLoading = true;
    bool savingTask = false;
    string loadError = "";
    string activeStatus = "all";
    string activeCat = "";
    string searchQuery = "";

    IEnumerable<TaskViewModel> allTasks
    {
        get
        {
            if (budgetTask is not null)
                yield return budgetTask;

            foreach (var task in tasks)
                yield return TaskViewModel.FromDto(task);
        }
    }

    IEnumerable<TaskViewModel> openTasks => allTasks.Where(t => !t.Done);

    IEnumerable<TaskViewModel> filteredTasks
    {
        get
        {
            var q = allTasks;

            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                q = q.Where(t =>
                    t.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)
                    || t.Category.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));
            }

            q = activeStatus switch
            {
                "open" => q.Where(t => !t.Done),
                "overdue" => q.Where(t => t.IsOverdue && !t.Done),
                "urgent" => q.Where(t => t.IsUrgent && !t.IsOverdue && !t.Done),
                "done" => q.Where(t => t.Done),
                _ => q
            };

            if (!string.IsNullOrEmpty(activeCat))
            {
                q = q.Where(t => t.Category == activeCat);
            }

            return q.OrderBy(t => t.Done)
                    .ThenBy(t => t.IsSystem ? 0 : 1)
                    .ThenBy(t => PriorityOrder(t.Priority))
                    .ThenBy(t => t.DueDate);
        }
    }

    TaskViewModel? budgetTask => currentEvent is not null && currentEvent.TotalBudget <= 0
        ? new TaskViewModel(
            -1,
            "Set your wedding budget",
            "Budget",
            DateTime.Today,
            "high",
            Done: false,
            IsSystem: true)
        : null;

    int totalCount => allTasks.Count();
    int doneCount => allTasks.Count(t => t.Done);
    int openCount => allTasks.Count(t => !t.Done);
    int progressPct => totalCount > 0
        ? doneCount * 100 / totalCount
        : 0;

    bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(searchQuery) ||
        !string.IsNullOrWhiteSpace(activeCat) ||
        activeStatus != "all";

    bool addOpen = false;
    bool confirmDeleteOpen = false;
    int pendingDeleteTaskId;

    string addError = "";
    Dictionary<string, string> addFieldErrors = new();
    string newTitle = "";

    string newCategory = "General";
    string newPriority = "medium";

    DateTime newDueDate = DateTime.Today.AddDays(7);

    protected override async Task OnParametersSetAsync()
    {
        loadError = "";
        isLoading = true;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            if (authState.User.IsInRole("Admin"))
            {
                Nav.NavigateTo("/admin", replace: true);
                return;
            }

            var ownEvent = (await Api.GetEventsAsync()).OrderByDescending(e => e.EventId).FirstOrDefault();
            if (ownEvent is null)
            {
                Nav.NavigateTo("/onboarding", replace: true);
                return;
            }

            if (EventId <= 0 || EventId != ownEvent.EventId)
                EventId = ownEvent.EventId;

            currentEvent = await Api.GetEventAsync(EventId) ?? ownEvent;
            await LoadTasksAsync();
        }
        catch (Exception ex)
        {
            loadError = $"Could not load tasks: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    async Task LoadTasksAsync()
    {
        tasks.Clear();
        tasks.AddRange(await Api.GetTasksAsync(EventId));
    }

    void CloseAdd()
    {
        addOpen = false;
        addError = "";
        addFieldErrors.Clear();
        newTitle = "";

        newCategory = "General";
        newPriority = "medium";

        newDueDate = DateTime.Today.AddDays(7);
    }

    async Task AddTask()
    {
        addError = "";
        addFieldErrors.Clear();
        ValidateNewTask();

        if (addFieldErrors.Count > 0)
        {
            addError = "Please fix the highlighted fields.";
            return;
        }

        savingTask = true;
        try
        {
            var created = await Api.CreateTaskAsync(EventId, new WeddingTaskCreateDto
            {
                Title = newTitle.Trim(),
                Category = newCategory,
                Priority = newPriority,
                DueDate = newDueDate.Date
            });

            if (created is not null)
                tasks.Add(created);

            CloseAdd();
        }
        catch (Exception ex)
        {
            addError = $"Could not add task: {ex.Message}";
        }
        finally
        {
            savingTask = false;
        }
    }

    void ValidateNewTask()
    {
        if (string.IsNullOrWhiteSpace(newTitle))
        {
            addFieldErrors[nameof(newTitle)] = "Task title is required.";
        }
        else if (newTitle.Trim().Length > 120)
        {
            addFieldErrors[nameof(newTitle)] = "Task title must be 120 characters or less.";
        }

        if (!string.IsNullOrWhiteSpace(newTitle) &&
            tasks.Any(t =>
                t.Title.Trim().Equals(newTitle.Trim(), StringComparison.OrdinalIgnoreCase) &&
                t.Category == newCategory &&
                t.DueDate.Date == newDueDate.Date))
        {
            addFieldErrors[nameof(newTitle)] = "This task already exists for the selected date and category.";
        }

        if (newDueDate.Date < DateTime.Today)
        {
            addFieldErrors[nameof(newDueDate)] = "Due date cannot be in the past.";
        }

        if (!categories.Contains(newCategory))
        {
            addFieldErrors[nameof(newCategory)] = "Choose one of the available categories.";
        }

        if (newPriority is not ("low" or "medium" or "high"))
        {
            addFieldErrors[nameof(newPriority)] = "Choose one of the available priorities.";
        }
    }

    async Task ToggleTask(TaskViewModel task)
    {
        if (task.IsSystem)
        {
            OpenBudget();
            return;
        }

        var dto = tasks.FirstOrDefault(t => t.TaskId == task.Id);
        if (dto is null)
            return;

        var updated = ToUpdateDto(dto, !dto.Done);

        try
        {
            await Api.UpdateTaskAsync(EventId, dto.TaskId, updated);
            dto.Done = updated.Done;
            dto.Status = updated.Done ? "completed" : "pending";
            dto.CompletedAt = updated.Done ? DateTime.UtcNow : null;
        }
        catch (Exception ex)
        {
            loadError = $"Could not update task: {ex.Message}";
        }
    }

    void RemoveTask(int id)
    {
        pendingDeleteTaskId = id;
        confirmDeleteOpen = true;
    }

    async Task ConfirmRemoveTask()
    {
        try
        {
            await Api.DeleteTaskAsync(EventId, pendingDeleteTaskId);
            tasks.RemoveAll(t => t.TaskId == pendingDeleteTaskId);
            confirmDeleteOpen = false;
        }
        catch (Exception ex)
        {
            loadError = $"Could not delete task: {ex.Message}";
        }
    }

    void ResetFilters()
    {
        searchQuery = "";
        activeCat = "";
        activeStatus = "all";
    }

    void OpenBudget() => Nav.NavigateTo("/budget");

    bool HasAddError(string field) => addFieldErrors.ContainsKey(field);

    RenderFragment AddFieldError(string field) => builder =>
    {
        if (!addFieldErrors.TryGetValue(field, out var message)) return;
        builder.OpenElement(0, "p");
        builder.AddAttribute(1, "class", "field-error");
        builder.AddContent(2, message);
        builder.CloseElement();
    };

    static int PriorityOrder(string priority) => priority switch
    {
        "high" => 0,
        "medium" => 1,
        _ => 2
    };

    static WeddingTaskUpdateDto ToUpdateDto(WeddingTaskDto task, bool done) => new()
    {
        Title = task.Title,
        Category = task.Category,
        Priority = task.Priority,
        DueDate = task.DueDate,
        Done = done,
        Notes = task.Notes
    };

    sealed record TaskViewModel(
        int Id,
        string Title,
        string Category,
        DateTime DueDate,
        string Priority,
        bool Done,
        bool IsSystem = false)
    {
        public string Key => IsSystem ? $"system-{Id}" : Id.ToString();
        public bool IsUrgent => IsSystem || (!Done && (DueDate.Date - DateTime.Today).Days <= 14);
        public bool IsOverdue => !Done && DueDate.Date < DateTime.Today;

        public static TaskViewModel FromDto(WeddingTaskDto task) => new(
            task.TaskId,
            task.Title,
            task.Category,
            task.DueDate,
            task.Priority,
            task.Done);
    }
}
