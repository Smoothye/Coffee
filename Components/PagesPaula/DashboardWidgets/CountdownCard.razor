<div class="countdown-card">
    <div class="countdown-rings" aria-hidden="true"><span></span><span></span></div>
    <div class="countdown-hearts" aria-hidden="true">
        <svg class="countdown-heart countdown-heart-lg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78Z" />
        </svg>
        <svg class="countdown-heart countdown-heart-sm" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78Z" />
        </svg>
    </div>
    <div class="countdown-copy">
        <span class="countdown-kicker">The little countdown</span>
        <strong>@DaysUntilWedding</strong>
        <span>days until @WeddingDate.ToString("MMMM d")</span>
    </div>
    <div class="countdown-mini-grid">
        <div><strong>@WeeksUntilWedding</strong><span>weeks</span></div>
        <div><strong>@MonthsUntilWedding</strong><span>months</span></div>
        <div><strong>@WeddingDate.ToString("ddd")</strong><span>day</span></div>
    </div>
</div>

@code {
    [Parameter] public DateTime WeddingDate { get; set; }
    [Parameter] public int DaysUntilWedding { get; set; }
    [Parameter] public int WeeksUntilWedding { get; set; }
    [Parameter] public int MonthsUntilWedding { get; set; }
}
