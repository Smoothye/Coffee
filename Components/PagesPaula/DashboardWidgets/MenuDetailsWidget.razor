@using WeddingPlannerApp.Components.LayoutPaula

<div class="widget widget-menu">
    <div class="widget-head">
        <div class="widget-head-left">
            <div class="widget-icon wicon-sage">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2" /><path d="M7 2v20" /><path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7" /></svg>
            </div>
            <h3 class="widget-title">Menu &amp; Details</h3>
        </div>
        <a href="@Href" class="widget-link-icon" title="Open menu" aria-label="Open menu">@SvgIcons.ArrowRight</a>
    </div>

    @if (!string.IsNullOrEmpty(SelectedMenu))
    {
        <a href="@Href" class="menu-selected menu-selected-link" aria-label="Open selected menus">
            <div class="menu-check-icon">@SvgIcons.Check</div>
            <div><p class="menu-name">@SelectedMenu</p><p class="menu-sub">Menu packages selected</p></div>
            <span class="menu-selected-arrow">@SvgIcons.ArrowRight</span>
        </a>
        @if (MenuRows.Count > 0)
        {
            <div class="dashboard-menu-list">
                @foreach (var row in MenuRows)
                {
                    <div class="dashboard-menu-row">@row</div>
                }
                @if (MenuEstimate > 0)
                {
                    <div class="dashboard-menu-total">Estimated menu cost: $@MenuEstimate.ToString("N0")</div>
                }
            </div>
        }
    }
    else
    {
        <div class="menu-empty">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color:var(--sage-light)"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2" /><path d="M7 2v20" /><path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7" /></svg>
            <p>No menu selected yet</p>
            <a href="@Href" class="widget-link" style="font-size:.8rem;margin-top:.25rem;">Select menu</a>
        </div>
    }

    <div class="quick-details">
        <QuickDetailLink Href="@VenueHref" Label="Venue" Value="@VenueName">
            <Icon>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
            </Icon>
        </QuickDetailLink>
        <QuickDetailLink Href="@GuestsHref" Label="Expected guests" Value="@ExpectedGuests.ToString()">
            <Icon>@SvgIcons.Users</Icon>
        </QuickDetailLink>
        <QuickDetailLink Href="@TablesHref"
                         Label="Seating plan"
                         Value="@(TablesConfirmed ? "Ready" : $"{SeatedGuests}/{SeatingTotalGuests} seated")"
                         ValueClass="@(TablesConfirmed ? "qd-ok" : "qd-pending")">
            <Icon>@SvgIcons.Lock</Icon>
        </QuickDetailLink>
        <QuickDetailLink Href="@BudgetHref"
                         Label="Budget status"
                         Value="@(BudgetPercent <= 80 ? "On track" : BudgetPercent <= 100 ? "Watch it" : "Over budget")"
                         ValueClass="@(BudgetPercent <= 80 ? "qd-ok" : "qd-warn")">
            <Icon>@SvgIcons.DollarSign</Icon>
        </QuickDetailLink>
    </div>
</div>

@code {
    [Parameter] public string SelectedMenu { get; set; } = "";
    [Parameter] public IReadOnlyList<string> MenuRows { get; set; } = Array.Empty<string>();
    [Parameter] public int MenuEstimate { get; set; }
    [Parameter] public string VenueName { get; set; } = "";
    [Parameter] public int ExpectedGuests { get; set; }
    [Parameter] public int SeatedGuests { get; set; }
    [Parameter] public int SeatingTotalGuests { get; set; }
    [Parameter] public bool TablesConfirmed { get; set; }
    [Parameter] public int BudgetPercent { get; set; }
    [Parameter] public string Href { get; set; } = "/menu";
    [Parameter] public string VenueHref { get; set; } = "/venues";
    [Parameter] public string GuestsHref { get; set; } = "/guests";
    [Parameter] public string TablesHref { get; set; } = "/tables";
    [Parameter] public string BudgetHref { get; set; } = "/budget";

}
