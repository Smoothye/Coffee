    };

    protected override void OnInitialized()
    {
        State.OnChange += Refresh;
    }

    protected override async Task OnParametersSetAsync() => await LoadPageDataAsync();

    async Task LoadPageDataAsync()
    {
        isLoading = true;
        loadError = "";

        try
        {
            if (!await EnsureCurrentEventAsync())
                return;

            await LoadMenusAsync();
            selectedByType = BuildSelectedByType(eventItem?.MenuIds ?? []);
            SyncSelectedMenuState();
            await LoadGuestMenuCountsAsync();
        }
        catch (Exception ex)
        {
            loadError = $"Could not load menus: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    async Task<bool> EnsureCurrentEventAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.IsInRole("Admin"))
        {
            Nav.NavigateTo("/admin", replace: true);
            return false;
        }

        var ownEvent = (await Api.GetEventsAsync()).OrderByDescending(e => e.EventId).FirstOrDefault();
        if (ownEvent is null)
        {
            Nav.NavigateTo("/onboarding", replace: true);
            return false;
        }

        if (EventId <= 0 || EventId != ownEvent.EventId)
        {
            EventId = ownEvent.EventId;
            Nav.NavigateTo($"/menu/{EventId}", replace: true);
            return false;
        }

        eventItem = ownEvent;
        return true;
    }

    async Task LoadMenusAsync()
    {
        try
        {
            var menus = await Api.GetMenusAsync();
            if (menus.Count > 0)
            {
                packages = menus.Select(ToMenuPackage).ToList();
                activePackage = activePackage is null ? null : packages.FirstOrDefault(p => p.Id == activePackage.Id);
                activeCourse = 0;
            }
        }
        catch
        {
            // Keep the curated fallback packages if the menu API is unavailable.
        }
    }

    async Task LoadGuestMenuCountsAsync()
    {
        menuCounts = new()
        {
            ["standard"] = 0,
            ["vegetarian"] = 0,
            ["vegan"] = 0,
            ["fasting"] = 0
        };

        var eventId = EventId;
        if (eventId <= 0)
        {
            var firstEvent = (await Api.GetEventsAsync()).OrderBy(e => e.EventId).FirstOrDefault();
            eventId = firstEvent?.EventId ?? 0;
        }

        if (eventId <= 0)
            return;

        var guests = await Api.GetGuestsAsync(eventId);
        var plusOneOwnerIds = guests
            .Where(IsPlusOneGuest)
            .Select(PlusOneOwnerId)
            .Where(id => id.HasValue)
            .Select(id => id!.Value)
            .ToHashSet();

        foreach (var guest in guests.Where(guest => guest.RsvpStatus != RsvpStatus.Declined))
        {
            menuCounts[MenuTypeFor(guest.DietaryRequirements)]++;
            if (guest.HasPlusOne && !plusOneOwnerIds.Contains(guest.GuestId))
                menuCounts["standard"]++;
        }
    }

    const string PlusOneNotePrefix = "Plus one for guest ";

    static bool IsPlusOneGuest(GuestDto guest) =>
        guest.Notes?.StartsWith(PlusOneNotePrefix, StringComparison.OrdinalIgnoreCase) == true;

    static int? PlusOneOwnerId(GuestDto guest)
    {
        if (!IsPlusOneGuest(guest))
            return null;

        var idText = guest.Notes![PlusOneNotePrefix.Length..].Trim();
        return int.TryParse(idText, out var ownerId) ? ownerId : null;
    }

    static string MenuTypeFor(DietaryRequirements dietary) => dietary switch
    {
        DietaryRequirements.Vegan => "vegan",
        DietaryRequirements.Vegetarian => "vegetarian",
        DietaryRequirements.Fasting => "fasting",
        _ => "standard"
    };

    static MenuPackage ToMenuPackage(WeddingPlannerApp.Models.Menu menu)
    {
        var courses = menu.MenuItems
            .GroupBy(item => string.IsNullOrWhiteSpace(item.CourseName) ? "Items" : item.CourseName)
            .OrderBy(group => group.Min(item => item.DisplayOrder))
            .Select(group => new Course(
                group.Key,
                group
                    .OrderBy(item => item.DisplayOrder)
                    .Select(item => new WeddingPlannerApp.Components.PagesPaula.MenuComponents.MenuItem(
                        item.Name,
                        item.Description ?? "",
                        []))
                    .ToList()))
            .ToList();

        if (courses.Count == 0)
            courses.Add(new Course("Items", []));

        return new MenuPackage(
            menu.MenuId.ToString(),
            menu.Name,
            menu.DietaryType.ToString().ToLowerInvariant(),
            (int)menu.Price,
            menu.Description ?? "",
            courses);
    }

    void Refresh() => InvokeAsync(StateHasChanged);
    public void Dispose() => State.OnChange -= Refresh;
}
