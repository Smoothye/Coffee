@page "/menu"
@page "/menu/{EventId:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@layout PaulaLayout
@rendermode InteractiveServer
@inject WeddingPlannerApp.Services.WeddingStateService State
@inject WeddingPlannerApp.Services.WeddingApiClient Api
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@using System.Text.RegularExpressions
@using Microsoft.AspNetCore.Components.Authorization
@using WeddingPlannerApp.Components.LayoutPaula
@using WeddingPlannerApp.Components.PagesPaula.MenuComponents
@using WeddingPlannerApp.DTOs.Event
@using WeddingPlannerApp.DTOs.Guest
@using WeddingPlannerApp.DTOs.Menu
@using WeddingPlannerApp.Models
@using GuestGroup = WeddingPlannerApp.Models.Group
@implements IDisposable

<PageNav Title="Menu"
         Subtitle="@(string.IsNullOrEmpty(State.SelectedMenuName) ? "Choose your wedding menu package" : $"{State.SelectedMenuName} selected")"
         IconSvg="@SvgIcons.MenuNav" />

<div class="menu-page">
    <div class="menu-filter-bar">
        <span class="menu-filter-label">Filter by dietary:</span>
        @foreach (var f in dietaryFilters)
        {
            var ff = f;
            <button class="menu-diet-btn @(dietFilter == ff.Key ? "menu-diet-active" : "")"
                    @onclick="@(() => { dietFilter = ff.Key; activePackage = null; })">
                @ff.Label
            </button>
        }

        @if (selectedByType.Count > 0)
        {
            <div class="menu-selection-summary" title="@SelectionSummary">
                <span class="menu-selection-check">@SvgIcons.CheckSmall</span>
                <span class="menu-selection-copy">
                    <span class="menu-selection-label">Selected</span>
                    <strong>@SelectionSummaryCompact</strong>
                </span>
                <button class="menu-selection-clear" @onclick="ClearSelection">Clear</button>
            </div>
        }
    </div>

    <div class="menu-count-wrap">
        <div class="menu-count-grid">
            @foreach (var item in GuestMenuBreakdown)
            {
                <div class="menu-count-card count-@item.Menu">
                    <div class="menu-count-info-wrap">
                        <button type="button"
                                class="menu-count-info"
                                aria-label="@($"{DietLabel(item.Menu)} guest count information")">
                            i
                        </button>
                        <div class="menu-count-tooltip" role="tooltip">
                            Guest counts include RSVP guests, plus-ones, and the couple. Declined guests are not counted.
                        </div>
                    </div>
                    <span class="menu-count-icon diet-icon-@item.Menu">@DietIcon(item.Menu)</span>
                    <span class="menu-count-label">@DietLabel(item.Menu)</span>
                    <div class="menu-count-split">
                        <div class="menu-count-stat">
                            <strong>@item.Available</strong>
                            <span>@MenuTypeLabel(item.Available)</span>
                        </div>
                        <div class="menu-count-stat">
                            <strong>@item.Count</strong>
                            <span>@GuestNeedLabel(item.Count)</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    @if (isLoading)
    {
        <div class="empty-venues">
            <p>Loading menus...</p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(loadError))
    {
        <div class="error-banner">@SvgIcons.AlertCircle @loadError</div>
    }
    else if (!packages.Any())
    {
        <div class="empty-venues">
            <p>No menus are available yet.</p>
        </div>
    }
    else if (activePackage == null)
    {
        <div class="menu-packages-grid">
            @foreach (var pkg in filteredPackages)
            {
                var p = pkg;
                var isSelected = IsSelected(p);
                <div class="menu-pkg-card @(isSelected ? "menu-pkg-selected" : "")" @key="p.Id">
                    @if (IsSelected(p))
                    {
                        <div class="menu-pkg-booked-badge">
                            @SvgIcons.CheckSmall
                            Your menu
                        </div>
                    }
                    <div class="menu-pkg-header">
                        <div class="menu-pkg-diet-badge diet-@p.DietaryType">@DietLabel(p.DietaryType)</div>
                        <h3 class="menu-pkg-name">@p.Name</h3>
                        <p class="menu-pkg-price">$@p.PricePerPerson<span>/person</span></p>
                        <p class="menu-pkg-desc">@p.Description</p>
                    </div>

                    <div class="menu-pkg-courses">
                        @foreach (var course in p.Courses)
                        {
                            <div class="menu-course-preview">
                                <span class="menu-course-label">@course.Label</span>
                                <span class="menu-course-count">@course.Items.Count items</span>
                            </div>
                        }
                    </div>

                    <div class="menu-pkg-actions">
                        <button class="btn-outline menu-view-btn" @onclick="@(() => { activePackage = p; activeCourse = 0; })">
                            View items
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </button>
                        <button class="menu-book-btn @(isSelected ? "menu-book-active" : "")" @onclick="@(() => ToggleSelect(p))">
                            @if (isSelected)
                            {
                                @SvgIcons.CheckSmall
                                <text>Selected</text>
                            }
                            else
                            {
                                <text>Select menu</text>
                            }
                        </button>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="menu-detail" @key="activePackage.Id">
            <div class="menu-detail-header">
                <button class="venue-back" @onclick="@(() => activePackage = null)">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                    All menus
                </button>
                <div class="menu-detail-title-wrap">
                    <div class="menu-pkg-diet-badge diet-@activePackage.DietaryType">@DietLabel(activePackage.DietaryType)</div>
                    <h2 class="menu-detail-title">@activePackage.Name</h2>
                    <p class="menu-pkg-price">$@activePackage.PricePerPerson<span>/person</span></p>
                </div>
                <button class="menu-book-btn @(IsSelected(activePackage) ? "menu-book-active" : "")"
                        @onclick="@(() => ToggleSelect(activePackage))">
                    @if (IsSelected(activePackage))
                    {
                        @SvgIcons.CheckSmall
                        <text>Selected</text>
                    }
                    else
                    {
                        <text>Select this menu</text>
                    }
                </button>
            </div>
            <div class="menu-course-tabs">
                @for (int i = 0; i < activePackage.Courses.Count; i++)
                {
                    var idx = i;
                    var course = activePackage.Courses[i];
                    <button class="menu-course-tab @(activeCourse == idx ? "course-tab-active" : "")"
                            @onclick="@(() => activeCourse = idx)">
                        @course.Label
                    </button>
                }
            </div>
            <div class="menu-items-grid">
                @foreach (var item in activePackage.Courses[activeCourse].Items)
                {
                    var menuItem = item;
                    <div class="menu-item-card">
                        <div class="menu-item-info">
                            <h4 class="menu-item-name">@menuItem.Name</h4>
                        </div>
                        <div class="menu-item-icon diet-icon-@activePackage.DietaryType">
                            @DietIcon(activePackage.DietaryType)
                        </div>
                    </div>
                }
            </div>
        </div>
    }

</div>

@code {
    [Parameter] public int EventId { get; set; }

    string        dietFilter    = "all";
    MenuPackage?  activePackage = null;
    int           activeCourse  = 0;
    bool          isLoading     = true;
    bool          isSaving      = false;
    string        loadError     = "";
    EventDto?     eventItem;

    Dictionary<string, string> selectedByType = new();
    Dictionary<string, int> menuCounts = new()
    {
        ["standard"] = 0,
        ["vegetarian"] = 0,
        ["vegan"] = 0,
        ["fasting"] = 0
    };

    bool IsSelected(MenuPackage p) => selectedByType.TryGetValue(p.DietaryType, out var id) && id == p.Id;

    async Task ToggleSelect(MenuPackage p)
    {
        if (isSaving)
            return;

        if (IsSelected(p))
        {
            selectedByType.Remove(p.DietaryType);
            EnsureOneMenuSelected();
        }
        else
        {
            selectedByType[p.DietaryType] = p.Id;
        }

        SyncSelectedMenuState();
        await SaveSelectionAsync();
    }

    async Task ClearSelection()
    {
        selectedByType.Clear();
        EnsureOneMenuSelected();
        SyncSelectedMenuState();
        await SaveSelectionAsync();
    }

    List<DietFilter> dietaryFilters = new()
    {
        new("all","All packages"), new("standard","Standard"),
        new("vegetarian","Vegetarian"), new("vegan","Vegan"), new("fasting","Fasting"),
    };

    IEnumerable<(string Menu, int Count, int Available)> GuestMenuBreakdown =>
        dietaryFilters.Where(f => f.Key != "all")
            .Select(f => (
                Menu: f.Key,
                Count: menuCounts.GetValueOrDefault(f.Key),
                Available: packages.Count(p => p.DietaryType == f.Key)));

    string MenuTypeLabel(int count) => count == 1 ? "type of menu" : "types of menu";

    string GuestNeedLabel(int count) => count == 1 ? "guest" : "guests";

    string SelectionSummary =>
        selectedByType.Count == 0 ? "" :
        string.Join(" + ", SelectedMenuNames());

    string SelectionSummaryCompact =>
        selectedByType.Count switch
        {
            0 => "",
            1 => SelectedMenuNames().FirstOrDefault() ?? "",
            _ => $"{selectedByType.Count} menus selected"
        };

    IEnumerable<MenuPackage> filteredPackages =>
        dietFilter == "all" ? packages : packages.Where(p => p.DietaryType == dietFilter);

    string DietLabel(string type) => type switch
    {
        "vegan"      => "Vegan",
        "vegetarian" => "Vegetarian",
        "fasting"    => "Fasting",
        _            => "Standard",
    };

    string DietTagLabel(string tag) => tag switch
    {
        "vegan"      => "Vegan",
        "vegetarian" => "Vegetarian",
        "fasting"    => "Fasting",
        "gf"         => "Gluten-Free",
        _            => tag,
    };

    MarkupString DietIcon(string type) => type switch
    {
        "vegan"      => new MarkupString(@"<svg xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M2 22c1.25-1.25 2.5-2.5 6-4C14 16 18 8 18 2c0 0-6 2-9 6-2 2.67-2.5 5-1 8'/><path d='M6 14c.5-3 3-5.5 6.5-7.5'/></svg>"),
        "vegetarian" => new MarkupString(@"<svg xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z'/><path d='M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12'/></svg>"),
        "fasting"    => new MarkupString(@"<svg xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M7 20c-1.8-3.4-1.2-7.1 1.6-9.9C11.3 7.4 15 6.2 20 5c-.8 4.8-2.2 8.4-4.9 11.1C12.3 18.9 10 20 7 20z'/><path d='M4 21c2.3-5.2 6.2-8.8 11.5-11.2'/></svg>"),
        _            => new MarkupString(@"<svg xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2'/><path d='M7 2v20'/><path d='M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7'/></svg>"),
    };

    async Task SaveSelectionAsync()
    {
        if (eventItem is null)
        {
            loadError = "Create an event first, then select menus.";
            return;
        }

        isSaving = true;
        loadError = "";

        try
        {
            var menuIds = SelectedMenuIds().ToList();
            await Api.UpdateMenuSelectionsAsync(eventItem.EventId, menuIds);
            eventItem.MenuIds = menuIds;
        }
        catch (Exception ex)
        {
            loadError = $"Could not save menu selection: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    Dictionary<string, string> BuildSelectedByType(IReadOnlyCollection<int> menuIds)
    {
        var selected = new Dictionary<string, string>();

        foreach (var menuId in menuIds)
        {
            var package = packages.FirstOrDefault(p => p.Id == menuId.ToString());
            if (package is not null)
                selected[package.DietaryType] = package.Id;
        }

        return selected;
    }

    IEnumerable<int> SelectedMenuIds() =>
        selectedByType.Values
            .Select(value => int.TryParse(value, out var id) ? id : (int?)null)
            .Where(id => id.HasValue)
            .Select(id => id!.Value);

    IEnumerable<string> SelectedMenuNames() =>
        selectedByType.Keys
            .OrderBy(key => key)
            .Select(key => packages.FirstOrDefault(package => package.Id == selectedByType[key])?.Name)
            .Where(name => !string.IsNullOrWhiteSpace(name))!;

    void SyncSelectedMenuState()
    {
        State.SelectMenu(
            string.Join(",", SelectedMenuIds()),
            string.Join(" + ", SelectedMenuNames()));
    }

    List<MenuPackage> packages = [];

    protected override void OnInitialized()
    {
        State.OnChange += Refresh;
    }

    protected override async Task OnParametersSetAsync() => await LoadPageDataAsync();

    async Task LoadPageDataAsync()
    {
        isLoading = true;
        loadError = "";

        try
        {
            if (!await EnsureCurrentEventAsync())
                return;

            await LoadMenusAsync();
            var menuSelections = await Api.GetMenuSelectionsAsync(EventId);
            selectedByType = BuildSelectedByType(menuSelections.Select(menu => menu.MenuId).ToList());
            await EnsureStandardMenuSelectedAsync();
            SyncSelectedMenuState();
            await LoadGuestMenuCountsAsync();
        }
        catch (Exception ex)
        {
            loadError = $"Could not load menus: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    async Task<bool> EnsureCurrentEventAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.IsInRole("Admin"))
        {
            Nav.NavigateTo("/admin", replace: true);
            return false;
        }

        var ownEvent = (await Api.GetEventsAsync()).OrderByDescending(e => e.EventId).FirstOrDefault();
        if (ownEvent is null)
        {
            Nav.NavigateTo("/onboarding", replace: true);
            return false;
        }

        if (EventId <= 0 || EventId != ownEvent.EventId)
        {
            EventId = ownEvent.EventId;
            Nav.NavigateTo($"/menu/{EventId}", replace: true);
            return false;
        }

        eventItem = ownEvent;
        return true;
    }

    async Task EnsureStandardMenuSelectedAsync()
    {
        if (eventItem is null || selectedByType.Count > 0)
            return;

        EnsureOneMenuSelected();
        if (selectedByType.Count > 0)
            await SaveSelectionAsync();
    }

    void EnsureOneMenuSelected()
    {
        if (selectedByType.Count > 0)
            return;

        var fallback = packages
            .Where(package => package.DietaryType == "standard")
            .OrderBy(package => package.Name)
            .FirstOrDefault()
            ?? packages.OrderBy(package => package.Name).FirstOrDefault();

        if (fallback is null)
            return;

        selectedByType[fallback.DietaryType] = fallback.Id;
    }

    async Task LoadMenusAsync()
    {
        try
        {
            var menus = await Api.GetMenusAsync();
            if (menus.Count > 0)
            {
                packages = menus.Select(ToMenuPackage).ToList();
                activePackage = activePackage is null ? null : packages.FirstOrDefault(p => p.Id == activePackage.Id);
                activeCourse = 0;
            }
        }
        catch (Exception ex)
        {
            packages = [];
            loadError = $"Could not load menus: {ex.Message}";
        }
    }

    async Task LoadGuestMenuCountsAsync()
    {
        menuCounts = new()
        {
            ["standard"] = 0,
            ["vegetarian"] = 0,
            ["vegan"] = 0,
            ["fasting"] = 0
        };

        EventDto? eventItem = null;
        var eventId = EventId;
        if (eventId > 0)
            eventItem = await Api.GetEventAsync(eventId);

        eventItem ??= (await Api.GetEventsAsync()).OrderBy(e => e.EventId).FirstOrDefault();
        eventId = eventItem?.EventId ?? 0;

        if (eventItem is null || eventId <= 0)
            return;

        var guests = await Api.GetGuestsAsync(eventId);
        await EnsureCoupleRowsAsync(eventItem, guests);
        var plusOneOwnerIds = guests
            .Where(IsPlusOneGuest)
            .Select(PlusOneOwnerId)
            .Where(id => id.HasValue)
            .Select(id => id!.Value)
            .ToHashSet();

        foreach (var guest in guests.Where(guest => guest.RsvpStatus != RsvpStatus.Declined))
        {
            menuCounts[MenuTypeFor(guest.DietaryRequirements)]++;
            if (guest.HasPlusOne && !plusOneOwnerIds.Contains(guest.GuestId))
                menuCounts["standard"]++;
        }
    }

    const string PlusOneNotePrefix = "Plus one for guest ";
    const string CoupleNotePrefix = "Wedding couple:";
    const string BrideCoupleNote = "Wedding couple: bride";
    const string GroomCoupleNote = "Wedding couple: groom";
    static readonly Regex GuestNamePattern = new(@"^[\p{L}\p{M}][\p{L}\p{M}' -]*$", RegexOptions.Compiled);

    static bool IsPlusOneGuest(GuestDto guest) =>
        guest.Notes?.StartsWith(PlusOneNotePrefix, StringComparison.OrdinalIgnoreCase) == true;

    async Task EnsureCoupleRowsAsync(EventDto eventItem, List<GuestDto> guests)
    {
        await EnsureCoupleRowAsync(eventItem, guests, BrideCoupleNote, eventItem.BrideName, "Bride", Gender.Female);
        await EnsureCoupleRowAsync(eventItem, guests, GroomCoupleNote, eventItem.GroomName, "Groom", Gender.Male);
    }

    async Task EnsureCoupleRowAsync(
        EventDto eventItem,
        List<GuestDto> guests,
        string note,
        string? fullName,
        string fallbackRole,
        Gender gender)
    {
        var existing = guests.FirstOrDefault(g => string.Equals(g.Notes?.Trim(), note, StringComparison.OrdinalIgnoreCase));
        var desired = BuildCoupleCreateDto(eventItem.EventId, fullName, fallbackRole, note, gender, existing?.DietaryRequirements ?? DietaryRequirements.Standard);

        if (existing is null)
        {
            var created = await Api.CreateGuestAsync(eventItem.EventId, desired);
            if (created is not null)
                guests.Add(created);
            return;
        }

        if (existing.FirstName == desired.FirstName &&
            existing.LastName == desired.LastName &&
            existing.Email == desired.Email &&
            existing.RsvpStatus == RsvpStatus.Confirmed &&
            existing.Group == GuestGroup.Family &&
            existing.HasPlusOne == false &&
            existing.Gender == gender)
        {
            return;
        }

        existing.FirstName = desired.FirstName;
        existing.LastName = desired.LastName;
        existing.Email = desired.Email;
        existing.RsvpStatus = RsvpStatus.Confirmed;
            existing.Group = GuestGroup.Family;
        existing.HasPlusOne = false;
        existing.Gender = gender;
        existing.Notes = note;
        await Api.UpdateGuestAsync(eventItem.EventId, existing.GuestId, ToUpdateDto(existing));
    }

    static GuestCreateDto BuildCoupleCreateDto(
        int eventId,
        string? fullName,
        string fallbackRole,
        string note,
        Gender gender,
        DietaryRequirements dietary)
    {
        var (firstName, lastName) = CoupleNameParts(fullName, fallbackRole);
        return new()
        {
            FirstName = firstName,
            LastName = lastName,
            Email = $"couple-{fallbackRole.ToLowerInvariant()}-{eventId}@wedding.local",
            Gender = gender,
            RsvpStatus = RsvpStatus.Confirmed,
            Group = GuestGroup.Family,
            DietaryRequirements = dietary,
            HasPlusOne = false,
            Notes = note
        };
    }

    static GuestUpdateDto ToUpdateDto(GuestDto guest) => new()
    {
        TableId = guest.TableId,
        FirstName = guest.FirstName.Trim(),
        LastName = guest.LastName.Trim(),
        Age = guest.Age,
        Email = guest.Email.Trim(),
        Phone = string.IsNullOrWhiteSpace(guest.Phone) ? null : guest.Phone.Trim(),
        Gender = guest.Gender,
        RsvpStatus = guest.RsvpStatus,
        Group = guest.Group,
        DietaryRequirements = guest.DietaryRequirements,
        HasPlusOne = guest.HasPlusOne,
        SeatNumber = guest.SeatNumber,
        Notes = string.IsNullOrWhiteSpace(guest.Notes) ? null : guest.Notes,
    };

    static (string FirstName, string LastName) CoupleNameParts(string? fullName, string fallbackRole)
    {
        var name = string.IsNullOrWhiteSpace(fullName) ? fallbackRole : fullName.Trim();
        if (!GuestNamePattern.IsMatch(name))
            name = fallbackRole;

        var parts = name.Split(' ', 2, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 0)
            return (fallbackRole, "Partner");

        if (parts.Length == 1)
            return (parts[0], fallbackRole);

        return (parts[0], parts[1]);
    }

    static int? PlusOneOwnerId(GuestDto guest)
    {
        if (!IsPlusOneGuest(guest))
            return null;

        var idText = guest.Notes![PlusOneNotePrefix.Length..].Trim();
        return int.TryParse(idText, out var ownerId) ? ownerId : null;
    }

    static string MenuTypeFor(DietaryRequirements dietary) => dietary switch
    {
        DietaryRequirements.Vegan => "vegan",
        DietaryRequirements.Vegetarian => "vegetarian",
        DietaryRequirements.Fasting => "fasting",
        _ => "standard"
    };

    static MenuPackage ToMenuPackage(MenuDto menu)
    {
        var courses = menu.MenuItems
            .GroupBy(item => string.IsNullOrWhiteSpace(item.CourseName) ? "Items" : item.CourseName)
            .OrderBy(group => group.Min(item => item.DisplayOrder))
            .Select(group => new Course(
                group.Key,
                group
                    .OrderBy(item => item.DisplayOrder)
                    .Select(item => new WeddingPlannerApp.Components.PagesPaula.MenuComponents.MenuItem(
                        item.Name,
                        item.Description ?? "",
                        []))
                    .ToList()))
            .ToList();

        if (courses.Count == 0)
            courses.Add(new Course("Items", []));

        return new MenuPackage(
            menu.MenuId.ToString(),
            menu.Name,
            menu.DietaryType.ToString().ToLowerInvariant(),
            (int)menu.Price,
            menu.Description ?? "",
            courses);
    }

    void Refresh() => InvokeAsync(StateHasChanged);
    public void Dispose() => State.OnChange -= Refresh;
}
