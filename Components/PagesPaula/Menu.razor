@page "/menu"
@page "/menu/{EventId:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@layout PaulaLayout
@rendermode InteractiveServer
@inject WeddingPlannerApp.Services.WeddingStateService State
@inject WeddingPlannerApp.Services.WeddingApiClient Api
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@using Microsoft.AspNetCore.Components.Authorization
@using WeddingPlannerApp.Components.LayoutPaula
@using WeddingPlannerApp.Components.PagesPaula.MenuComponents
@using WeddingPlannerApp.DTOs.Event
@using WeddingPlannerApp.DTOs.Guest
@using WeddingPlannerApp.Models
@implements IDisposable

<PageNav Title="Menu"
         Subtitle="@(string.IsNullOrEmpty(State.SelectedMenuName) ? "Choose your wedding menu package" : $"{State.SelectedMenuName} selected")"
         IconSvg="@SvgIcons.MenuNav" />

<div class="menu-page">
    <div class="menu-filter-bar">
        <span class="menu-filter-label">Filter by dietary:</span>
        @foreach (var f in dietaryFilters)
        {
            var ff = f;
            <button class="menu-diet-btn @(dietFilter == ff.Key ? "menu-diet-active" : "")"
                    @onclick="@(() => { dietFilter = ff.Key; activePackage = null; })">
                @ff.Label
            </button>
        }
    </div>

    <div class="menu-count-grid">
        @foreach (var item in GuestMenuBreakdown)
        {
            <div class="menu-count-card count-@item.Menu">
                <span class="menu-count-icon diet-icon-@item.Menu">@DietIcon(item.Menu)</span>
                <span class="menu-count-label">@DietLabel(item.Menu)</span>
                <div class="menu-count-split">
                    <div class="menu-count-stat">
                        <strong>@item.Available</strong>
                        <span>@MenuTypeLabel(item.Available)</span>
                    </div>
                    <div class="menu-count-stat">
                        <strong>@item.Count</strong>
                        <span>@GuestNeedLabel(item.Count)</span>
                    </div>
                </div>
            </div>
        }
    </div>
    @if (showGuestCountNotice)
    {
        <div class="menu-count-note">
            <div>
                @SvgIcons.CheckSmall
                <span>Guest counts use RSVP guests and plus-ones. The couple is not added automatically.</span>
            </div>
            <button class="menu-count-note-close"
                    type="button"
                    title="Dismiss"
                    aria-label="Dismiss guest count note"
                    @onclick="@(() => showGuestCountNotice = false)">
                x
            </button>
        </div>
    }

    @if (selectedByType.Count > 0)
    {
        <div class="menu-selection-summary">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Selected: <strong>@SelectionSummary</strong></span>
            <button class="task-filter-btn" style="font-size:.72rem;padding:.2rem .55rem;" @onclick="ClearSelection">Clear all</button>
        </div>
    }

    @if (isLoading)
    {
        <div class="empty-venues">
            <p>Loading menus...</p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(loadError))
    {
        <div class="error-banner">@SvgIcons.AlertCircle @loadError</div>
    }
    else if (!packages.Any())
    {
        <div class="empty-venues">
            <p>No menus are available yet.</p>
        </div>
    }
    else if (activePackage == null)
    {
        <div class="menu-packages-grid">
            @foreach (var pkg in filteredPackages)
            {
                var p = pkg;
                var isSelected = IsSelected(p);
                <div class="menu-pkg-card @(isSelected ? "menu-pkg-selected" : "")" @key="p.Id">
                    @if (IsSelected(p))
                    {
                        <div class="menu-pkg-booked-badge">
                            @SvgIcons.CheckSmall
                            Your menu
                        </div>
                    }
                    <div class="menu-pkg-header">
                        <div class="menu-pkg-diet-badge diet-@p.DietaryType">@DietLabel(p.DietaryType)</div>
                        <h3 class="menu-pkg-name">@p.Name</h3>
                        <p class="menu-pkg-price">$@p.PricePerPerson<span>/person</span></p>
                        <p class="menu-pkg-desc">@p.Description</p>
                    </div>

                    <div class="menu-pkg-courses">
                        @foreach (var course in p.Courses)
                        {
                            <div class="menu-course-preview">
                                <span class="menu-course-label">@course.Label</span>
                                <span class="menu-course-count">@course.Items.Count items</span>
                            </div>
                        }
                    </div>

                    <div class="menu-pkg-actions">
                        <button class="btn-outline menu-view-btn" @onclick="@(() => { activePackage = p; activeCourse = 0; })">
                            View items
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </button>
                        <button class="menu-book-btn @(isSelected ? "menu-book-active" : "")" @onclick="@(() => ToggleSelect(p))">
                            @if (isSelected)
                            {
                                @SvgIcons.CheckSmall
                                <text>Selected</text>
                            }
                            else
                            {
                                <text>Select menu</text>
                            }
                        </button>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="menu-detail" @key="activePackage.Id">
            <div class="menu-detail-header">
                <button class="venue-back" @onclick="@(() => activePackage = null)">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                    All menus
                </button>
                <div class="menu-detail-title-wrap">
                    <div class="menu-pkg-diet-badge diet-@activePackage.DietaryType">@DietLabel(activePackage.DietaryType)</div>
                    <h2 class="menu-detail-title">@activePackage.Name</h2>
                    <p class="menu-pkg-price">$@activePackage.PricePerPerson<span>/person</span></p>
                </div>
                <button class="menu-book-btn @(IsSelected(activePackage) ? "menu-book-active" : "")"
                        @onclick="@(() => ToggleSelect(activePackage))">
                    @if (IsSelected(activePackage))
                    {
                        @SvgIcons.CheckSmall
                        <text>Selected</text>
                    }
                    else
                    {
                        <text>Select this menu</text>
                    }
                </button>
            </div>
            <div class="menu-course-tabs">
                @for (int i = 0; i < activePackage.Courses.Count; i++)
                {
                    var idx = i;
                    var course = activePackage.Courses[i];
                    <button class="menu-course-tab @(activeCourse == idx ? "course-tab-active" : "")"
                            @onclick="@(() => activeCourse = idx)">
                        @course.Label
                    </button>
                }
            </div>
            <div class="menu-items-grid">
                @foreach (var item in activePackage.Courses[activeCourse].Items)
                {
                    var menuItem = item;
                    <div class="menu-item-card">
                        <div class="menu-item-info">
                            <h4 class="menu-item-name">@menuItem.Name</h4>
                        </div>
                        <div class="menu-item-icon diet-icon-@activePackage.DietaryType">
                            @DietIcon(activePackage.DietaryType)
                        </div>
                    </div>
                }
            </div>
        </div>
    }

</div>

@code {
    [Parameter] public int EventId { get; set; }

    string        dietFilter    = "all";
    MenuPackage?  activePackage = null;
    int           activeCourse  = 0;
    bool          showGuestCountNotice = true;
    bool          isLoading     = true;
    bool          isSaving      = false;
    string        loadError     = "";
    EventDto?     eventItem;

    Dictionary<string, string> selectedByType = new();
    Dictionary<string, int> menuCounts = new()
    {
        ["standard"] = 0,
        ["vegetarian"] = 0,
        ["vegan"] = 0,
        ["fasting"] = 0
    };

    bool IsSelected(MenuPackage p) => selectedByType.TryGetValue(p.DietaryType, out var id) && id == p.Id;

    async Task ToggleSelect(MenuPackage p)
    {
        if (isSaving)
            return;

        if (IsSelected(p)) selectedByType.Remove(p.DietaryType);
        else selectedByType[p.DietaryType] = p.Id;

        SyncSelectedMenuState();
        await SaveSelectionAsync();
    }

    async Task ClearSelection()
    {
        selectedByType.Clear();
        SyncSelectedMenuState();
        await SaveSelectionAsync();
    }

    List<DietFilter> dietaryFilters = new()
    {
        new("all","All packages"), new("standard","Standard"),
        new("vegetarian","Vegetarian"), new("vegan","Vegan"), new("fasting","Fasting"),
    };

    IEnumerable<(string Menu, int Count, int Available)> GuestMenuBreakdown =>
        dietaryFilters.Where(f => f.Key != "all")
            .Select(f => (
                Menu: f.Key,
                Count: menuCounts.GetValueOrDefault(f.Key),
                Available: packages.Count(p => p.DietaryType == f.Key)));

    string MenuTypeLabel(int count) => count == 1 ? "type of menu" : "types of menu";

    string GuestNeedLabel(int count) => count == 1 ? "guest" : "guests";

    string SelectionSummary =>
        selectedByType.Count == 0 ? "" :
        string.Join(" + ", SelectedMenuNames());

    IEnumerable<MenuPackage> filteredPackages =>
        dietFilter == "all" ? packages : packages.Where(p => p.DietaryType == dietFilter);

    string DietLabel(string type) => type switch
    {
        "vegan"      => "Vegan",
        "vegetarian" => "Vegetarian",
        "fasting"    => "Fasting",
        _            => "Standard",
    };

    string DietTagLabel(string tag) => tag switch
    {
        "vegan"      => "Vegan",
        "vegetarian" => "Vegetarian",
        "fasting"    => "Fasting",
        "gf"         => "Gluten-Free",
        _            => tag,
    };

    MarkupString DietIcon(string type) => type switch
    {
        "vegan"      => new MarkupString(@"<svg xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M2 22c1.25-1.25 2.5-2.5 6-4C14 16 18 8 18 2c0 0-6 2-9 6-2 2.67-2.5 5-1 8'/><path d='M6 14c.5-3 3-5.5 6.5-7.5'/></svg>"),
        "vegetarian" => new MarkupString(@"<svg xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z'/><path d='M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12'/></svg>"),
        "fasting"    => new MarkupString(@"<svg xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M7 20c-1.8-3.4-1.2-7.1 1.6-9.9C11.3 7.4 15 6.2 20 5c-.8 4.8-2.2 8.4-4.9 11.1C12.3 18.9 10 20 7 20z'/><path d='M4 21c2.3-5.2 6.2-8.8 11.5-11.2'/></svg>"),
        _            => new MarkupString(@"<svg xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2'/><path d='M7 2v20'/><path d='M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7'/></svg>"),
    };

    async Task SaveSelectionAsync()
    {
        if (eventItem is null)
        {
            loadError = "Create an event first, then select menus.";
            return;
        }

        isSaving = true;
        loadError = "";

        try
        {
            var menuIds = SelectedMenuIds().ToList();
            await Api.UpdateEventAsync(eventItem.EventId, new EventUpdateDto
            {
                VenueId = eventItem.VenueId,
                MenuIds = menuIds,
                Name = eventItem.Name,
                BrideName = eventItem.BrideName,
                GroomName = eventItem.GroomName,
                EventDate = eventItem.EventDate,
                EstimatedGuests = eventItem.EstimatedGuests,
                TotalBudget = eventItem.TotalBudget,
                Notes = eventItem.Notes
            });

            eventItem.MenuIds = menuIds;
        }
        catch (Exception ex)
        {
            loadError = $"Could not save menu selection: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    Dictionary<string, string> BuildSelectedByType(IReadOnlyCollection<int> menuIds)
    {
        var selected = new Dictionary<string, string>();

        foreach (var menuId in menuIds)
        {
            var package = packages.FirstOrDefault(p => p.Id == menuId.ToString());
            if (package is not null)
                selected[package.DietaryType] = package.Id;
        }

        return selected;
    }

    IEnumerable<int> SelectedMenuIds() =>
        selectedByType.Values
            .Select(value => int.TryParse(value, out var id) ? id : (int?)null)
            .Where(id => id.HasValue)
            .Select(id => id!.Value);

    IEnumerable<string> SelectedMenuNames() =>
        selectedByType.Keys
            .OrderBy(key => key)
            .Select(key => packages.FirstOrDefault(package => package.Id == selectedByType[key])?.Name)
            .Where(name => !string.IsNullOrWhiteSpace(name))!;

    void SyncSelectedMenuState()
    {
        State.SelectMenu(
            string.Join(",", SelectedMenuIds()),
            string.Join(" + ", SelectedMenuNames()));
    }

