        "vegetarian" => new MarkupString(@"<svg xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z'/><path d='M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12'/></svg>"),
        "fasting"    => new MarkupString(@"<svg xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M7 20c-1.8-3.4-1.2-7.1 1.6-9.9C11.3 7.4 15 6.2 20 5c-.8 4.8-2.2 8.4-4.9 11.1C12.3 18.9 10 20 7 20z'/><path d='M4 21c2.3-5.2 6.2-8.8 11.5-11.2'/></svg>"),
        _            => new MarkupString(@"<svg xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2'/><path d='M7 2v20'/><path d='M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7'/></svg>"),
    };
    List<MenuPackage> packages = new()
    {
        new MenuPackage("standard-classic","Classic Elegance","standard",85,"A timeless menu featuring premium meats, seasonal sides and indulgent desserts.",new(){new("Starters",new(){new("Bruschetta al Pomodoro","Toasted sourdough, heirloom tomatoes, basil, aged balsamic",new(){"vegetarian"}),new("Prawn Cocktail","Tiger prawns, Marie Rose sauce, lemon, baby gem lettuce",new(){"gf"}),new("Cream of Mushroom Soup","Wild mushroom veloutÃƒÂ©, truffle oil, chive cream",new(){"vegetarian","gf"})}),new("Main Course",new(){new("Herb-Crusted Chicken","Free-range breast, roasted garlic jus, fondant potato",new(){"gf"}),new("Slow-Roasted Beef Sirloin","28-day aged sirloin, red wine reduction, dauphinoise potato",new(){"gf"}),new("Pan-Seared Salmon","Atlantic salmon, lemon butter, asparagus, new potatoes",new(){"gf"})}),new("Desserts",new(){new("Wedding Cake Slice","Three-tier vanilla sponge, Swiss meringue buttercream",new(){"vegetarian"}),new("CrÃƒÂ¨me BrÃƒÂ»lÃƒÂ©e","Classic vanilla custard, caramelized sugar, fresh berries",new(){"vegetarian","gf"}),new("Chocolate Fondant","Warm dark chocolate cake, vanilla bean ice cream",new(){"vegetarian"})})}),
