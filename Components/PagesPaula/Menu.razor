        new MenuPackage("veg-garden","Garden Fresh","vegetarian",75,"Vibrant vegetarian items showcasing seasonal produce and bold Mediterranean flavours.",new(){new("Starters",new(){new("Caprese Salad","Burrata, heirloom tomatoes, basil pesto, pine nuts",new(){"vegetarian","gf"}),new("Roasted Red Pepper Soup","Charred peppers, smoked paprika, crÃƒÂ¨me fraÃƒÂ®che",new(){"vegetarian","gf"}),new("Cheese & Chutney Board","Artisan cheeses, honeycomb, walnuts, crackers",new(){"vegetarian"})}),new("Main Course",new(){new("Wild Mushroom Risotto","Arborio rice, porcini, parmesan, truffle oil",new(){"vegetarian","gf"}),new("Spinach & Ricotta Cannelloni","Fresh pasta, tomato coulis, parmesan gratin",new(){"vegetarian"}),new("Mediterranean Tart","Roasted vegetables, feta, olive tapenade, shortcrust pastry",new(){"vegetarian"})}),new("Desserts",new(){new("Lemon Posset","Set lemon cream, shortbread, mixed berry compote",new(){"vegetarian","gf"}),new("Tiramisu","Mascarpone, espresso-soaked sponge, cocoa dusting",new(){"vegetarian"})})}),
